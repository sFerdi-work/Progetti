<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>NM Coaching Pro</title>
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#e03a3e">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="NM Coaching">
<meta name="mobile-web-app-capable" content="yes">
<link rel="apple-touch-icon" href="icon-192.png">
<link rel="icon" type="image/png" sizes="192x192" href="icon-192.png">
<link rel="icon" type="image/png" sizes="512x512" href="icon-512.png">
<script>
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('sw.js')
      .then(reg => console.log('[PWA] SW registrato:', reg.scope))
      .catch(err => console.error('[PWA] SW errore:', err));
  });
}
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&family=Barlow+Condensed:wght@300;400;600;700&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --black:#070709;--white:#f0f0f2;--grey-dark:#111115;--grey-mid:#1a1a22;
  --grey-panel:#151519;--grey-line:rgba(255,255,255,0.08);--grey-card:#1c1c24;
  --accent:#e03a3e;--blue:#4a9eff;--green:#2ecc71;--yellow:#f4c430;--purple:#9b59b6;
  --text-muted:#888;--text-soft:#aaa;--text-mid:#c8c8cc;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--black);color:var(--white);font-family:'Inter','Barlow',sans-serif;min-height:100vh;font-size:14px;line-height:1.45;
  background-image:radial-gradient(ellipse at 15% 0%,rgba(224,58,62,0.05) 0%,transparent 55%),
                   radial-gradient(ellipse at 85% 100%,rgba(74,158,255,0.04) 0%,transparent 50%)}

/* ====== LEGGIBILITÀ DESKTOP – override globali ====== */
/* Aumento dimensione minima dei font piccoli inline ovunque tramite selettore d'attributo */
input,select,textarea,button{font-size:13.5px}
label{font-size:12px!important;letter-spacing:1.5px!important}
.tab-btn{font-size:13px!important;letter-spacing:2px!important;padding:10px 16px!important}
.btn-sm{font-size:11px!important;letter-spacing:1.5px!important;padding:7px 14px!important}
.sec-head h2{font-size:17px!important;letter-spacing:3.5px!important}
.brand-title{font-size:20px!important;letter-spacing:5px!important}
.brand-sub{font-size:9px!important;letter-spacing:3px!important}
/* Tutto ciò che era Barlow Condensed (UI dense) ora più leggibile */
.muscle-badge,.tpl-btn,.dtpl-btn,.fa-tab,.tpl-mtab,.fa-result-name,.fa-result-brand,.fa-result-macros,.tl-name,.tl-meta,.tl-badge,.te-title,.tpl-section-head{font-size:12.5px!important;letter-spacing:.8px!important}
.day-tab{font-size:12px!important;letter-spacing:1.5px!important}
.modal-title{font-size:20px!important;letter-spacing:3px!important}
.food-chip{font-size:12.5px!important;letter-spacing:.5px!important;padding:6px 11px!important}
.fc-kcal{font-size:12.5px!important}
.type-chip{font-size:12.5px!important;letter-spacing:1px!important;padding:7px 13px!important}
/* Tabelle dieta/esercizi più leggibili */
.food-input{font-size:13px!important}
.food-name{font-size:13.5px!important}
.food-num{font-size:13px!important}
table th{font-size:11px!important;letter-spacing:1.5px!important;padding:7px 8px!important}
table td{font-size:13px!important;padding:6px 8px!important}
/* Testi muted globali con maggior contrasto */
[style*="color:var(--text-muted)"]{color:#a0a0a8!important}
/* Ingrandimento aggressivo dei testi uppercase micro-label che sono ovunque inline */
[style*="font-size:7px"],[style*="font-size:7.5px"]{font-size:10.5px!important}
[style*="font-size:8px"],[style*="font-size:8.5px"]{font-size:11px!important}
[style*="font-size:9px"],[style*="font-size:9.5px"]{font-size:11.5px!important}
[style*="font-size:10px"]{font-size:12px!important}
[style*="font-size:10.5px"]{font-size:12.5px!important}
[style*="font-size:11px"]:not(.no-resize){font-size:13px!important}
[style*="font-size:11.5px"]{font-size:13px!important}
[style*="font-size:12px"]:not(.no-resize){font-size:13.5px!important}
/* Letter-spacing ridotto sui testi uppercase quando ingranditi (Inter è meno stretto di Barlow Condensed) */
[style*="letter-spacing:3px"]{letter-spacing:1.5px!important}
[style*="letter-spacing:4px"]{letter-spacing:2px!important}
[style*="letter-spacing:5px"]{letter-spacing:2.5px!important}
[style*="letter-spacing:2.5px"]{letter-spacing:1.2px!important}
[style*="letter-spacing:2px"]:not([style*="font-family:'Bebas"]){letter-spacing:1px!important}
/* Font-weight più solido per testi piccoli che diventano uppercase */
[style*="text-transform:uppercase"]{font-weight:600}
nav{background:rgba(7,7,9,0.94);backdrop-filter:blur(22px);border-bottom:1px solid var(--grey-line);
    padding:0 26px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200;height:56px;gap:10px}
.logo-row{display:flex;align-items:center;gap:11px;flex-shrink:0}
.nm-svg{width:36px;height:36px;flex-shrink:0;filter:drop-shadow(0 0 8px rgba(224,58,62,0.45))}
.brand-title{font-family:'Bebas Neue',sans-serif;font-size:18px;letter-spacing:5px;
  background:linear-gradient(135deg,var(--white) 40%,var(--text-soft));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.brand-sub{font-family:'Inter',sans-serif;font-size:7.5px;letter-spacing:4.5px;color:var(--text-muted);margin-top:1px}
.nav-tabs{display:flex;gap:0;flex:1;justify-content:center}
.tab-btn{background:transparent;border:none;color:var(--text-soft);font-family:'Inter',sans-serif;
  font-size:12px;letter-spacing:2px;text-transform:uppercase;padding:8px 14px;cursor:pointer;position:relative;transition:color .2s;font-weight:600}
.tab-btn::after{content:'';position:absolute;bottom:0;left:50%;right:50%;height:1.5px;background:var(--accent);transition:all .25s}
.tab-btn.active,.tab-btn:hover{color:var(--white)}
.tab-btn.active::after{left:10px;right:10px}
  font-family:'Inter',sans-serif;font-size:8px;letter-spacing:1.5px;padding:2px 7px;text-transform:uppercase;margin-left:6px}
.nav-right{display:flex;gap:5px;align-items:center;flex-shrink:0}
.btn-sm{padding:6px 12px;font-family:'Inter',sans-serif;font-size:9.5px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;border:none;transition:all .2s}
.btn-primary{background:var(--white);color:var(--black);font-weight:700}
.btn-ghost{background:transparent;color:var(--text-muted);border:1px solid var(--grey-line)}
.btn-ghost:hover{color:var(--white);border-color:rgba(255,255,255,0.2)}
.btn-accent{background:linear-gradient(135deg,var(--accent),#c0272b);color:var(--white);font-weight:700;box-shadow:0 2px 10px rgba(224,58,62,0.2)}
.btn-accent:hover{box-shadow:0 4px 18px rgba(224,58,62,0.38);transform:translateY(-1px)}
.btn-green{background:var(--green);color:#000;font-weight:700}
.btn-green:hover{background:#27ae60}
.btn-blue{background:var(--blue);color:#000;font-weight:700}
.btn-blue:hover{background:#2980b9}
.page{display:none;animation:fadeUp .3s ease}
.page.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
main{max-width:1280px;margin:0 auto;padding:22px 18px 80px}
.sec-head{display:flex;align-items:center;gap:11px;margin:26px 0 11px}
.sec-head h2{font-family:'Bebas Neue',sans-serif;font-size:15px;letter-spacing:4px;color:var(--text-mid)}
.sec-line{flex:1;height:1px;background:linear-gradient(to right,var(--grey-line),transparent)}
.sec-dot{width:5px;height:5px;background:var(--accent);transform:rotate(45deg);flex-shrink:0;box-shadow:0 0 5px var(--accent)}

/* ─── PRINT ─────────────────────────────────────────────── */
@media print{
  *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important}
  /* Reset overrides di leggibilità schermo */
  [style*="font-size:7px"],[style*="font-size:7.5px"]{font-size:7.5px!important}
  [style*="font-size:8px"],[style*="font-size:8.5px"]{font-size:8.5px!important}
  [style*="font-size:9px"],[style*="font-size:9.5px"]{font-size:9.5px!important}
  [style*="font-size:10px"]{font-size:10px!important}
  [style*="font-size:11px"]{font-size:11px!important}
  [style*="font-size:12px"]{font-size:12px!important}
  nav,#modal_print,.save-bar,.template-bar,.diet-tpl-bar,.btn-add-group,.btn-add-ex,.ex-del,.cal-del-ev,.muscle-badge,.food-library-grid,.summary-strip,.obiettivo_suggestion{display:none!important}
  body{background:#fff!important;color:#111!important}
  main{max-width:100%;padding:0 12mm!important}
  .page{display:none!important}
  #print-area{display:block!important}
  .pr-page{page-break-inside:avoid}
  .pr-header{display:flex;align-items:flex-start;justify-content:space-between;border-bottom:2.5px solid #e03a3e;padding-bottom:10px;margin-bottom:16px}
  .pr-logo-txt{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:6px;color:#e03a3e}
  .pr-sub{font-family:'Inter',sans-serif;font-size:9px;letter-spacing:3px;color:#999;text-transform:uppercase}
  .pr-client-box{background:#f8f8f8;border:1px solid #e0e0e0;padding:10px 14px;margin-bottom:16px;display:grid;grid-template-columns:repeat(3,1fr);gap:6px 14px}
  .pr-field{font-family:'Inter',sans-serif}
  .pr-field .pf-label{font-size:7px;letter-spacing:2.5px;text-transform:uppercase;color:#999;margin-bottom:1px}
  .pr-field .pf-val{font-size:12px;color:#111;font-weight:600}
  .pr-sec{font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:3px;color:#e03a3e;border-bottom:1px solid #fcc;margin:12px 0 7px;padding-bottom:3px}
  .pr-day-head{font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:2px;background:#e03a3e;color:#fff;padding:3px 8px;margin:8px 0 4px;display:inline-block}
  .pr-meal{margin-bottom:7px;page-break-inside:avoid}
  .pr-meal-name{font-family:'Inter',sans-serif;font-size:10px;letter-spacing:2px;font-weight:700;color:#555;text-transform:uppercase;margin-bottom:3px}
  .pr-food-table{width:100%;border-collapse:collapse;font-family:'Inter',sans-serif;font-size:10px}
  .pr-food-table th{background:#f0f0f0;padding:3px 6px;text-align:left;font-size:8px;letter-spacing:2px;text-transform:uppercase;color:#666;font-weight:700}
  .pr-food-table td{padding:2px 6px;border-bottom:1px solid #f0f0f0}
  .pr-food-table tr:nth-child(even) td{background:#fafafa}
  .pr-macro-row{display:flex;gap:18px;margin:8px 0;font-family:'Inter',sans-serif}
  .pr-macro-item{text-align:center}
  .pr-macro-item .pm-val{font-family:'Bebas Neue',sans-serif;font-size:16px;color:#e03a3e}
  .pr-macro-item .pm-lbl{font-size:8px;letter-spacing:2px;text-transform:uppercase;color:#999}
  .pr-ex-table{width:100%;border-collapse:collapse;font-family:'Inter',sans-serif;font-size:10.5px;margin-bottom:7px}
  .pr-ex-table th{background:#111;color:#fff;padding:3px 7px;text-align:left;font-size:8px;letter-spacing:2px;text-transform:uppercase}
  .pr-ex-table td{padding:3px 7px;border-bottom:1px solid #eee}
  .pr-ex-table tr:nth-child(even) td{background:#f8f8f8}
  .pr-group-head{font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:2.5px;color:#fff;background:#222;padding:4px 9px;margin:9px 0 3px;display:block}
  .pr-meta-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-bottom:10px;font-family:'Inter',sans-serif;font-size:10px}
  .pr-meta-item{background:#f5f5f5;padding:6px 9px}
  .pr-meta-item .pm-k{font-size:7.5px;letter-spacing:2px;text-transform:uppercase;color:#999}
  .pr-meta-item .pm-v{font-size:13px;font-family:'Bebas Neue',sans-serif;color:#111}
  .pr-note{font-family:'Barlow',sans-serif;font-size:9.5px;color:#666;border-left:2px solid #e03a3e;padding:5px 10px;margin:8px 0;background:#fff9f9}
  .pr-footer{text-align:center;font-family:'Inter',sans-serif;font-size:8px;letter-spacing:3px;color:#ccc;margin-top:20px;padding-top:8px;border-top:1px solid #eee}
}
#print-area{display:none}

.home-hero{display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-bottom:14px}
.hero-left{background:var(--grey-dark);border:1px solid var(--grey-line);padding:30px 34px;position:relative;overflow:hidden}
.hero-left::before{content:'NM';font-family:'Bebas Neue',sans-serif;font-size:210px;color:rgba(255,255,255,0.018);position:absolute;right:-25px;top:-35px;line-height:1;pointer-events:none;letter-spacing:-8px}
.hero-stat{padding:16px 0;border-bottom:1px solid var(--grey-line)}
.hero-stat:last-child{border-bottom:none}
.hero-stat .hs-label{font-family:'Inter',sans-serif;font-size:8.5px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;margin-bottom:3px}
.hero-stat .hs-val{font-family:'Bebas Neue',sans-serif;font-size:42px;line-height:1;background:linear-gradient(135deg,var(--white),var(--text-mid));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-stat .hs-sub{font-family:'Inter',sans-serif;font-size:9.5px;color:var(--text-muted);margin-top:2px}
.home-actions{display:grid;grid-template-columns:1fr 1fr;gap:2px;align-content:start}
.action-card{background:var(--grey-panel);border:1px solid var(--grey-line);padding:20px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden}
.action-card:hover{background:var(--grey-mid);border-color:rgba(255,255,255,0.13);transform:translateY(-1px)}
.action-card .ac-icon{font-size:19px;margin-bottom:9px}
.action-card .ac-title{font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:2.5px}
.action-card .ac-sub{font-family:'Inter',sans-serif;font-size:8.5px;letter-spacing:2px;color:var(--text-muted);text-transform:uppercase;margin-top:3px}
.alert-strip{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-bottom:14px}
.alert-item{background:var(--grey-dark);border:1px solid var(--grey-line);padding:14px 16px;display:flex;align-items:center;gap:10px}
.alert-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.alert-dot.red{background:var(--accent);box-shadow:0 0 6px var(--accent)}
.alert-dot.yellow{background:var(--yellow);box-shadow:0 0 6px var(--yellow)}
.alert-dot.green{background:var(--green);box-shadow:0 0 6px var(--green)}
.alert-label{font-family:'Inter',sans-serif;font-size:9.5px;letter-spacing:2px;color:var(--text-muted);text-transform:uppercase}
.alert-val{font-family:'Bebas Neue',sans-serif;font-size:20px;margin-left:auto}
.client-row-home{display:flex;align-items:center;gap:13px;padding:12px 15px;background:var(--grey-dark);border:1px solid var(--grey-line);margin-bottom:2px;cursor:pointer;transition:all .2s}
.client-row-home:hover{background:var(--grey-mid);border-color:rgba(255,255,255,0.11);transform:translateX(2px)}
.cr-avatar{width:33px;height:33px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:12px;flex-shrink:0}
.cr-name{font-family:'Inter',sans-serif;font-size:13px;font-weight:600;letter-spacing:1px}
.cr-info{font-family:'Inter',sans-serif;font-size:9.5px;color:var(--text-muted);margin-top:2px}
.cr-badge{margin-left:auto;font-family:'Inter',sans-serif;font-size:8.5px;letter-spacing:2px;padding:2px 7px;text-transform:uppercase}
.cr-badge.ab{background:rgba(46,204,113,0.11);color:var(--green);border:1px solid rgba(46,204,113,0.2)}
.cr-badge.wb{background:rgba(244,196,48,0.11);color:var(--yellow);border:1px solid rgba(244,196,48,0.2)}
.cr-badge.nb{background:rgba(255,255,255,0.04);color:var(--text-muted);border:1px solid var(--grey-line)}

/* CLIENTS */
.clients-layout{display:grid;grid-template-columns:265px 1fr;gap:2px;min-height:600px}
.sidebar-clients{background:var(--grey-dark);border:1px solid var(--grey-line)}
.sidebar-top{padding:11px 13px;border-bottom:1px solid var(--grey-line);display:flex;gap:5px}
.sidebar-search{flex:1;background:transparent;border:1px solid var(--grey-line);color:var(--white);font-family:'Inter',sans-serif;font-size:11px;letter-spacing:1px;padding:5px 9px;outline:none;transition:border-color .2s}
.sidebar-search:focus{border-color:rgba(255,255,255,0.22)}
.sidebar-search::placeholder{color:var(--text-muted)}
.client-item{padding:10px 13px;cursor:pointer;border-bottom:1px solid var(--grey-line);transition:all .2s;display:flex;align-items:center;gap:9px}
.client-item:hover{background:var(--grey-mid)}
.client-item.selected{background:rgba(224,58,62,0.06);border-left:2px solid var(--accent)}
.ci-avatar{width:27px;height:27px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:11px;flex-shrink:0}
.ci-info .ci-name{font-family:'Inter',sans-serif;font-size:12px;font-weight:600;letter-spacing:1px}
.ci-info .ci-sub{font-family:'Inter',sans-serif;font-size:9px;color:var(--text-muted);margin-top:1px}
.ci-exp{margin-left:auto;width:5px;height:5px;border-radius:50%;flex-shrink:0}
.client-detail{background:var(--grey-panel);border:1px solid var(--grey-line)}
.detail-tabs{display:flex;border-bottom:1px solid var(--grey-line);overflow-x:auto}
.dtab{padding:10px 16px;font-family:'Inter',sans-serif;font-size:9.5px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;color:var(--text-muted);border-bottom:1.5px solid transparent;transition:all .2s;white-space:nowrap;flex-shrink:0}
.dtab.active{color:var(--white);border-bottom-color:var(--accent)}

/* SAVE BAR — always at bottom of detail */
.save-bar{
  position:sticky;bottom:0;background:rgba(7,7,9,0.96);backdrop-filter:blur(10px);
  border-top:1px solid var(--grey-line);padding:10px 20px;
  display:flex;align-items:center;gap:10px;z-index:50;
}
.save-bar .sb-info{font-family:'Inter',sans-serif;font-size:10px;letter-spacing:2px;color:var(--text-muted);text-transform:uppercase;flex:1}
.save-bar .sb-name{color:var(--white);font-weight:600}

.detail-body{padding:18px 20px}
.detail-body.hidden{display:none}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:2px}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.grid-2{display:grid;grid-template-columns:repeat(2,1fr);gap:2px}
.m-card{background:var(--grey-dark);padding:12px 13px;border:1px solid transparent;transition:all .15s}
.m-card:hover{background:var(--grey-mid);border-color:var(--grey-line)}
.m-card:focus-within{border-color:rgba(224,58,62,0.28)}
.m-card .mlabel{font-family:'Inter',sans-serif;font-size:8px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;margin-bottom:6px}
.m-row{display:flex;align-items:baseline;gap:5px}
.m-card input[type=number],.m-card input[type=text]{background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.09);color:var(--white);font-family:'Bebas Neue',sans-serif;font-size:22px;width:100%;outline:none;padding:0;transition:border-color .2s;-moz-appearance:textfield}
.m-card input:focus{border-bottom-color:rgba(224,58,62,0.55)}
.m-card input::-webkit-outer-spin-button,.m-card input::-webkit-inner-spin-button{-webkit-appearance:none}
.m-unit{font-family:'Inter',sans-serif;font-size:9.5px;color:var(--text-muted);white-space:nowrap}
.computed-val{font-family:'Bebas Neue',sans-serif;font-size:22px;border-bottom:1px solid rgba(255,255,255,0.05);min-height:30px;padding-bottom:2px}
.field{margin-bottom:12px}
.field label{display:block;font-family:'Inter',sans-serif;font-size:8.5px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;margin-bottom:5px}
.field input,.field select,.field textarea{background:var(--grey-dark);border:1px solid var(--grey-line);color:var(--white);font-family:'Barlow',sans-serif;font-size:12.5px;padding:7px 11px;width:100%;outline:none;transition:border-color .2s}
.field input:focus,.field select:focus,.field textarea:focus{border-color:rgba(224,58,62,0.38)}
.field select option{background:#161618}
.field textarea{resize:vertical;min-height:62px}
.anagrafica-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px}
.anagrafica-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:9px}
.summary-strip{display:grid;grid-template-columns:repeat(5,1fr);gap:2px;margin-top:18px}
.s-card{background:var(--grey-panel);padding:13px 15px;border:1px solid var(--grey-line);border-top:2px solid rgba(224,58,62,0.28)}
.s-card .s-label{font-family:'Inter',sans-serif;font-size:7.5px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;margin-bottom:3px}
.s-card .s-val{font-family:'Bebas Neue',sans-serif;font-size:26px;line-height:1}
.s-card .s-unit{font-family:'Inter',sans-serif;font-size:9.5px;color:var(--text-muted);margin-left:2px}

/* SCADENZE */
.scad-strip{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;margin-bottom:14px}
.scad-card{background:var(--grey-dark);border:1px solid var(--grey-line);padding:13px 15px;border-top:2px solid transparent}
.scad-card.ok{border-top-color:var(--green)}.scad-card.warn{border-top-color:var(--yellow)}.scad-card.crit{border-top-color:var(--accent)}
.scad-card .sc-label{font-family:'Inter',sans-serif;font-size:7.5px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;margin-bottom:4px}
.scad-card .sc-date{font-family:'Bebas Neue',sans-serif;font-size:18px;line-height:1}
.scad-card .sc-days{font-family:'Inter',sans-serif;font-size:9.5px;margin-top:3px}

/* WORKOUT */
.workout-meta{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:7px;margin-bottom:14px}
.wm-field{background:var(--grey-dark);padding:9px 11px;border:1px solid var(--grey-line)}
.wm-field label{display:block;font-family:'Inter',sans-serif;font-size:7.5px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;margin-bottom:4px}
.wm-field input,.wm-field select{background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.09);color:var(--white);font-family:'Inter',sans-serif;font-size:12px;width:100%;outline:none;padding:2px 0}
.wm-field select option{background:#161618}
.template-bar{background:var(--grey-dark);border:1px solid var(--grey-line);padding:12px 14px;margin-bottom:11px;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.template-bar span{font-family:'Inter',sans-serif;font-size:8px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase}
.tpl-btn{background:rgba(74,158,255,0.07);border:1px solid rgba(74,158,255,0.18);color:var(--blue);font-family:'Inter',sans-serif;font-size:9.5px;letter-spacing:1.5px;padding:4px 10px;cursor:pointer;text-transform:uppercase;transition:all .2s}
.tpl-btn:hover{background:rgba(74,158,255,0.16);border-color:rgba(74,158,255,0.35)}
.ex-table{width:100%;border-collapse:collapse;font-family:'Inter',sans-serif}
.ex-table th{font-size:7.5px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;padding:6px 7px;border-bottom:1px solid var(--grey-line);text-align:left;font-weight:400;background:rgba(0,0,0,0.28)}
.ex-table td{padding:3px 4px;border-bottom:1px solid rgba(255,255,255,0.025)}
.ex-table tr:hover td{background:rgba(255,255,255,0.012)}
.ex-input{background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.07);color:var(--white);font-family:'Inter',sans-serif;font-size:12px;width:100%;outline:none;padding:4px 3px;transition:border-color .2s}
.ex-input:focus{border-bottom-color:rgba(224,58,62,0.38)}
.ex-input.exname{font-size:12px;font-weight:600}
.ex-input.exnum{text-align:center}
.ex-input.exnote{font-size:10px;color:var(--text-soft)}
.ex-del{background:transparent;border:none;color:var(--text-muted);cursor:pointer;font-size:13px;padding:2px 5px;transition:color .15s}
.ex-del:hover{color:var(--accent)}
.group-header{background:rgba(255,255,255,0.022);padding:8px 11px;display:flex;align-items:center;gap:9px;margin:7px 0 2px;border-left:2px solid var(--accent)}
.btn-add-ex{background:transparent;border:1px dashed rgba(255,255,255,0.09);color:var(--text-muted);font-family:'Inter',sans-serif;font-size:9.5px;letter-spacing:2px;text-transform:uppercase;padding:6px 13px;cursor:pointer;width:100%;margin-top:4px;transition:all .2s}
.btn-add-ex:hover{border-color:rgba(255,255,255,0.22);color:var(--white)}
.btn-add-group{background:transparent;border:1px solid rgba(255,255,255,0.07);color:var(--text-soft);font-family:'Inter',sans-serif;font-size:9.5px;letter-spacing:2px;padding:5px 11px;cursor:pointer;transition:all .2s}
.btn-add-group:hover{border-color:rgba(255,255,255,0.22);color:var(--white)}
.muscle-badge{display:inline-block;font-family:'Inter',sans-serif;font-size:8.5px;letter-spacing:1px;padding:2px 6px;background:rgba(74,158,255,0.09);color:var(--blue);text-transform:uppercase;margin:1px;cursor:pointer;border:1px solid rgba(74,158,255,0.14);transition:all .2s}
.muscle-badge:hover{background:rgba(74,158,255,0.2)}

/* DIETA 7-giorni */
.diet-day-tabs{display:flex;gap:2px;margin-bottom:10px;flex-wrap:wrap}
.day-tab{padding:5px 11px;font-family:'Inter',sans-serif;font-size:9.5px;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;background:var(--grey-dark);border:1px solid var(--grey-line);color:var(--text-muted);transition:all .2s}
.day-tab.active{background:rgba(46,204,113,0.1);border-color:rgba(46,204,113,0.28);color:var(--green)}
.day-tab.has-data::after{content:'•';margin-left:4px;color:var(--green)}
.diet-meta{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:7px;margin-bottom:12px}
.diet-tpl-bar{background:var(--grey-dark);border:1px solid var(--grey-line);padding:11px 13px;margin-bottom:11px;display:flex;align-items:center;gap:7px;flex-wrap:wrap}
.diet-tpl-bar span{font-family:'Inter',sans-serif;font-size:8px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase}
.dtpl-btn{background:rgba(46,204,113,0.07);border:1px solid rgba(46,204,113,0.18);color:var(--green);font-family:'Inter',sans-serif;font-size:9.5px;letter-spacing:1px;padding:3px 9px;cursor:pointer;text-transform:uppercase;transition:all .2s}
.dtpl-btn:hover{background:rgba(46,204,113,0.16)}
.meal-block{margin-bottom:11px;border:1px solid var(--grey-line);background:var(--grey-dark)}
.meal-head{display:flex;align-items:center;gap:9px;padding:9px 13px;border-bottom:1px solid var(--grey-line);background:rgba(255,255,255,0.018)}
.meal-head input{background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.09);color:var(--white);font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:2px;outline:none;width:170px}
.meal-kcal{margin-left:auto;font-family:'Bebas Neue',sans-serif;font-size:15px;color:var(--yellow)}
.meal-kcal-label{font-family:'Inter',sans-serif;font-size:8px;letter-spacing:2px;color:var(--text-muted);text-transform:uppercase;margin-left:2px}
.food-table{width:100%;border-collapse:collapse;font-family:'Inter',sans-serif}
.food-table th{font-size:7.5px;letter-spacing:2px;color:var(--text-muted);text-transform:uppercase;padding:5px 7px;border-bottom:1px solid rgba(255,255,255,0.035);text-align:left;font-weight:400}
.food-table td{padding:3px 4px;border-bottom:1px solid rgba(255,255,255,0.022)}
.food-table tr:hover td{background:rgba(255,255,255,0.012)}
.food-input{background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.06);color:var(--white);font-family:'Inter',sans-serif;font-size:11.5px;width:100%;outline:none;padding:3px 2px;transition:border-color .2s}
.food-input:focus{border-bottom-color:rgba(46,204,113,0.38)}
.food-input.food-name{font-weight:600}
.food-input.food-num{text-align:center}
.diet-summary{display:grid;grid-template-columns:repeat(5,1fr);gap:2px;margin-top:10px;padding:13px;background:rgba(46,204,113,0.04);border:1px solid rgba(46,204,113,0.1)}
.ds-item .ds-label{font-family:'Inter',sans-serif;font-size:7.5px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;margin-bottom:2px}
.ds-item .ds-val{font-family:'Bebas Neue',sans-serif;font-size:24px;line-height:1}
.ds-item .ds-unit{font-family:'Inter',sans-serif;font-size:9.5px;color:var(--text-muted);margin-left:2px}
.food-library-grid{display:flex;flex-wrap:wrap;gap:3px;margin-top:5px}
.food-chip{background:rgba(46,204,113,0.05);border:1px solid rgba(46,204,113,0.14);color:var(--green);font-family:'Inter',sans-serif;font-size:8.5px;letter-spacing:1px;padding:2px 7px;cursor:pointer;text-transform:uppercase;transition:all .2s;display:flex;align-items:center;gap:4px}
.food-chip:hover{background:rgba(46,204,113,0.14)}
.food-chip .fc-kcal{color:var(--yellow);font-size:9.5px;font-family:'Bebas Neue',sans-serif}

/* PAGAMENTI */
.payments-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:14px}
.pay-card{background:var(--grey-dark);border:1px solid var(--grey-line);padding:15px 17px}
.pay-card .pc-label{font-family:'Inter',sans-serif;font-size:8px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;margin-bottom:9px}
.pay-card .pc-val{font-family:'Bebas Neue',sans-serif;font-size:30px;line-height:1}
.pay-item{display:flex;align-items:center;gap:9px;padding:9px 13px;background:var(--grey-dark);border:1px solid var(--grey-line);margin-bottom:2px}
.pay-item .pi-date{font-family:'Bebas Neue',sans-serif;font-size:15px;line-height:1;min-width:66px}
.pi-desc{font-family:'Inter',sans-serif;font-size:12px;font-weight:600;letter-spacing:1px}
.pi-note{font-family:'Inter',sans-serif;font-size:9.5px;color:var(--text-muted)}
.pi-amt{font-family:'Bebas Neue',sans-serif;font-size:18px;margin-left:auto;color:var(--green)}
.pi-badge{font-family:'Inter',sans-serif;font-size:8.5px;letter-spacing:2px;padding:2px 6px;text-transform:uppercase;margin-left:7px}
.pi-badge.paid{background:rgba(46,204,113,0.1);color:var(--green);border:1px solid rgba(46,204,113,0.2)}
.pi-badge.pending{background:rgba(244,196,48,0.1);color:var(--yellow);border:1px solid rgba(244,196,48,0.2)}
.pi-badge.overdue{background:rgba(224,58,62,0.1);color:var(--accent);border:1px solid rgba(224,58,62,0.2)}

/* CHARTS */
.charts-grid{display:grid;grid-template-columns:1fr 1fr;gap:11px;margin-top:5px}
.chart-card{background:var(--grey-dark);border:1px solid var(--grey-line);padding:17px}
.chart-card.full{grid-column:1/-1}
.chart-card .c-title{font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:3px;margin-bottom:2px}
.chart-card .c-sub{font-family:'Inter',sans-serif;font-size:8.5px;letter-spacing:2px;color:var(--text-muted);text-transform:uppercase;margin-bottom:13px}
.chart-wrap{position:relative;height:210px}.chart-wrap.tall{height:270px}.chart-wrap.small{height:190px}
.kpi-row{display:flex;gap:14px;margin-bottom:11px;flex-wrap:wrap}
.kpi-item .kv{font-family:'Bebas Neue',sans-serif;font-size:22px;line-height:1}
.kpi-item .kl{font-family:'Inter',sans-serif;font-size:7.5px;letter-spacing:2px;color:var(--text-muted);text-transform:uppercase}
.health-row{display:flex;flex-direction:column;gap:6px}
.h-item{display:flex;align-items:center;gap:9px}
.h-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.h-dot.green{background:var(--green)}.h-dot.yellow{background:var(--yellow)}.h-dot.red{background:var(--accent)}
.h-name{font-family:'Inter',sans-serif;font-size:10.5px;letter-spacing:1px;flex:1}
.h-val{font-family:'Bebas Neue',sans-serif;font-size:16px;margin-left:auto}
.h-range{font-family:'Inter',sans-serif;font-size:8.5px;color:var(--text-muted);margin-left:5px}
#somatoCanvas{display:block;margin:0 auto}

/* CALENDAR */
.calendar-layout{display:grid;grid-template-columns:1fr 300px;gap:11px}
.calendar-main{background:var(--grey-dark);border:1px solid var(--grey-line);padding:17px}
.cal-nav{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.cal-month{font-family:'Bebas Neue',sans-serif;font-size:19px;letter-spacing:4px}
.cal-btn{background:transparent;border:1px solid var(--grey-line);color:var(--text-muted);width:28px;height:28px;cursor:pointer;font-size:12px;transition:all .2s;display:flex;align-items:center;justify-content:center}
.cal-btn:hover{border-color:rgba(255,255,255,0.22);color:var(--white)}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px}
.cal-dow{font-family:'Inter',sans-serif;font-size:8px;letter-spacing:3px;color:var(--text-muted);text-align:center;padding:3px 0;text-transform:uppercase}
.cal-day{min-height:60px;background:var(--grey-panel);border:1px solid var(--grey-line);padding:4px 6px;cursor:pointer;transition:all .2s;position:relative}
.cal-day:hover{background:var(--grey-mid);border-color:rgba(255,255,255,0.1)}
.cal-day.today{border-color:var(--accent);box-shadow:inset 0 0 0 1px rgba(224,58,62,0.18)}
.cal-day.selected{border-color:rgba(255,255,255,0.3);background:rgba(255,255,255,0.035)}
.cal-day.has-events::after{content:'';width:4px;height:4px;background:var(--accent);border-radius:50%;position:absolute;top:4px;right:5px;box-shadow:0 0 4px var(--accent)}
.cal-dn{font-family:'Bebas Neue',sans-serif;font-size:15px;line-height:1}
.cal-event{font-family:'Inter',sans-serif;font-size:8.5px;padding:1px 3px;margin-top:2px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
.cal-event.training{background:rgba(74,158,255,0.22);color:var(--blue)}
.cal-event.teams{background:rgba(90,90,200,0.25);color:#9999ff}
.cal-event.zoom{background:rgba(46,164,220,0.22);color:#5bc8f5}
.cal-event.studio{background:rgba(224,58,62,0.2);color:var(--accent)}
.cal-event.phone{background:rgba(46,204,113,0.18);color:var(--green)}
.cal-event.other{background:rgba(244,196,48,0.18);color:var(--yellow)}
.cal-sidebar{display:flex;flex-direction:column;gap:7px}
.cal-day-detail{background:var(--grey-dark);border:1px solid var(--grey-line);padding:14px}
.cal-day-title{font-family:'Bebas Neue',sans-serif;font-size:15px;letter-spacing:3px;margin-bottom:11px}
.cal-events-list{display:flex;flex-direction:column;gap:4px;margin-bottom:12px}
.cal-event-item{background:var(--grey-panel);border:1px solid var(--grey-line);padding:8px 9px;display:flex;align-items:flex-start;gap:8px}
.cal-event-item .ce-bar{width:2px;background:var(--blue);align-self:stretch;flex-shrink:0}
.cal-event-item .ce-bar.teams{background:#9999ff}.cal-event-item .ce-bar.zoom{background:#5bc8f5}.cal-event-item .ce-bar.studio{background:var(--accent)}.cal-event-item .ce-bar.phone{background:var(--green)}.cal-event-item .ce-bar.other{background:var(--yellow)}
.ce-content .ce-time{font-family:'Bebas Neue',sans-serif;font-size:14px;line-height:1}
.ce-content .ce-title{font-family:'Inter',sans-serif;font-size:10.5px;font-weight:600;letter-spacing:1px;margin-top:2px}
.ce-content .ce-client{font-family:'Inter',sans-serif;font-size:8.5px;color:var(--text-muted)}
.cal-del-ev{margin-left:auto;background:transparent;border:none;color:var(--text-muted);cursor:pointer;font-size:12px;padding:0 2px;transition:color .15s}
.cal-del-ev:hover{color:var(--accent)}
.appt-form{background:var(--grey-dark);border:1px solid var(--grey-line);padding:14px}
.appt-form label{display:block;font-family:'Inter',sans-serif;font-size:7.5px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;margin-bottom:4px;margin-top:9px}
.appt-form label:first-of-type{margin-top:0}
.appt-form input,.appt-form select{background:var(--grey-panel);border:1px solid var(--grey-line);color:var(--white);font-family:'Barlow',sans-serif;font-size:12px;padding:6px 8px;width:100%;outline:none;transition:border-color .2s}
.appt-form input:focus,.appt-form select:focus{border-color:rgba(74,158,255,0.38)}
.appt-form select option{background:#161618}
.appt-btn{background:var(--blue);color:#fff;border:none;padding:7px 16px;font-family:'Bebas Neue',sans-serif;font-size:12px;letter-spacing:2px;cursor:pointer;width:100%;margin-top:11px;transition:all .2s}
.appt-btn:hover{background:#2a7fd8}
.note-area{width:100%;background:var(--grey-dark);border:1px solid var(--grey-line);color:var(--white);font-family:'Barlow',sans-serif;font-size:12.5px;padding:9px 13px;resize:vertical;outline:none;min-height:65px;transition:border-color .2s}
.note-area:focus{border-color:rgba(224,58,62,0.32)}
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:55px 18px;color:var(--text-muted)}
.empty-state .es-icon{font-size:35px;margin-bottom:9px;opacity:0.32}
.empty-state p{font-family:'Inter',sans-serif;font-size:11px;letter-spacing:2px;text-transform:uppercase}

/* TEMPLATE MANAGER MODAL */
.tpl-manager-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.82);backdrop-filter:blur(10px);z-index:1100;display:flex;align-items:center;justify-content:center;animation:fadeUp .2s}
.tpl-manager-box{background:var(--grey-dark);border:1px solid rgba(255,255,255,0.13);width:760px;max-width:96vw;max-height:90vh;display:flex;flex-direction:column;box-shadow:0 28px 70px rgba(0,0,0,0.7)}
.tpl-manager-head{padding:18px 22px 14px;border-bottom:1px solid var(--grey-line);display:flex;align-items:center;gap:12px;flex-shrink:0}
.tpl-manager-head h3{font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:4px;flex:1}
.tpl-manager-tabs{display:flex;border-bottom:1px solid var(--grey-line);flex-shrink:0}
.tpl-mtab{padding:9px 18px;font-family:'Inter',sans-serif;font-size:9.5px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;color:var(--text-muted);border-bottom:1.5px solid transparent;transition:all .2s}
.tpl-mtab.active{color:var(--white);border-bottom-color:var(--accent)}
.tpl-manager-body{padding:16px 20px;overflow-y:auto;flex:1}
.tpl-list-row{display:flex;align-items:center;gap:9px;padding:10px 12px;background:var(--grey-panel);border:1px solid var(--grey-line);margin-bottom:3px;transition:all .2s}
.tpl-list-row:hover{background:var(--grey-mid);border-color:rgba(255,255,255,0.1)}
.tpl-list-row .tl-name{font-family:'Inter',sans-serif;font-size:13px;font-weight:600;letter-spacing:1px;flex:1}
.tpl-list-row .tl-meta{font-family:'Inter',sans-serif;font-size:9px;color:var(--text-muted);letter-spacing:1.5px}
.tpl-list-row .tl-badge{font-family:'Inter',sans-serif;font-size:8px;letter-spacing:2px;padding:2px 7px;text-transform:uppercase;background:rgba(74,158,255,0.09);color:var(--blue);border:1px solid rgba(74,158,255,0.18)}
.tpl-list-row .tl-badge.green{background:rgba(46,204,113,0.09);color:var(--green);border-color:rgba(46,204,113,0.18)}
.tpl-edit-form{background:var(--grey-panel);border:1px solid var(--grey-line);padding:16px;margin-top:11px}
.tpl-edit-form .te-title{font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:3px;margin-bottom:14px;color:var(--text-mid)}
.tpl-row-2{display:grid;grid-template-columns:1fr 1fr;gap:9px}
.tpl-row-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px}
.tpl-section-head{font-family:'Inter',sans-serif;font-size:8px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;margin:12px 0 6px;border-bottom:1px solid var(--grey-line);padding-bottom:4px}
.tpl-group-edit{background:var(--grey-dark);border:1px solid var(--grey-line);padding:11px 13px;margin-bottom:5px}
.tpl-group-edit .tge-name{font-family:'Inter',sans-serif;font-size:11px;font-weight:700;letter-spacing:2px;color:var(--text-soft);margin-bottom:7px;display:flex;gap:7px;align-items:center}
.tpl-ex-mini{display:flex;align-items:center;gap:6px;padding:4px 6px;background:rgba(255,255,255,0.025);margin-bottom:2px;border-radius:1px}
.tpl-ex-mini input{background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.07);color:var(--white);font-family:'Inter',sans-serif;font-size:11px;outline:none;padding:2px 2px;transition:border-color .2s}
.tpl-ex-mini input:focus{border-bottom-color:rgba(224,58,62,0.38)}
.tpl-ex-mini .te-del{background:transparent;border:none;color:var(--text-muted);cursor:pointer;font-size:11px;padding:0 3px;transition:color .15s;flex-shrink:0}
.tpl-ex-mini .te-del:hover{color:var(--accent)}
/* MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.78);backdrop-filter:blur(9px);z-index:1000;display:flex;align-items:center;justify-content:center;animation:fadeUp .2s}
.modal-box{background:var(--grey-dark);border:1px solid rgba(255,255,255,0.11);padding:26px;width:490px;max-width:94vw;box-shadow:0 22px 60px rgba(0,0,0,0.6)}
.modal-title{font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:4px;margin-bottom:18px}
.modal-actions{display:flex;gap:7px;justify-content:flex-end;margin-top:18px}

/* Type chips */
.type-chip{display:inline-flex;align-items:center;gap:6px;background:var(--grey-mid);border:1px solid var(--grey-line);padding:5px 11px;font-family:'Inter',sans-serif;font-size:11px;letter-spacing:1.5px;color:var(--white);text-transform:uppercase;font-weight:600}
.type-chip.built{opacity:0.7}
.type-chip.custom{background:rgba(46,204,113,0.08);border-color:rgba(46,204,113,0.3);color:var(--green)}
.type-chip .tc-del{background:transparent;border:none;color:var(--accent);cursor:pointer;font-size:13px;padding:0;line-height:1}
.type-chip .tc-del:hover{color:#ff5050}

/* Food Adder tabs */
.fa-tab{padding:9px 16px;font-family:'Inter',sans-serif;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--text-muted);cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;font-weight:600}
.fa-tab:hover{color:var(--white)}
.fa-tab.active{color:var(--white);border-bottom-color:var(--green)}

/* Food search results */
.fa-result-row{display:flex;align-items:center;gap:10px;padding:9px 12px;border-bottom:1px solid var(--grey-line);cursor:pointer;transition:background .15s}
.fa-result-row:hover{background:rgba(255,255,255,0.04)}
.fa-result-row:last-child{border-bottom:none}
.fa-result-img{width:38px;height:38px;background:var(--grey-mid);border:1px solid var(--grey-line);object-fit:cover;flex-shrink:0}
.fa-result-info{flex:1;min-width:0}
.fa-result-name{font-family:'Barlow',sans-serif;font-size:12px;color:var(--white);font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.fa-result-brand{font-family:'Inter',sans-serif;font-size:9px;letter-spacing:1.5px;color:var(--text-muted);text-transform:uppercase;margin-top:1px}
.fa-result-macros{font-family:'Inter',sans-serif;font-size:10px;color:var(--text-soft);letter-spacing:.5px;flex-shrink:0;text-align:right;line-height:1.4}
.fa-result-macros strong{color:var(--green);font-weight:700}

/* Custom food list */
.fa-custom-row{display:flex;align-items:center;gap:10px;padding:8px 11px;border-bottom:1px solid var(--grey-line);background:rgba(46,204,113,0.03)}
.fa-custom-row:last-child{border-bottom:none}
.fa-custom-name{flex:1;font-family:'Barlow',sans-serif;font-size:12px;color:var(--white)}
.fa-custom-macros{font-family:'Inter',sans-serif;font-size:9.5px;color:var(--text-muted);letter-spacing:1px}

/* Custom food chip mark */
.food-chip.custom-food{background:rgba(46,204,113,0.06)!important;border-left:2px solid var(--green)!important}
.muscle-badge.custom-ex{background:rgba(74,158,255,0.08)!important;border-left:2px solid var(--blue)!important}

/* GCAL status toast */

@media(max-width:980px){
  .clients-layout{grid-template-columns:1fr}.calendar-layout{grid-template-columns:1fr}
  .charts-grid{grid-template-columns:1fr}.chart-card.full{grid-column:1}
  .grid-4{grid-template-columns:repeat(2,1fr)}.anagrafica-grid{grid-template-columns:1fr 1fr}
  .home-hero{grid-template-columns:1fr}.summary-strip{grid-template-columns:repeat(3,1fr)}
  .diet-meta{grid-template-columns:1fr 1fr}.scad-strip{grid-template-columns:1fr}
}

/* ── SUPABASE LOGIN OVERLAY ── */
#sb_login_overlay{
  position:fixed;inset:0;z-index:9000;
  background:radial-gradient(ellipse at 30% 20%,rgba(224,58,62,0.12) 0%,transparent 60%),
             radial-gradient(ellipse at 80% 80%,rgba(74,158,255,0.09) 0%,transparent 55%),
             var(--black);
  display:flex;align-items:center;justify-content:center;
  animation:fadeUp .3s ease;
}
#sb_login_overlay.hidden{display:none}
.sb-login-card{
  width:420px;max-width:94vw;
  background:var(--grey-dark);
  border:1px solid rgba(255,255,255,0.11);
  padding:36px 32px 30px;
  box-shadow:0 28px 80px rgba(0,0,0,0.7);
  position:relative;
}
.sb-login-logo{display:flex;align-items:center;gap:12px;margin-bottom:28px}
.sb-login-logo .brand-title{font-size:22px!important}
.sb-login-logo .brand-sub{font-size:9px!important}
.sb-login-title{font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:4px;color:var(--text-mid);margin-bottom:22px;border-bottom:1px solid var(--grey-line);padding-bottom:12px}
.sb-field{margin-bottom:14px}
.sb-field label{display:block;font-family:'Inter',sans-serif;font-size:9px;letter-spacing:2.5px;text-transform:uppercase;color:var(--text-muted);margin-bottom:5px}
.sb-field input{width:100%;background:var(--grey-panel);border:1px solid var(--grey-line);color:var(--white);font-family:'Barlow',sans-serif;font-size:13px;padding:9px 12px;outline:none;transition:border-color .2s}
.sb-field input:focus{border-color:rgba(224,58,62,0.4)}
.sb-login-btn{width:100%;margin-top:20px;background:linear-gradient(135deg,var(--accent),#c0272b);color:#fff;border:none;font-family:'Bebas Neue',sans-serif;font-size:14px;letter-spacing:3px;padding:12px;cursor:pointer;transition:all .2s;box-shadow:0 4px 18px rgba(224,58,62,0.25)}
.sb-login-btn:hover{box-shadow:0 6px 28px rgba(224,58,62,0.42);transform:translateY(-1px)}
.sb-login-btn:disabled{opacity:0.5;cursor:wait;transform:none}
.sb-login-hint{font-family:'Inter',sans-serif;font-size:9px;letter-spacing:1.5px;color:var(--text-muted);text-align:center;margin-top:14px;cursor:pointer;text-decoration:underline;text-underline-offset:3px}
.sb-login-hint:hover{color:var(--text-soft)}
.sb-config-section{display:none;margin-top:18px;border-top:1px solid var(--grey-line);padding-top:16px}
.sb-config-section.open{display:block}
.sb-config-title{font-family:'Inter',sans-serif;font-size:8px;letter-spacing:2.5px;text-transform:uppercase;color:var(--blue);margin-bottom:10px}
.sb-error{font-family:'Inter',sans-serif;font-size:10.5px;color:var(--accent);letter-spacing:.5px;margin-top:10px;text-align:center;min-height:16px}
.sb-status-dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:5px;vertical-align:middle}
.sb-status-dot.ok{background:var(--green);box-shadow:0 0 6px var(--green)}
.sb-status-dot.ko{background:var(--accent);box-shadow:0 0 6px var(--accent)}
.sb-status-dot.sync{background:var(--yellow);box-shadow:0 0 6px var(--yellow);animation:pulse 1s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}
.sb-nav-status{display:flex;align-items:center;gap:6px;font-family:'Inter',sans-serif;font-size:9px;letter-spacing:1.5px;color:var(--text-muted);cursor:pointer;padding:4px 8px;border:1px solid var(--grey-line);transition:all .2s}
.sb-nav-status:hover{color:var(--white);border-color:rgba(255,255,255,0.2)}
</style>
</head>
<body>

<!-- ════════════════════════════════════════════
     SUPABASE LOGIN OVERLAY
════════════════════════════════════════════ -->
<div id="sb_login_overlay">
  <div class="sb-login-card">
    <div class="sb-login-logo">
      <svg class="nm-svg" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:40px;height:40px;flex-shrink:0;filter:drop-shadow(0 0 8px rgba(224,58,62,0.45))">
        <rect width="100" height="100" fill="#070709"/>
        <polygon points="8,20 8,80 22,80 22,44 36,80 50,80 50,20 36,20 36,56 22,20" fill="#f0f0f2"/>
        <polygon points="52,20 52,80 66,80 66,44 75,62 83,44 83,80 95,80 95,20 83,20 75,44 66,20" fill="#f0f0f2"/>
        <rect x="8" y="16" width="84" height="2.5" fill="#e03a3e" opacity="0.75"/>
      </svg>
      <div>
        <div class="brand-title" style="font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:5px;background:linear-gradient(135deg,#f0f0f2 40%,#aaa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text">NM Coaching</div>
        <div class="brand-sub" style="font-family:'Inter',sans-serif;font-size:9px;letter-spacing:3px;color:#888;margin-top:1px">#TEAMMARINO · PRO</div>
      </div>
    </div>
    <div class="sb-login-title">Accesso — Supabase Cloud</div>

    <div class="sb-field">
      <label>Email</label>
      <input type="email" id="sb_email" placeholder="coach@esempio.com" autocomplete="email" onkeydown="if(event.key==='Enter')sbLogin()">
    </div>
    <div class="sb-field">
      <label>Password</label>
      <input type="password" id="sb_pass" placeholder="••••••••" autocomplete="current-password" onkeydown="if(event.key==='Enter')sbLogin()">
    </div>

    <div id="sb_error" class="sb-error"></div>

    <button class="sb-login-btn" id="sb_login_btn" onclick="sbLogin()">Entra</button>

    <div class="sb-login-hint" onclick="toggleSbConfig()">⚙ Configura connessione Supabase</div>

    <div class="sb-config-section" id="sb_config_section">
      <div class="sb-config-title">Parametri database</div>
      <div class="sb-field">
        <label>Supabase Project URL</label>
        <input type="text" id="sb_url" placeholder="https://xxxx.supabase.co" oninput="sbSaveConfig()">
      </div>
      <div class="sb-field">
        <label>Anon / Public Key</label>
        <input type="text" id="sb_key" placeholder="eyJhbGci..." oninput="sbSaveConfig()">
      </div>
      <div style="font-family:'Inter',sans-serif;font-size:9px;color:var(--text-muted);letter-spacing:1px;line-height:1.6">
        Recupera questi valori dalla dashboard Supabase → Settings → API.<br>
        Vengono salvati in localStorage (solo su questo browser).
      </div>
    </div>

    <div style="margin-top:20px;font-family:'Inter',sans-serif;font-size:8.5px;color:var(--text-muted);letter-spacing:1px;text-align:center;line-height:1.7">
      I tuoi dati sono protetti da Supabase Auth.<br>
      Nessun accesso senza email + password.
    </div>
  </div>
</div>

<nav>
  <div class="logo-row">
    <svg class="nm-svg" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="100" height="100" fill="#070709"/>
      <polygon points="8,20 8,80 22,80 22,44 36,80 50,80 50,20 36,20 36,56 22,20" fill="#f0f0f2"/>
      <polygon points="52,20 52,80 66,80 66,44 75,62 83,44 83,80 95,80 95,20 83,20 75,44 66,20" fill="#f0f0f2"/>
      <rect x="8" y="16" width="84" height="2.5" fill="#e03a3e" opacity="0.75"/>
    </svg>
    <div>
      <div class="brand-title">NM Coaching</div>
      <div class="brand-sub">#TeamMarino · Pro</div>
    </div>
  </div>
  <div class="nav-tabs">
    <button class="tab-btn active" onclick="showPage('home')">Home</button>
    <button class="tab-btn" onclick="showPage('clienti')">Clienti</button>
    <button class="tab-btn" onclick="showPage('grafici')">Grafici</button>
    <button class="tab-btn" onclick="showPage('calendario')">Calendario</button>
  </div>
  <div class="nav-right">
    <div class="sb-nav-status" id="sb_nav_status" onclick="sbShowSyncStatus()" title="Stato connessione Supabase">
      <span class="sb-status-dot ok" id="sb_nav_dot"></span>
      <span id="sb_nav_label">Cloud</span>
    </div>
    <button class="btn-sm btn-ghost" onclick="sbLogout()" id="btn_logout" title="Esci da Supabase">Esci</button>
    <button class="btn-sm btn-ghost" onclick="if(confirm('Reset tutti i dati?')){localStorage.clear();location.reload()}">Reset</button>
    <button class="btn-sm btn-primary" onclick="showPrintModal()">Stampa</button>
  </div>
</nav>

<main>

<!-- HOME -->
<div class="page active" id="page-home">
  <div class="home-hero">
    <div class="hero-left">
      <div style="font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:7px;margin-bottom:3px">Dashboard</div>
      <div style="font-family:'Inter',sans-serif;font-size:9px;color:var(--text-muted);letter-spacing:3px;text-transform:uppercase;margin-bottom:22px">Performance & Analytics</div>
      <div class="hero-stat"><div class="hs-label">Clienti</div><div class="hs-val" id="stat_clienti">0</div><div class="hs-sub">profili registrati</div></div>
      <div class="hero-stat"><div class="hs-label">Appuntamenti</div><div class="hs-val" id="stat_appt">0</div><div class="hs-sub">nel calendario</div></div>
      <div class="hero-stat"><div class="hs-label">Incasso Totale</div><div class="hs-val" id="stat_incasso">€0</div><div class="hs-sub">pagamenti registrati</div></div>
    </div>
    <div class="home-actions">
      <div class="action-card" onclick="showPage('clienti');newClient()"><div class="ac-icon">➕</div><div class="ac-title">Nuovo Cliente</div><div class="ac-sub">Anagrafica completa</div></div>
      <div class="action-card" onclick="showPage('calendario')"><div class="ac-icon">📅</div><div class="ac-title">Calendario</div><div class="ac-sub">+ Google Calendar</div></div>
      <div class="action-card" onclick="showPage('clienti')"><div class="ac-icon">👥</div><div class="ac-title">Lista Clienti</div><div class="ac-sub">Schede & Diete</div></div>
      <div class="action-card" onclick="showPage('grafici')"><div class="ac-icon">📊</div><div class="ac-title">Grafici ISAK</div><div class="ac-sub">Analisi morfologica</div></div>
    </div>
  </div>
  <div class="alert-strip">
    <div class="alert-item"><div class="alert-dot green"></div><div><div class="alert-label">Pagamenti ok</div><div style="font-family:'Inter',sans-serif;font-size:9px;color:var(--text-muted)">Nessuna urgenza</div></div><div class="alert-val" id="stat_pay_ok">0</div></div>
    <div class="alert-item"><div class="alert-dot yellow"></div><div><div class="alert-label">Scadono presto</div><div style="font-family:'Inter',sans-serif;font-size:9px;color:var(--text-muted)">Entro 7 giorni</div></div><div class="alert-val" id="stat_schede_exp">0</div></div>
    <div class="alert-item"><div class="alert-dot red"></div><div><div class="alert-label">Pagamenti scaduti</div><div style="font-family:'Inter',sans-serif;font-size:9px;color:var(--text-muted)">Da rinnovare</div></div><div class="alert-val" id="stat_pay_overdue">0</div></div>
  </div>
  <div class="sec-head"><div class="sec-dot"></div><h2>Clienti Recenti</h2><div class="sec-line"></div></div>
  <div id="home_clients_list"><div class="empty-state"><div class="es-icon">👤</div><p>Nessun cliente — aggiungine uno</p></div></div>
</div>

<!-- CLIENTI -->
<div class="page" id="page-clienti">
  <div class="clients-layout">
    <div class="sidebar-clients">
      <div class="sidebar-top">
        <input class="sidebar-search" type="text" placeholder="Cerca cliente…" oninput="filterClients(this.value)">
        <button class="btn-sm btn-accent" onclick="newClient()" style="flex-shrink:0">+</button>
      </div>
      <div id="clients_sidebar_list"></div>
    </div>
    <div class="client-detail" id="client_detail_panel">
      <div class="empty-state" id="detail_empty" style="height:100%;display:flex"><div class="es-icon">👈</div><p>Seleziona o crea un cliente</p></div>
      <div id="detail_content" style="display:none">
        <div class="detail-tabs">
          <div class="dtab active" onclick="showDtab('anagrafica')">Anagrafica</div>
          <div class="dtab" onclick="showDtab('isak')">Misure ISAK</div>
          <div class="dtab" onclick="showDtab('allenamento')">Allenamento</div>
          <div class="dtab" onclick="showDtab('dieta')">🥗 Dieta</div>
          <div class="dtab" onclick="showDtab('pagamenti')">💳 Pagamenti</div>
          <div class="dtab" onclick="showDtab('foto_cl')">📸 Foto</div>
          <div class="dtab" onclick="showDtab('note_cl')">Note</div>
        </div>

        <!-- ANAGRAFICA -->
        <div class="detail-body" id="dtab-anagrafica">
          <div style="font-family:'Bebas Neue',sans-serif;font-size:19px;letter-spacing:4px;margin-bottom:16px" id="det_nome_title">Nuovo Cliente</div>
          <div class="anagrafica-grid">
            <div class="field"><label>Nome</label><input type="text" id="cl_nome" oninput="updateClientHeader()"></div>
            <div class="field"><label>Cognome</label><input type="text" id="cl_cognome" oninput="updateClientHeader()"></div>
            <div class="field"><label>Data di Nascita</label><input type="date" id="cl_dob"></div>
            <div class="field"><label>Sesso</label><select id="cl_sesso" onchange="syncMSJSesso(this.value)"><option value="">—</option><option value="M">Maschio</option><option value="F">Femmina</option></select></div>
            <div class="field"><label>Email</label><input type="email" id="cl_email"></div>
            <div class="field"><label>Telefono</label><input type="tel" id="cl_tel"></div>
            <div class="field"><label>Città</label><input type="text" id="cl_citta" placeholder="es. Roma, Milano…"></div>
            <div class="field"><label>Provincia</label><input type="text" id="cl_provincia" placeholder="es. RM, MI…" maxlength="2" style="text-transform:uppercase"></div>
            <div class="field"><label>Sport / Disciplina</label><input type="text" id="cl_sport" placeholder="es. Fitness, Calcio…"></div>
            <div class="field"><label>Livello Attività</label>
              <select id="cl_attivita" onchange="computeMSJ()"><option value="">—</option><option>Sedentario</option><option>1-2 volte/sett</option><option>3-5 volte/sett</option><option>Ogni giorno</option><option>Atleta agonista</option></select>
            </div>
            <div class="field"><label>🎯 Obiettivo (genera scheda auto)</label>
              <select id="cl_obiettivo" onchange="onObiettivoChange()">
                <option value="">— Seleziona obiettivo —</option>
                <option value="dimagrimento">Dimagrimento / Perdita peso</option>
                <option value="ipertrofia">Ipertrofia / Aumento massa</option>
                <option value="forza">Forza massimale</option>
                <option value="tonificazione">Tonificazione</option>
                <option value="resistenza">Resistenza / Endurance</option>
                <option value="riabilitazione">Riabilitazione / Benessere</option>
                <option value="sport">Prestazione sportiva</option>
              </select>
            </div>
          </div>
          <div id="obiettivo_suggestion" style="display:none;background:rgba(74,158,255,0.06);border:1px solid rgba(74,158,255,0.2);padding:12px 14px;margin-bottom:14px">
            <div style="font-family:'Inter',sans-serif;font-size:8.5px;letter-spacing:2.5px;color:var(--blue);text-transform:uppercase;margin-bottom:8px">💡 Scheda consigliata per questo obiettivo</div>
            <div id="obiettivo_desc" style="font-family:'Inter',sans-serif;font-size:11.5px;color:var(--text-soft);margin-bottom:10px"></div>
            <div style="display:flex;gap:6px">
              <button class="btn-sm btn-blue" onclick="applyObiettivoTemplate(false)">Carica Allenamento</button>
              <button class="btn-sm btn-green" onclick="applyObiettivoTemplate(true)">Carica anche Dieta</button>
              <button class="btn-sm btn-ghost" onclick="document.getElementById('obiettivo_suggestion').style.display='none'">Ignora</button>
            </div>
          </div>
          <!-- ═══ MIFFLIN–ST JEOR ═══ -->
          <div id="msj_panel" style="background:rgba(46,204,113,0.05);border:1px solid rgba(46,204,113,0.2);padding:14px 16px;margin-bottom:14px">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
              <div style="font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:3px;color:var(--green)">🔥 Fabbisogno Calorico — Mifflin–St Jeor</div>
              <button onclick="computeMSJ()" style="background:rgba(46,204,113,0.15);border:1px solid rgba(46,204,113,0.35);color:var(--green);font-family:'Inter',sans-serif;font-size:9px;letter-spacing:2px;padding:4px 11px;cursor:pointer;text-transform:uppercase;font-weight:700">↺ Ricalcola</button>
            </div>
            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:10px">
              <div class="m-card" style="padding:9px 11px">
                <div class="mlabel">Peso</div>
                <div class="m-row"><input type="number" id="msj_peso" step="0.1" placeholder="—" oninput="computeMSJ()" style="font-family:'Bebas Neue',sans-serif;font-size:20px;background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.09);color:var(--white);width:100%;outline:none;-moz-appearance:textfield"><span class="m-unit">kg</span></div>
              </div>
              <div class="m-card" style="padding:9px 11px">
                <div class="mlabel">Altezza</div>
                <div class="m-row"><input type="number" id="msj_altezza" step="0.1" placeholder="—" oninput="computeMSJ()" style="font-family:'Bebas Neue',sans-serif;font-size:20px;background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.09);color:var(--white);width:100%;outline:none;-moz-appearance:textfield"><span class="m-unit">cm</span></div>
              </div>
              <div class="m-card" style="padding:9px 11px">
                <div class="mlabel">Età</div>
                <div class="m-row"><input type="number" id="msj_eta" step="1" placeholder="—" oninput="computeMSJ()" style="font-family:'Bebas Neue',sans-serif;font-size:20px;background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.09);color:var(--white);width:100%;outline:none;-moz-appearance:textfield"><span class="m-unit">anni</span></div>
              </div>
              <div class="m-card" style="padding:9px 11px">
                <div class="mlabel">Sesso</div>
                <select id="msj_sesso" onchange="computeMSJ()" style="background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.09);color:var(--white);font-family:'Bebas Neue',sans-serif;font-size:18px;width:100%;outline:none;padding:2px 0;cursor:pointer">
                  <option value="">—</option>
                  <option value="M">♂ M</option>
                  <option value="F">♀ F</option>
                </select>
              </div>
            </div>
            <!-- Risultati BMR + TDEE -->
            <div id="msj_results" style="display:none">
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:10px">
                <div style="background:var(--grey-dark);border:1px solid var(--grey-line);padding:10px 13px;text-align:center">
                  <div style="font-family:'Inter',sans-serif;font-size:8px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;margin-bottom:4px">BMR (Riposo)</div>
                  <div style="font-family:'Bebas Neue',sans-serif;font-size:32px;color:var(--green)" id="msj_bmr_val">—</div>
                  <div style="font-family:'Inter',sans-serif;font-size:9px;color:var(--text-muted)">kcal/die</div>
                </div>
                <div style="background:var(--grey-dark);border:1px solid rgba(46,204,113,0.3);padding:10px 13px;text-align:center">
                  <div style="font-family:'Inter',sans-serif;font-size:8px;letter-spacing:3px;color:var(--green);text-transform:uppercase;margin-bottom:4px">TDEE — <span id="msj_attivita_label">—</span></div>
                  <div style="font-family:'Bebas Neue',sans-serif;font-size:32px;color:var(--white)" id="msj_tdee_val">—</div>
                  <div style="font-family:'Inter',sans-serif;font-size:9px;color:var(--text-muted)">kcal/die</div>
                </div>
              </div>
              <!-- Obiettivo calcolato -->
              <div style="background:rgba(46,204,113,0.08);border:1px solid rgba(46,204,113,0.25);padding:10px 13px;margin-bottom:8px">
                <div style="font-family:'Inter',sans-serif;font-size:8px;letter-spacing:3px;color:var(--green);text-transform:uppercase;margin-bottom:6px">🎯 Target per obiettivo: <span id="msj_obiettivo_label" style="color:var(--white)">—</span></div>
                <div style="display:flex;align-items:baseline;gap:8px">
                  <div style="font-family:'Bebas Neue',sans-serif;font-size:38px;color:var(--green)" id="msj_target_val">—</div>
                  <div style="font-family:'Inter',sans-serif;font-size:11px;color:var(--text-muted)">kcal/die</div>
                  <div style="font-family:'Inter',sans-serif;font-size:10px;color:var(--text-soft);margin-left:4px" id="msj_delta_label"></div>
                </div>
                <div style="font-family:'Inter',sans-serif;font-size:10px;color:var(--text-soft);margin-top:4px" id="msj_macro_hint"></div>
              </div>
              <div style="display:flex;gap:6px;align-items:center">
                <button onclick="applyMSJTarget()" style="background:var(--green);color:#000;font-family:'Inter',sans-serif;font-size:9.5px;letter-spacing:2px;font-weight:700;padding:7px 14px;border:none;cursor:pointer;text-transform:uppercase">Applica a Piano Dieta</button>
                <div style="font-family:'Inter',sans-serif;font-size:9px;color:var(--text-muted);letter-spacing:1px">Sovrascrive "Obiettivo Kcal/die" nella tab Dieta</div>
              </div>
            </div>
            <div id="msj_incomplete" style="font-family:'Inter',sans-serif;font-size:10px;color:var(--text-muted);letter-spacing:1px;padding:4px 0">Inserisci peso, altezza, età e sesso per il calcolo automatico.</div>
          </div>
          <!-- ═══ fine MIFFLIN ═══ -->

          <div class="anagrafica-grid-2" style="margin-top:6px">
            <div class="field"><label>Patologie / Controindicazioni</label><textarea id="cl_patologie" rows="2"></textarea></div>
            <div class="field"><label>Integratori / Note Alimentari</label><textarea id="cl_integratori" rows="2"></textarea></div>
          </div>
          <div class="sec-head" style="margin-top:14px"><div class="sec-dot"></div><h2>Scadenze & Rinnovi</h2><div class="sec-line"></div></div>
          <div class="scad-strip">
            <div class="scad-card" id="scad_allenamento_card"><div class="sc-label">Scheda Allenamento</div><div class="sc-date" id="scad_allenamento">—</div><div class="sc-days" id="scad_allenamento_days" style="color:var(--text-muted)">Non impostata</div></div>
            <div class="scad-card" id="scad_dieta_card"><div class="sc-label">Piano Dieta</div><div class="sc-date" id="scad_dieta">—</div><div class="sc-days" id="scad_dieta_days" style="color:var(--text-muted)">Non impostata</div></div>
            <div class="scad-card" id="scad_pag_card"><div class="sc-label">Prossimo Pagamento</div><div class="sc-date" id="scad_pag">—</div><div class="sc-days" id="scad_pag_days" style="color:var(--text-muted)">Non impostato</div></div>
          </div>
          <div class="anagrafica-grid">
            <div class="field"><label>Scad. Scheda Allenamento</label><input type="date" id="cl_scad_all" onchange="updateScadenze()"></div>
            <div class="field"><label>Scad. Piano Dieta</label><input type="date" id="cl_scad_diet" onchange="updateScadenze()"></div>
            <div class="field"><label>Prossimo Pagamento</label><input type="date" id="cl_scad_pag" onchange="updateScadenze()"></div>
          </div>
        </div>

        <!-- ISAK -->
        <div class="detail-body hidden" id="dtab-isak">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
            <div><div style="font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:4px">Misure ISAK</div></div>
            <div style="display:flex;gap:5px;align-items:center">
              <div style="font-family:'Inter',sans-serif;font-size:8.5px;color:var(--text-muted);letter-spacing:2px">Data:</div>
              <input type="date" id="isak_data" style="background:var(--grey-dark);border:1px solid var(--grey-line);color:var(--white);font-family:'Inter',sans-serif;font-size:11px;padding:4px 7px;outline:none">
              <div style="font-family:'Inter',sans-serif;font-size:8.5px;color:var(--text-muted);letter-spacing:2px;margin-left:5px">Val. n°:</div>
              <input type="number" id="isak_num" min="1" max="20" style="background:var(--grey-dark);border:1px solid var(--grey-line);color:var(--white);font-family:'Bebas Neue',sans-serif;font-size:16px;width:42px;padding:2px 6px;outline:none">
            </div>
          </div>
          <div class="sec-head"><div class="sec-dot"></div><h2>Misure di Base</h2><div class="sec-line"></div></div>
          <div class="grid-4">
            <div class="m-card"><div class="mlabel">Massa Corporea</div><div class="m-row"><input type="number" id="peso" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">kg</span></div></div>
            <div class="m-card"><div class="mlabel">Statura Allungata</div><div class="m-row"><input type="number" id="statura" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">cm</span></div></div>
            <div class="m-card"><div class="mlabel">Statura Seduto</div><div class="m-row"><input type="number" id="statura_sed" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">cm</span></div></div>
            <div class="m-card"><div class="mlabel">Apertura Braccia</div><div class="m-row"><input type="number" id="apertura" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">cm</span></div></div>
          </div>
          <div class="sec-head"><div class="sec-dot"></div><h2>Pliche Cutanee</h2><div class="sec-line"></div></div>
          <div class="grid-4">
            <div class="m-card"><div class="mlabel">Triceps</div><div class="m-row"><input type="number" id="p_triceps" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">mm</span></div></div>
            <div class="m-card"><div class="mlabel">Sottoscapolare</div><div class="m-row"><input type="number" id="p_sott" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">mm</span></div></div>
            <div class="m-card"><div class="mlabel">Biceps</div><div class="m-row"><input type="number" id="p_biceps" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">mm</span></div></div>
            <div class="m-card"><div class="mlabel">Cresta Iliaca</div><div class="m-row"><input type="number" id="p_cresta" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">mm</span></div></div>
            <div class="m-card"><div class="mlabel">Sopraspinale</div><div class="m-row"><input type="number" id="p_sopra" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">mm</span></div></div>
            <div class="m-card"><div class="mlabel">Addominale</div><div class="m-row"><input type="number" id="p_add" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">mm</span></div></div>
            <div class="m-card"><div class="mlabel">Coscia</div><div class="m-row"><input type="number" id="p_coscia" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">mm</span></div></div>
            <div class="m-card"><div class="mlabel">Gamba</div><div class="m-row"><input type="number" id="p_gamba" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">mm</span></div></div>
          </div>
          <div class="sec-head"><div class="sec-dot"></div><h2>Perimetri</h2><div class="sec-line"></div></div>
          <div class="grid-4">
            <div class="m-card"><div class="mlabel">Braccio Rilassato</div><div class="m-row"><input type="number" id="c_br_ril" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">cm</span></div></div>
            <div class="m-card"><div class="mlabel">Braccio Contratto</div><div class="m-row"><input type="number" id="c_br_fl" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">cm</span></div></div>
            <div class="m-card"><div class="mlabel">Vita</div><div class="m-row"><input type="number" id="c_vita" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">cm</span></div></div>
            <div class="m-card"><div class="mlabel">Fianchi</div><div class="m-row"><input type="number" id="c_fianchi" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">cm</span></div></div>
            <div class="m-card"><div class="mlabel">Coscia Media</div><div class="m-row"><input type="number" id="c_coscia" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">cm</span></div></div>
            <div class="m-card"><div class="mlabel">Gamba</div><div class="m-row"><input type="number" id="c_gamba" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">cm</span></div></div>
          </div>
          <div class="sec-head"><div class="sec-dot"></div><h2>Diametri Ossei</h2><div class="sec-line"></div></div>
          <div class="grid-3">
            <div class="m-card"><div class="mlabel">Omero</div><div class="m-row"><input type="number" id="d_omero" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">cm</span></div></div>
            <div class="m-card"><div class="mlabel">Bistiloideo</div><div class="m-row"><input type="number" id="d_bist" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">cm</span></div></div>
            <div class="m-card"><div class="mlabel">Femore</div><div class="m-row"><input type="number" id="d_femore" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">cm</span></div></div>
          </div>
          <div class="sec-head"><div class="sec-dot"></div><h2>Composizione Corporea</h2><div class="sec-line"></div></div>
          <div class="grid-3">
            <div class="m-card"><div class="mlabel">Massa Grassa (kg)</div><div class="m-row"><input type="number" id="mg_kg" step="0.01" placeholder="0.00" oninput="computeISAK()"><span class="m-unit">kg</span></div></div>
            <div class="m-card"><div class="mlabel">Massa Magra</div><div class="computed-val" id="mpg_disp">—<span class="m-unit" style="font-size:9.5px;margin-left:3px">kg</span></div></div>
            <div class="m-card"><div class="mlabel">% Grassa</div><div class="computed-val" id="perc_mg_disp">—<span class="m-unit" style="font-size:9.5px;margin-left:3px">%</span></div></div>
            <div class="m-card"><div class="mlabel">T. Adiposo</div><div class="m-row"><input type="number" id="t_adiposo" step="0.01" placeholder="0.00" oninput="computeISAK()"><span class="m-unit">kg</span></div></div>
            <div class="m-card"><div class="mlabel">T. Muscolare</div><div class="m-row"><input type="number" id="t_musc" step="0.01" placeholder="0.00" oninput="computeISAK()"><span class="m-unit">kg</span></div></div>
            <div class="m-card"><div class="mlabel">T. Osseo</div><div class="m-row"><input type="number" id="t_osseo" step="0.01" placeholder="0.00" oninput="computeISAK()"><span class="m-unit">kg</span></div></div>
          </div>
          <div class="sec-head"><div class="sec-dot"></div><h2>Parametri Vitali</h2><div class="sec-line"></div></div>
          <div class="grid-4">
            <div class="m-card"><div class="mlabel">FC Riposo</div><div class="m-row"><input type="number" id="fc" step="1" placeholder="0" oninput="computeISAK()"><span class="m-unit">bpm</span></div></div>
            <div class="m-card"><div class="mlabel">P. Sistolica</div><div class="m-row"><input type="number" id="p_sist" step="1" placeholder="120" oninput="computeISAK()"><span class="m-unit">mmHg</span></div></div>
            <div class="m-card"><div class="mlabel">P. Diastolica</div><div class="m-row"><input type="number" id="p_diast" step="1" placeholder="80" oninput="computeISAK()"><span class="m-unit">mmHg</span></div></div>
            <div class="m-card"><div class="mlabel">% Acqua</div><div class="m-row"><input type="number" id="acqua" step="0.1" placeholder="0.0" oninput="computeISAK()"><span class="m-unit">%</span></div></div>
          </div>
          <div class="summary-strip">
            <div class="s-card"><div class="s-label">Peso</div><div class="s-val"><span id="s_peso">—</span><span class="s-unit">kg</span></div></div>
            <div class="s-card"><div class="s-label">IMC</div><div class="s-val"><span id="s_imc">—</span><span class="s-unit">kg/m²</span></div></div>
            <div class="s-card"><div class="s-label">% Grassa</div><div class="s-val"><span id="s_perc_mg">—</span><span class="s-unit">%</span></div></div>
            <div class="s-card"><div class="s-label">Σ6 Pliche</div><div class="s-val"><span id="s_sigma6">—</span><span class="s-unit">mm</span></div></div>
            <div class="s-card"><div class="s-label">Σ8 Pliche</div><div class="s-val"><span id="s_sigma8">—</span><span class="s-unit">mm</span></div></div>
          </div>
        </div>

        <!-- ALLENAMENTO -->
        <div class="detail-body hidden" id="dtab-allenamento">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
            <div><div style="font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:4px">Scheda Allenamento</div><div style="font-family:'Inter',sans-serif;font-size:8.5px;color:var(--text-muted);letter-spacing:3px;text-transform:uppercase;margin-top:2px">Giorni di allenamento distinti — seleziona il giorno</div></div>
            <div style="display:flex;gap:5px">
              <button class="btn-add-group" onclick="addWorkoutDay()">+ Giorno</button>
              <button class="btn-add-group" onclick="addGroup()" style="background:rgba(255,255,255,0.04)">+ Gruppo</button>
            </div>
          </div>
          <div class="template-bar">
            <span>Template rapidi:</span>
            <button class="tpl-btn" onclick="confirmLoadTemplate('fullbody')">Full Body 3gg</button>
            <button class="tpl-btn" onclick="confirmLoadTemplate('upperlower')">Upper/Lower 4gg</button>
            <button class="tpl-btn" onclick="confirmLoadTemplate('ppl')">PPL 6gg</button>
            <button class="tpl-btn" onclick="confirmLoadTemplate('forza')">Forza 5×5</button>
            <button class="tpl-btn" onclick="confirmLoadTemplate('ipertrofia')">Ipertrofia</button>
            <button class="tpl-btn" onclick="confirmLoadTemplate('hiit')">HIIT</button>
            <button class="tpl-btn" onclick="confirmLoadTemplate('dimagrimento')">Dimagrimento</button>
            <button class="tpl-btn" id="wk_custom_tpl_btns" style="display:none"></button>
            <button class="btn-sm btn-ghost" onclick="openTplManager('workout')" style="margin-left:auto;font-size:8px;letter-spacing:2px;padding:4px 10px;border-color:rgba(74,158,255,0.25);color:var(--blue)">Gestisci</button>
          </div>
          <!-- Selettore giorno allenamento -->
          <div class="diet-day-tabs" id="wk_day_tabs" style="margin-bottom:10px"></div>
          <div class="workout-meta">
            <div class="wm-field"><label>Nome Scheda</label><input type="text" id="wk_nome" placeholder="es. Scheda A – Forza" oninput="syncWkDayName()"></div>
            <div class="wm-field"><label>Tipo Allenamento <button onclick="openWkTypeManager()" style="background:transparent;border:1px solid rgba(74,158,255,0.3);color:var(--blue);font-family:'Inter',sans-serif;font-size:8px;letter-spacing:1.5px;padding:1px 6px;cursor:pointer;text-transform:uppercase;margin-left:6px" title="Gestisci tipi">+ Tipo</button></label>
              <select id="wk_tipo"></select>
            </div>
            <div class="wm-field"><label>Freq. settimanale</label>
              <select id="wk_freq"><option>2x/settimana</option><option>3x/settimana</option><option>4x/settimana</option><option>5x/settimana</option><option>6x/settimana</option></select>
            </div>
            <div class="wm-field"><label>Riscaldamento (min)</label><input type="number" id="wk_warm" placeholder="10" min="0"></div>
            <div class="wm-field"><label>Durata sessione (min)</label><input type="number" id="wk_dur" placeholder="60" min="0"></div>
            <div class="wm-field"><label>Recupero serie (sec)</label><input type="number" id="wk_rec" placeholder="90" min="0"></div>
            <div class="wm-field"><label>📅 Scadenza Scheda</label><input type="date" id="wk_scad" onchange="syncScadFromWorkout()"></div>
          </div>
          <div id="workout_groups"></div>
          <div style="display:flex;gap:5px;margin-top:7px">
            <button class="btn-add-ex" onclick="addGroup()" style="width:auto;padding:6px 16px">+ Nuovo Gruppo</button>
            <button class="btn-add-ex" onclick="addFreeExercise()" style="width:auto;padding:6px 16px">+ Esercizio Libero</button>
          </div>
          <div style="margin-top:12px;padding:9px 11px;background:var(--grey-dark);border:1px solid var(--grey-line)">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
              <div style="font-family:'Inter',sans-serif;font-size:7.5px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase">Biblioteca rapida</div>
              <button onclick="openExAdder()" style="background:rgba(74,158,255,0.08);border:1px solid rgba(74,158,255,0.3);color:var(--blue);font-family:'Inter',sans-serif;font-size:8.5px;letter-spacing:2px;padding:3px 9px;cursor:pointer;text-transform:uppercase;font-weight:700">+ Esercizio</button>
            </div>
            <input type="text" id="ex_library_search" placeholder="Cerca esercizio…" oninput="renderLibrary(this.value)" style="background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.09);color:var(--white);font-family:'Inter',sans-serif;font-size:11px;width:100%;outline:none;padding:3px 2px;margin-bottom:7px;transition:border-color .2s" onfocus="this.style.borderBottomColor='rgba(74,158,255,0.38)'" onblur="this.style.borderBottomColor='rgba(255,255,255,0.09)'" autocomplete="off">
            <div id="exercise_library"></div>
          </div>
          <div class="field" style="margin-top:14px"><label>Note Allenamento</label><textarea id="wk_note" class="note-area" placeholder="Progressione, indicazioni tecniche…"></textarea></div>
        </div>

        <!-- DIETA 7 GIORNI -->
        <div class="detail-body hidden" id="dtab-dieta">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
            <div><div style="font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:4px">Piano Dieta</div><div style="font-family:'Inter',sans-serif;font-size:8.5px;color:var(--text-muted);letter-spacing:3px;text-transform:uppercase;margin-top:2px">7 giorni settimanali + piano mensile</div></div>
            <div style="display:flex;gap:5px"><button class="btn-add-group" onclick="addMealToDay()">+ Pasto</button></div>
          </div>
          <div class="diet-tpl-bar">
            <span>Template:</span>
            <button class="dtpl-btn" onclick="loadDietTemplateDirect('dimagrimento')">Dimagrimento</button>
            <button class="dtpl-btn" onclick="loadDietTemplateDirect('mantenimento')">Mantenimento</button>
            <button class="dtpl-btn" onclick="loadDietTemplateDirect('massa')">Massa</button>
            <button class="dtpl-btn" onclick="loadDietTemplateDirect('proteica')">Alto Proteico</button>
            <button class="dtpl-btn" onclick="loadDietTemplateDirect('lowcarb')">Low Carb</button>
            <select id="diet_tpl_scope" style="background:var(--grey-mid);border:1px solid var(--grey-line);color:var(--text-soft);font-family:'Inter',sans-serif;font-size:9px;letter-spacing:1px;padding:3px 7px;outline:none;cursor:pointer">
              <option value="all">Tutta la settimana</option>
              <option value="current">Solo giorno selezionato</option>
              <option value="weekdays">Lun – Ven</option>
              <option value="weekend">Sab – Dom</option>
            </select>
            <button class="dtpl-btn" onclick="copyDayToAll()">Copia giorno su tutta settimana</button>
            <button class="btn-sm btn-ghost" onclick="openTplManager('diet')" style="margin-left:auto;font-size:8px;letter-spacing:2px;padding:4px 10px;border-color:rgba(46,204,113,0.25);color:var(--green)">Gestisci</button>
          </div>
          <div class="diet-meta">
            <div class="wm-field"><label>Nome Piano</label><input type="text" id="diet_nome" placeholder="Piano Dieta"></div>
            <div class="wm-field"><label>Obiettivo Kcal/die</label><input type="number" id="diet_kcal_target" placeholder="2200" oninput="computeDiet()"></div>
            <div class="wm-field"><label>Durata (settimane)</label><input type="number" id="diet_durata" placeholder="4" min="1"></div>
            <div class="wm-field"><label>📅 Scadenza Dieta</label><input type="date" id="diet_scad" onchange="syncScadFromDiet()"></div>
          </div>
          <!-- Selettore giorno -->
          <div class="diet-day-tabs" id="diet_day_tabs"></div>
          <!-- Riepilogo macros giorno corrente -->
          <div class="diet-summary" id="diet_summary">
            <div class="ds-item"><div class="ds-label">Kcal Oggi</div><div class="ds-val"><span id="ds_kcal">0</span><span class="ds-unit">kcal</span></div></div>
            <div class="ds-item"><div class="ds-label">Proteine</div><div class="ds-val"><span id="ds_prot">0</span><span class="ds-unit">g</span></div></div>
            <div class="ds-item"><div class="ds-label">Carboidrati</div><div class="ds-val"><span id="ds_carb">0</span><span class="ds-unit">g</span></div></div>
            <div class="ds-item"><div class="ds-label">Grassi</div><div class="ds-val"><span id="ds_fat">0</span><span class="ds-unit">g</span></div></div>
            <div class="ds-item"><div class="ds-label">Media Sett.</div><div class="ds-val"><span id="ds_avg">0</span><span class="ds-unit">kcal</span></div></div>
          </div>
          <div id="diet_meals" style="margin-top:10px"></div>
          <div style="margin-top:10px;padding:9px 11px;background:var(--grey-dark);border:1px solid rgba(46,204,113,0.1)">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
              <div style="font-family:'Inter',sans-serif;font-size:7.5px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase">Libreria alimenti — clicca per aggiungere al pasto attivo</div>
              <button onclick="openFoodAdder()" style="background:rgba(46,204,113,0.08);border:1px solid rgba(46,204,113,0.3);color:var(--green);font-family:'Inter',sans-serif;font-size:8.5px;letter-spacing:2px;padding:3px 9px;cursor:pointer;text-transform:uppercase;font-weight:700">+ Alimento</button>
            </div>
            <input type="text" id="food_library_search" placeholder="Cerca alimento…" oninput="renderFoodLibrary(this.value)" style="background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.09);color:var(--white);font-family:'Inter',sans-serif;font-size:11px;width:100%;outline:none;padding:3px 2px;margin-bottom:7px;transition:border-color .2s" onfocus="this.style.borderBottomColor='rgba(46,204,113,0.38)'" onblur="this.style.borderBottomColor='rgba(255,255,255,0.09)'" autocomplete="off">
            <div class="food-library-grid" id="food_library_grid"></div>
          </div>
          <div class="field" style="margin-top:12px"><label>Note Piano Dieta</label><textarea id="diet_note" class="note-area" placeholder="Indicazioni, allergie, timing pasti…"></textarea></div>
        </div>

        <!-- PAGAMENTI -->
        <div class="detail-body hidden" id="dtab-pagamenti">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
            <div><div style="font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:4px">Storico Pagamenti</div></div>
            <button class="btn-sm btn-green" onclick="showAddPayment()">+ Pagamento</button>
          </div>
          <div class="payments-grid">
            <div class="pay-card"><div class="pc-label">Totale Incassato</div><div class="pc-val" id="pay_totale">€0</div><div style="font-family:'Inter',sans-serif;font-size:9.5px;color:var(--text-muted);margin-top:3px" id="pay_totale_sub">0 pagamenti</div></div>
            <div class="pay-card" style="border-top:2px solid rgba(244,196,48,0.38)"><div class="pc-label">In Attesa / Scaduto</div><div class="pc-val" id="pay_pending" style="color:var(--yellow)">€0</div><div style="font-family:'Inter',sans-serif;font-size:9.5px;color:var(--text-muted);margin-top:3px" id="pay_pending_sub">0 in sospeso</div></div>
          </div>
          <div id="pay_list"><div class="empty-state" style="padding:28px"><div class="es-icon">💳</div><p>Nessun pagamento registrato</p></div></div>
        </div>

        <!-- FOTO PRIMA/DOPO -->
        <div class="detail-body hidden" id="dtab-foto_cl">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:14px">
            <div><div style="font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:4px">Foto Prima / Dopo</div><div style="font-family:'Inter',sans-serif;font-size:8.5px;color:var(--text-muted);letter-spacing:3px;text-transform:uppercase;margin-top:2px">Le immagini vengono ridimensionate e salvate nel browser</div></div>
            <label for="foto_upload_input" class="btn-sm btn-accent" style="cursor:pointer;display:inline-flex;align-items:center;gap:5px">Aggiungi Foto</label>
            <input type="file" id="foto_upload_input" accept="image/*" multiple style="display:none" onchange="handleFotoUpload(this)">
          </div>
          <!-- Confronto Prima / Dopo -->
          <div id="foto_comparison_area" style="display:none;margin-bottom:18px">
            <div style="font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:3px;margin-bottom:10px;color:var(--text-mid)">Confronto</div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
              <div>
                <div style="font-family:'Inter',sans-serif;font-size:8px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;margin-bottom:5px">📌 Prima <span id="foto_label_prima" style="color:var(--text-soft)"></span></div>
                <div style="position:relative">
                  <img id="foto_img_prima" src="" style="width:100%;max-height:380px;object-fit:contain;background:var(--grey-dark);border:1px solid var(--grey-line);display:block">
                  <div style="position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,0.6);padding:5px 8px;display:flex;align-items:center;justify-content:space-between">
                    <span id="foto_date_prima" style="font-family:'Inter',sans-serif;font-size:9px;color:#ccc;letter-spacing:1.5px"></span>
                    <button onclick="openFotoSelector('prima')" style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:var(--white);font-family:'Inter',sans-serif;font-size:8px;letter-spacing:2px;padding:2px 7px;cursor:pointer;text-transform:uppercase">Cambia</button>
                  </div>
                </div>
              </div>
              <div>
                <div style="font-family:'Inter',sans-serif;font-size:8px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;margin-bottom:5px">🏆 Dopo <span id="foto_label_dopo" style="color:var(--text-soft)"></span></div>
                <div style="position:relative">
                  <img id="foto_img_dopo" src="" style="width:100%;max-height:380px;object-fit:contain;background:var(--grey-dark);border:1px solid var(--grey-line);display:block">
                  <div style="position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,0.6);padding:5px 8px;display:flex;align-items:center;justify-content:space-between">
                    <span id="foto_date_dopo" style="font-family:'Inter',sans-serif;font-size:9px;color:#ccc;letter-spacing:1.5px"></span>
                    <button onclick="openFotoSelector('dopo')" style="background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:var(--white);font-family:'Inter',sans-serif;font-size:8px;letter-spacing:2px;padding:2px 7px;cursor:pointer;text-transform:uppercase">Cambia</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- Galleria -->
          <div style="font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:3px;margin-bottom:10px;color:var(--text-mid)">Galleria <span id="foto_count_badge" style="font-family:'Inter',sans-serif;font-size:10px;color:var(--text-muted);font-weight:400;letter-spacing:1px"></span></div>
          <div id="foto_gallery" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:6px">
            <div class="empty-state" style="grid-column:1/-1;padding:30px"><div class="es-icon">📷</div><p>Nessuna foto. Caricane una con il tasto ↑</p></div>
          </div>
          <!-- Modal selettore -->
          <div id="foto_selector_modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.82);z-index:500;align-items:center;justify-content:center">
            <div style="background:var(--grey-mid);border:1px solid var(--grey-line);padding:20px;max-width:700px;width:92%;max-height:80vh;overflow-y:auto">
              <div style="font-family:'Bebas Neue',sans-serif;font-size:15px;letter-spacing:3px;margin-bottom:12px" id="foto_selector_title">Scegli foto — PRIMA</div>
              <div id="foto_selector_grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:6px"></div>
              <div style="margin-top:12px;text-align:right"><button class="btn-sm btn-ghost" onclick="closeFotoSelector()">Chiudi</button></div>
            </div>
          </div>
        </div>

        <!-- NOTE -->
        <div class="detail-body hidden" id="dtab-note_cl">
          <div style="font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:4px;margin-bottom:12px">Note e Diario</div>
          <textarea class="note-area" id="cl_note_text" style="min-height:200px" placeholder="Osservazioni, progressi, annotazioni del coach…"></textarea>
        </div>

        <!-- SAVE BAR UNIFICATA -->
        <div class="save-bar">
          <div class="sb-info">Tutte le tab salvano la scheda di <span class="sb-name" id="sb_client_name">—</span></div>
          <button class="btn-sm btn-ghost" style="color:var(--accent);border-color:rgba(224,58,62,0.3)" onclick="showDeleteClientModal()">Elimina</button>
          <button class="btn-sm btn-ghost" onclick="showPage('grafici');setTimeout(buildCharts,100)">Grafici →</button>
          <button class="btn-sm btn-ghost" style="color:var(--blue);border-color:rgba(74,158,255,0.3)" onclick="printFullClient()" title="Stampa anagrafica, allenamento, dieta, misure e note">Stampa completa</button>
          <button class="btn-sm btn-accent" onclick="saveAllClientData()">Salva tutto</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- GRAFICI -->
<div class="page" id="page-grafici">
  <div class="charts-grid">
    <div class="chart-card"><div class="c-title">Pliche Cutanee</div><div class="c-sub">Profilo adiposo — mm</div><div class="chart-wrap tall"><canvas id="chartPliche"></canvas></div></div>
    <div class="chart-card"><div class="c-title">Perimetri</div><div class="c-sub">Misure in cm</div><div class="chart-wrap tall"><canvas id="chartPerimetri"></canvas></div></div>
    <div class="chart-card"><div class="c-title">Composizione Corporea</div><div class="c-sub">Frazionamento molecolare</div><div class="kpi-row"><div class="kpi-item"><div class="kv" id="kpi_mg">—</div><div class="kl">Massa Grassa kg</div></div><div class="kpi-item"><div class="kv" id="kpi_mpg">—</div><div class="kl">Massa Magra kg</div></div><div class="kpi-item"><div class="kv" id="kpi_pmg">—</div><div class="kl">% Grassa</div></div></div><div class="chart-wrap small"><canvas id="chartCompo"></canvas></div></div>
    <div class="chart-card"><div class="c-title">Frazionamento Tissutale</div><div class="c-sub">Composizione tessutale</div><div class="kpi-row"><div class="kpi-item"><div class="kv" id="kpi_tad">—</div><div class="kl">T. Adiposo kg</div></div><div class="kpi-item"><div class="kv" id="kpi_tmu">—</div><div class="kl">T. Muscolare kg</div></div><div class="kpi-item"><div class="kv" id="kpi_tos">—</div><div class="kl">T. Osseo kg</div></div></div><div class="chart-wrap small"><canvas id="chartTessuti"></canvas></div></div>
    <div class="chart-card full"><div class="c-title">Distribuzione Pliche</div><div class="c-sub">Profilo dettagliato — mm</div><div class="chart-wrap"><canvas id="chartPlicheLine"></canvas></div></div>
    <div class="chart-card"><div class="c-title">Indici di Salute</div><div class="c-sub">Valori vs intervallo</div><div class="health-row" id="healthRow" style="margin-top:9px"></div></div>
    <div class="chart-card"><div class="c-title">Somatotipo</div><div class="c-sub">Endomorfia · Mesomorfia · Ectomorfia</div><canvas id="somatoCanvas" width="290" height="250"></canvas></div>
    <div class="chart-card full"><div class="c-title">Distribuzione Adiposa</div><div class="c-sub">% per zona corporea</div><div class="chart-wrap small"><canvas id="chartAdiposa"></canvas></div></div>
  </div>
</div>

<!-- CALENDARIO -->
<div class="page" id="page-calendario">
  <div class="calendar-layout">
    <div class="calendar-main">
      <div class="cal-nav">
        <button class="cal-btn" onclick="changeMonth(-1)">‹</button>
        <div class="cal-month" id="cal_month_label"></div>
        <button class="cal-btn" onclick="changeMonth(1)">›</button>
      </div>
      <div class="cal-grid" id="cal_days">
        <div class="cal-dow">Lun</div><div class="cal-dow">Mar</div><div class="cal-dow">Mer</div>
        <div class="cal-dow">Gio</div><div class="cal-dow">Ven</div><div class="cal-dow">Sab</div><div class="cal-dow">Dom</div>
      </div>
    </div>
    <div class="cal-sidebar">
      <div class="cal-day-detail">
        <div class="cal-day-title" id="cal_selected_label">— Seleziona un giorno</div>
        <div class="cal-events-list" id="cal_events_list"></div>
      </div>
      <div class="appt-form">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:3px;margin-bottom:3px">Nuovo Appuntamento</div>
        <label>Cliente</label>
        <select id="appt_client"><option value="">— Seleziona cliente —</option></select>
        <label>Tipo sessione</label>
        <select id="appt_type">
          <option value="training">🏋️ Allenamento in palestra</option>
          <option value="studio">🏢 Studio / In presenza</option>
          <option value="teams">💼 Microsoft Teams</option>
          <option value="zoom">📹 Zoom</option>
          <option value="meet">📞 Google Meet</option>
          <option value="phone">📱 Telefonata</option>
          <option value="isak">📏 Misurazione ISAK</option>
          <option value="consult">🩺 Consulenza nutrizionale</option>
          <option value="other">📌 Altro</option>
        </select>
        <label>Link / Luogo</label>
        <input type="text" id="appt_location" placeholder="es. link Zoom, indirizzo palestra…">
        <label>Ora</label>
        <input type="time" id="appt_time" value="09:00">
        <label>Durata (min)</label>
        <input type="number" id="appt_dur" value="60" min="15" step="15">
        <label>Note</label>
        <input type="text" id="appt_note" placeholder="es. Prima valutazione">
        <button class="appt-btn" onclick="addAppointment()">+ Aggiungi</button>
      </div>
    </div>
  </div>
</div>

</main>


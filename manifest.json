let charts={};
Chart.defaults.color='#666';Chart.defaults.borderColor='rgba(255,255,255,0.04)';Chart.defaults.font.family="'Inter',sans-serif";
function buildCharts(){
  Object.values(charts).forEach(c=>{try{c.destroy()}catch(e){}});charts={};
  const W='#f0f0f2',R='#e03a3e',B='#4a9eff',G='#2ecc71',Y='#f4c430';
  document.getElementById('kpi_mg').textContent=isNaN(ivr('mg_kg'))?'—':ivr('mg_kg').toFixed(2);
  const [ps,mg]=[ivr('peso'),ivr('mg_kg')];
  document.getElementById('kpi_mpg').textContent=(!isNaN(mg)&&!isNaN(ps))?(ps-mg).toFixed(2):'—';
  document.getElementById('kpi_pmg').textContent=(!isNaN(mg)&&!isNaN(ps)&&ps>0)?((mg/ps)*100).toFixed(1)+'%':'—';
  ['tad','tmu','tos'].forEach((k,i)=>{const el=document.getElementById('kpi_'+k);if(el)el.textContent=isNaN(ivr(['t_adiposo','t_musc','t_osseo'][i]))?'—':ivr(['t_adiposo','t_musc','t_osseo'][i]).toFixed(2);});
  try{const c=document.getElementById('chartPliche').getContext('2d');charts.pliche=new Chart(c,{type:'radar',data:{labels:['Triceps','Sottoscap.','Biceps','Cresta','Soprasp.','Addome','Coscia','Gamba'],datasets:[{data:[iv('p_triceps'),iv('p_sott'),iv('p_biceps'),iv('p_cresta'),iv('p_sopra'),iv('p_add'),iv('p_coscia'),iv('p_gamba')],backgroundColor:'rgba(224,58,62,0.09)',borderColor:R,borderWidth:2,pointBackgroundColor:R,pointRadius:3}]},options:{responsive:true,maintainAspectRatio:false,scales:{r:{grid:{color:'rgba(255,255,255,0.05)'},angleLines:{color:'rgba(255,255,255,0.05)'},ticks:{color:'#555',backdropColor:'transparent',font:{size:9}},pointLabels:{color:W,font:{size:9.5}}}},plugins:{legend:{display:false}}}});}catch(e){}
  try{const c=document.getElementById('chartPerimetri').getContext('2d');const data=[iv('c_br_ril'),iv('c_br_fl'),iv('c_vita'),iv('c_fianchi'),iv('c_coscia'),iv('c_gamba')];charts.perimetri=new Chart(c,{type:'bar',data:{labels:['Br. Ril.','Br. Contr.','Vita','Fianchi','Coscia','Gamba'],datasets:[{data,backgroundColor:data.map((_,i)=>`rgba(74,158,255,${0.28+i*0.08})`),borderColor:B,borderWidth:1,borderRadius:2}]},options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{color:'rgba(255,255,255,0.03)'},ticks:{color:'#666'}},y:{grid:{display:false},ticks:{color:W}}}}});}catch(e){}
  try{const mg_v=isNaN(ivr('mg_kg'))?0:ivr('mg_kg');const mpg_v=(!isNaN(ps)&&!isNaN(ivr('mg_kg')))?Math.max(0,ps-ivr('mg_kg')):0;const c=document.getElementById('chartCompo').getContext('2d');charts.compo=new Chart(c,{type:'doughnut',data:{labels:['Massa Grassa','Massa Magra'],datasets:[{data:[mg_v,mpg_v],backgroundColor:[R,'rgba(74,158,255,0.62)'],borderColor:['#070709'],borderWidth:3}]},options:{responsive:true,maintainAspectRatio:false,cutout:'70%',plugins:{legend:{position:'bottom',labels:{color:W,font:{size:9.5},padding:11,boxWidth:8}},tooltip:{callbacks:{label:c=>` ${c.parsed.toFixed(2)} kg`}}}}});}catch(e){}
  try{const ta=isNaN(ivr('t_adiposo'))?0:ivr('t_adiposo'),tm=isNaN(ivr('t_musc'))?0:ivr('t_musc'),to=isNaN(ivr('t_osseo'))?0:ivr('t_osseo'),tot=ta+tm+to,tres=(!isNaN(ps)&&ps>tot)?ps-tot:0;const c=document.getElementById('chartTessuti').getContext('2d');charts.tessuti=new Chart(c,{type:'doughnut',data:{labels:['T. Adiposo','T. Musc.','T. Osseo','Residuo'],datasets:[{data:[ta,tm,to,tres],backgroundColor:[Y,R,'rgba(170,170,170,0.4)','rgba(70,70,70,0.4)'],borderColor:['#070709'],borderWidth:3}]},options:{responsive:true,maintainAspectRatio:false,cutout:'70%',plugins:{legend:{position:'bottom',labels:{color:W,font:{size:9.5},padding:9,boxWidth:8}},tooltip:{callbacks:{label:c=>` ${c.parsed.toFixed(2)} kg`}}}}});}catch(e){}
  try{const c=document.getElementById('chartPlicheLine').getContext('2d');const gr=c.createLinearGradient(0,0,0,210);gr.addColorStop(0,'rgba(224,58,62,0.25)');gr.addColorStop(1,'rgba(224,58,62,0)');charts.plicheLine=new Chart(c,{type:'line',data:{labels:['Triceps','Sottoscap.','Biceps','Cresta','Soprasp.','Addome','Coscia','Gamba'],datasets:[{data:[iv('p_triceps'),iv('p_sott'),iv('p_biceps'),iv('p_cresta'),iv('p_sopra'),iv('p_add'),iv('p_coscia'),iv('p_gamba')],backgroundColor:gr,borderColor:R,borderWidth:2,pointBackgroundColor:W,pointBorderColor:R,pointRadius:4,fill:true,tension:0.35}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{color:'rgba(255,255,255,0.03)'},ticks:{color:W}},y:{grid:{color:'rgba(255,255,255,0.03)'},ticks:{color:'#666'}}}}});}catch(e){}
  buildHealthRow();buildSomato();
  try{const c=document.getElementById('chartAdiposa').getContext('2d');const su=iv('p_triceps')+iv('p_biceps'),ce=iv('p_cresta')+iv('p_sopra')+iv('p_add')+iv('p_sott'),inf=iv('p_coscia')+iv('p_gamba'),t2=su+ce+inf||1;charts.adiposa=new Chart(c,{type:'bar',data:{labels:['Superiore','Centrale','Inferiore'],datasets:[{data:[(su/t2*100).toFixed(1),(ce/t2*100).toFixed(1),(inf/t2*100).toFixed(1)],backgroundColor:['rgba(224,58,62,0.52)','rgba(244,196,48,0.52)','rgba(74,158,255,0.52)'],borderColor:[R,Y,B],borderWidth:1,borderRadius:3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{display:false},ticks:{color:W}},y:{grid:{color:'rgba(255,255,255,0.03)'},ticks:{color:'#666',callback:v=>v+'%'}}}}});}catch(e){}
}
function buildHealthRow(){
  const vita=iv('c_vita'),fianchi=iv('c_fianchi'),peso=ivr('peso'),statura=ivr('statura'),h=statura/100;
  const imc=(statura>0&&peso>0)?peso/(h*h):null;const ivf=(fianchi>0)?vita/fianchi:null;const rvs=(statura>0)?vita/statura:null;
  const sesso=currentClientIdx!==null?(DB.clients[currentClientIdx].sesso||'F'):'F';
  const items=[{name:'IMC',val:imc?imc.toFixed(1):'—',range:'18.5–24.9',ok:imc&&imc>=18.5&&imc<=24.9?'green':imc&&imc<18.5?'yellow':'red',unit:'kg/m²'},{name:'Vita/Fianchi',val:ivf?ivf.toFixed(2):'—',range:sesso==='M'?'<0.90':'<0.85',ok:ivf&&ivf<(sesso==='M'?0.9:0.85)?'green':ivf&&ivf<0.95?'yellow':'red',unit:''},{name:'Vita/Statura',val:rvs?rvs.toFixed(2):'—',range:'<0.50',ok:rvs&&rvs<0.50?'green':rvs&&rvs<0.60?'yellow':'red',unit:''},{name:'Conicità',val:(statura>0&&peso>0&&vita>0)?((vita/100)/(0.109*Math.sqrt(peso/statura*100))).toFixed(2):'—',range:'<1.40',ok:null,unit:''}];
  document.getElementById('healthRow').innerHTML=items.map(it=>`<div class="h-item">${it.ok?`<div class="h-dot ${it.ok}"></div>`:'<div style="width:7px;height:7px;flex-shrink:0"></div>'}<div class="h-name">${it.name}</div><div class="h-val">${it.val}<span style="font-family:'Inter';font-size:9px;color:#555;margin-left:2px">${it.unit}</span></div><div class="h-range">${it.range}</div></div>`).join('');
}
function buildSomato(){
  const canvas=document.getElementById('somatoCanvas');const ctx=canvas.getContext('2d');const CW=canvas.width,H=canvas.height;ctx.clearRect(0,0,CW,H);
  const top={x:CW/2,y:20},left={x:20,y:H-20},right={x:CW-20,y:H-20};
  ctx.beginPath();ctx.moveTo(top.x,top.y);ctx.lineTo(left.x,left.y);ctx.lineTo(right.x,right.y);ctx.closePath();ctx.strokeStyle='rgba(255,255,255,0.1)';ctx.lineWidth=1.5;ctx.stroke();
  ctx.setLineDash([3,5]);ctx.strokeStyle='rgba(255,255,255,0.05)';
  for(let t=0.25;t<1;t+=0.25){ctx.beginPath();ctx.moveTo(top.x+(left.x-top.x)*t,top.y+(left.y-top.y)*t);ctx.lineTo(left.x+(right.x-left.x)*(1-t),left.y);ctx.stroke();ctx.beginPath();ctx.moveTo(top.x+(right.x-top.x)*t,top.y+(right.y-top.y)*t);ctx.lineTo(left.x+(right.x-left.x)*t,left.y);ctx.stroke();ctx.beginPath();ctx.moveTo(left.x+(right.x-left.x)*t,left.y);ctx.lineTo(top.x+(right.x-top.x)*(1-t),top.y+(right.y-top.y)*(1-t));ctx.stroke();}
  ctx.setLineDash([]);ctx.fillStyle='#777';ctx.font="bold 9.5px 'Inter'";ctx.textAlign='center';ctx.fillText('MESOMORFIA',top.x,top.y-7);ctx.textAlign='left';ctx.fillText('ENDOMORFIA',2,H-4);ctx.textAlign='right';ctx.fillText('ECTOMORFIA',CW-2,H-4);
  const endo=iv('p_triceps')>0?computeEndo():null,meso=iv('d_omero')>0?computeMeso():null,ecto=ivr('peso')>0&&ivr('statura')>0?computeEcto():null;
  if(endo!==null&&meso!==null&&ecto!==null){const X=ecto-endo,Y2=2*meso-(endo+ecto),scale=(CW-40)/16,cx=CW/2+X*scale,cy=H/2-Y2*scale*0.7+20;ctx.beginPath();ctx.arc(cx,cy,5.5,0,Math.PI*2);ctx.fillStyle='#e03a3e';ctx.fill();ctx.strokeStyle='#fff';ctx.lineWidth=1.5;ctx.stroke();ctx.fillStyle='#fff';ctx.font="9.5px 'Inter'";ctx.textAlign='center';ctx.fillText(`${endo.toFixed(1)}–${meso.toFixed(1)}–${ecto.toFixed(1)}`,cx,cy-11);}
}
function computeEndo(){const s=iv('p_triceps')+iv('p_sott')+iv('p_sopra'),h=iv('statura'),sc=(h>0)?s*(170.18/h):s;return -0.7182+0.1451*sc-0.00068*sc*sc+0.0000014*sc*sc*sc;}
function computeMeso(){const H=iv('statura'),om=iv('d_omero'),fe=iv('d_femore'),brC=iv('c_br_ril')-iv('p_triceps')/10,gaC=iv('c_gamba')-iv('p_gamba')/10;if(H<=0)return 2;return 0.858*om+0.601*fe+0.188*brC+0.161*gaC-0.131*H+4.5;}
function computeEcto(){const H=iv('statura'),W2=iv('peso');if(H<=0||W2<=0)return 3;const HWR=H/Math.cbrt(W2);if(HWR>40.75)return 0.732*HWR-28.58;if(HWR>=38.25)return 0.463*HWR-17.63;return 0.1;}

// ═══════════════════════════ PRINT ═══════════════════════════
let printMode=null;
function showPrintModal(){
  if(currentClientIdx===null){flashSave('Seleziona prima un cliente',true);return;}
  const c=DB.clients[currentClientIdx];
  document.getElementById('print_modal_client_name').textContent=`${c.nome||''} ${c.cognome||''}`.trim()||'Cliente';
  printMode=null;
  document.getElementById('print_opt_diet').style.borderColor='var(--grey-line)';
  document.getElementById('print_opt_workout').style.borderColor='var(--grey-line)';
  document.getElementById('print_opt_both').style.borderColor='var(--grey-line)';
  document.getElementById('print_confirm_btn').disabled=true;
  document.getElementById('modal_print').style.display='flex';
}
function closePrintModal(){document.getElementById('modal_print').style.display='none';printMode=null;}
function selectPrintOpt(mode){
  printMode=mode;
  document.getElementById('print_opt_diet').style.borderColor=mode==='diet'?'var(--accent)':'var(--grey-line)';
  document.getElementById('print_opt_workout').style.borderColor=mode==='workout'?'var(--accent)':'var(--grey-line)';
  document.getElementById('print_opt_both').style.borderColor=mode==='both'?'var(--accent)':'var(--grey-line)';
  document.getElementById('print_confirm_btn').disabled=false;
}
function executePrint(){
  if(!printMode||currentClientIdx===null)return;
  closePrintModal();
  const c=DB.clients[currentClientIdx];
  const pa=document.getElementById('print-area');
  pa.innerHTML='';
  // Header comune
  const today=new Date();
  const dateStr=`${String(today.getDate()).padStart(2,'0')}/${String(today.getMonth()+1).padStart(2,'0')}/${today.getFullYear()}`;
  let modeLabel='Piano Dieta Settimanale';
  if(printMode==='workout')modeLabel='Scheda Allenamento';
  else if(printMode==='both')modeLabel='Dieta + Scheda Allenamento';
  const header=`
    <div class="pr-header">
      <div><div class="pr-logo-txt">NM Coaching Pro</div><div class="pr-sub">${modeLabel}</div></div>
      <div style="text-align:right;font-family:'Inter',sans-serif;font-size:10px;color:#999"><div>${dateStr}</div></div>
    </div>
    <div class="pr-client-box">
      <div class="pr-field"><div class="pf-label">Cliente</div><div class="pf-val">${(c.nome||'')+' '+(c.cognome||'')}</div></div>
      <div class="pr-field"><div class="pf-label">Data Nascita</div><div class="pf-val">${c.dob?c.dob.split('-').reverse().join('/'):'—'}</div></div>
      <div class="pr-field"><div class="pf-label">Sesso</div><div class="pf-val">${c.sesso||'—'}</div></div>
      <div class="pr-field"><div class="pf-label">Sport / Attività</div><div class="pf-val">${c.sport||'—'}</div></div>
      <div class="pr-field"><div class="pf-label">Obiettivo</div><div class="pf-val">${c.obiettivo||'—'}</div></div>
      <div class="pr-field"><div class="pf-label">Email / Tel</div><div class="pf-val">${c.email||c.tel||'—'}</div></div>
      ${c.isak&&c.isak.peso?`<div class="pr-field"><div class="pf-label">Peso</div><div class="pf-val">${c.isak.peso} kg</div></div>`:''}
      ${c.isak&&c.isak.statura?`<div class="pr-field"><div class="pf-label">Statura</div><div class="pf-val">${c.isak.statura} cm</div></div>`:''}
      ${c.isak&&c.isak.mg_kg?`<div class="pr-field"><div class="pf-label">Massa Grassa</div><div class="pf-val">${c.isak.mg_kg} kg</div></div>`:''}
    </div>`;
  if(printMode==='diet'){pa.innerHTML=header+buildPrintDiet(c);}
  else if(printMode==='workout'){pa.innerHTML=header+buildPrintWorkout(c);}
  else if(printMode==='both'){
    // Stampa dieta + salto pagina + allenamento
    const dietHtml=buildPrintDiet(c);
    const workoutHtml=buildPrintWorkout(c);
    pa.innerHTML=header+dietHtml+`<div style="page-break-before:always"></div>`+workoutHtml;
  }
  setTimeout(()=>{window.print();},120);
}

function buildPrintDiet(c){
  const diet=c.diet;
  if(!diet||!diet.week||!diet.week.length)return'<p style="font-family:\'Inter\',sans-serif;color:#999">Nessun piano dieta configurato.</p>';
  let html=`<div class="pr-sec">Piano Dieta — ${diet.nome||'Settimanale'}</div>`;
  if(diet.kcal_target)html+=`<div style="font-family:'Inter',sans-serif;font-size:10.5px;color:#555;margin-bottom:8px">Obiettivo: <strong>${diet.kcal_target} kcal/die</strong> · Durata: ${diet.durata||4} settimane</div>`;
  DAYS_IT.forEach((day,di)=>{
    const meals=diet.week[di]||[];
    const dayKcal=meals.reduce((a,m)=>a+m.foods.reduce((b,f)=>b+(parseFloat(f.kcal)||0)*((parseFloat(f.qta)||100)/100),0),0);
    html+=`<div class="pr-day-head">${day} — ${dayKcal.toFixed(0)} kcal</div>`;
    meals.forEach(meal=>{
      if(!meal.foods.length)return;
      const mKcal=meal.foods.reduce((a,f)=>a+(parseFloat(f.kcal)||0)*((parseFloat(f.qta)||100)/100),0);
      html+=`<div class="pr-meal"><div class="pr-meal-name">${meal.name} <span style="color:#e03a3e">${mKcal.toFixed(0)} kcal</span></div>
      <table class="pr-food-table"><thead><tr><th>Alimento</th><th>g</th><th>Kcal</th><th>Prot</th><th>Carb</th><th>Grassi</th></tr></thead><tbody>
      ${meal.foods.map(f=>{const r=(parseFloat(f.qta)||100)/100;return`<tr><td>${f.name}</td><td>${f.qta}</td><td>${((f.kcal||0)*r).toFixed(0)}</td><td>${((f.prot||0)*r).toFixed(1)}g</td><td>${((f.carb||0)*r).toFixed(1)}g</td><td>${((f.fat||0)*r).toFixed(1)}g</td></tr>`;}).join('')}
      </tbody></table></div>`;
    });
  });
  if(diet.note)html+=`<div class="pr-note">${diet.note}</div>`;
  html+=`<div class="pr-footer">NM Coaching Pro · Stampato il ${new Date().toLocaleDateString('it-IT')}</div>`;
  return html;
}

function buildPrintWorkout(c){
  const wk=c.workout;
  const days=wk?.days||[];
  if(!days.length)return'<p style="font-family:\'Inter\',sans-serif;color:#999">Nessuna scheda allenamento configurata.</p>';
  const freq=wk.freq||'—';
  let html=`<div class="pr-sec">Scheda Allenamento</div>`;
  html+=`<div class="pr-meta-grid">
    <div class="pr-meta-item"><div class="pm-k">Frequenza</div><div class="pm-v">${freq}</div></div>
    <div class="pr-meta-item"><div class="pm-k">Giorni</div><div class="pm-v">${days.length} sessioni</div></div>
  </div>`;
  days.forEach((day,di)=>{
    const groups=day.groups||[];
    html+=`<div style="page-break-inside:avoid;margin-bottom:16px">`;
    html+=`<div style="font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:3px;background:#e03a3e;color:#fff;padding:5px 10px;margin-bottom:5px">
      Giorno ${day.label||String.fromCharCode(65+di)} — ${day.nome||''}
      <span style="font-size:10px;letter-spacing:1px;opacity:0.8;margin-left:10px">${day.tipo||''} · ${day.dur||'—'} min · Rec. ${day.rec||'90'}s</span>
    </div>`;
    groups.forEach(g=>{
      if(!g.exercises.length)return;
      html+=`<span class="pr-group-head">${g.name}</span>
      <table class="pr-ex-table"><thead><tr><th>Esercizio</th><th>Serie×Reps</th><th>Kg</th><th>Recupero</th><th>RPE</th><th>Note</th></tr></thead><tbody>
      ${g.exercises.map(ex=>`<tr><td><strong>${ex.name}</strong></td><td>${ex.reps}</td><td>${ex.kg}</td><td>${ex.rest||'90s'}</td><td>${ex.rpe||'7'}</td><td>${ex.note||''}</td></tr>`).join('')}
      </tbody></table>`;
    });
    if(day.note)html+=`<div class="pr-note">${day.note}</div>`;
    html+=`</div>`;
  });
  html+=`<div style="margin-top:18px;font-family:'Inter',sans-serif;font-size:9px;color:#bbb;border-top:1px solid #eee;padding-top:7px">
    <div style="display:flex;gap:30px">
      <div>Coach: ___________________________</div>
      <div>Firma: ___________________________</div>
      <div>Data: ___________________________</div>
    </div>
  </div>`;
  html+=`<div class="pr-footer">NM Coaching Pro · Stampato il ${new Date().toLocaleDateString('it-IT')}</div>`;
  return html;
}


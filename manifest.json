const APPT_TYPE_LABELS={training:'🏋️ Allenamento',studio:'🏢 Studio',teams:'💼 Teams',zoom:'📹 Zoom',meet:'📞 Google Meet',phone:'📱 Telefonata',isak:'📏 ISAK',consult:'🩺 Consulenza',other:'📌 Appuntamento'};

function addAppointment(){
  if(!calSelectedDate){alert('Seleziona prima un giorno');return;}
  const clientSel=document.getElementById('appt_client');
  const ev={
    clientName:clientSel.value?(clientSel.options[clientSel.selectedIndex]?.text||''):'',
    clientId:clientSel.value,
    type:document.getElementById('appt_type').value,
    location:document.getElementById('appt_location').value,
    time:document.getElementById('appt_time').value,
    dur:document.getElementById('appt_dur').value,
    note:document.getElementById('appt_note').value
  };
  if(!DB.appointments[calSelectedDate])DB.appointments[calSelectedDate]=[];
  DB.appointments[calSelectedDate].push(ev);
  DB.appointments[calSelectedDate].sort((a,b)=>a.time.localeCompare(b.time));
  saveStore(DB);renderCalendar();flashSave('Appuntamento aggiunto!');
}

function deleteAppt(dateStr,idx){DB.appointments[dateStr].splice(idx,1);if(!DB.appointments[dateStr].length)delete DB.appointments[dateStr];saveStore(DB);renderCalendar();}


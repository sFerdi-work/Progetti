      <div class="pr-field"><div class="pf-label">Cliente</div><div class="pf-val">${nome}</div></div>
      <div class="pr-field"><div class="pf-label">Data Nascita</div><div class="pf-val">${c.dob?c.dob.split('-').reverse().join('/'):'—'}</div></div>
      <div class="pr-field"><div class="pf-label">Sesso</div><div class="pf-val">${c.sesso||'—'}</div></div>
      <div class="pr-field"><div class="pf-label">Sport / Attività</div><div class="pf-val">${c.sport||'—'}</div></div>
      <div class="pr-field"><div class="pf-label">Livello Attività</div><div class="pf-val">${c.attivita||'—'}</div></div>
      <div class="pr-field"><div class="pf-label">Obiettivo</div><div class="pf-val">${c.obiettivo||'—'}</div></div>
      <div class="pr-field"><div class="pf-label">Email</div><div class="pf-val">${c.email||'—'}</div></div>
      <div class="pr-field"><div class="pf-label">Telefono</div><div class="pf-val">${c.tel||'—'}</div></div>
      <div class="pr-field"><div class="pf-label">Città</div><div class="pf-val">${c.citta||'—'}${c.provincia?' ('+c.provincia.toUpperCase()+')':''}</div></div>
    </div>`;
  // Patologie / Integratori
  if(c.patologie||c.integratori){
    html+=`<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px;font-family:'Inter',sans-serif;font-size:9.5px">`;
    if(c.patologie)html+=`<div style="border-left:2px solid #e03a3e;padding:5px 10px;background:#fff9f9"><div style="font-size:7.5px;letter-spacing:2px;color:#999;text-transform:uppercase;margin-bottom:3px">Patologie / Controindicazioni</div><div style="color:#333">${c.patologie}</div></div>`;
    if(c.integratori)html+=`<div style="border-left:2px solid #4a9eff;padding:5px 10px;background:#f5f9ff"><div style="font-size:7.5px;letter-spacing:2px;color:#999;text-transform:uppercase;margin-bottom:3px">Integratori / Note Alimentari</div><div style="color:#333">${c.integratori}</div></div>`;
    html+=`</div>`;
  }
  // ── Misure ISAK & Grafici ──
  const isakSection=buildPrintISAK(c);
  if(isakSection)html+=isakSection;
  // ── Allenamento ──
  const wkSection=buildPrintWorkout(c);
  html+=`<div style="page-break-before:always"></div>`+wkSection;
  // ── Dieta ──
  const dietSection=buildPrintDiet(c);
  html+=`<div style="page-break-before:always"></div>`+dietSection;
  // ── Note ──
  if(c.notes&&c.notes.trim()){
    html+=`<div style="page-break-before:always"></div>`;
    html+=`<div class="pr-sec">Note & Diario Coach</div>`;
    html+=`<div style="font-family:'Barlow',sans-serif;font-size:10.5px;color:#333;line-height:1.65;white-space:pre-wrap;border-left:2px solid #e03a3e;padding:8px 14px;background:#fff9f9">${escapeHtml(c.notes)}</div>`;
    html+=`<div class="pr-footer">NM Coaching Pro · Stampato il ${new Date().toLocaleDateString('it-IT')}</div>`;
  }
  pa.innerHTML=html;
  setTimeout(()=>window.print(),150);
}

function buildPrintISAK(c){
  const isak=c.isak;
  if(!isak)return'';
  const v=k=>isak[k]!=null&&isak[k]!==''?parseFloat(isak[k]):null;
  const fmt=k=>{const x=v(k);return x!=null?x.toFixed(1):'—';};
  const fmtI=k=>{const x=v(k);return x!=null?x.toFixed(0):'—';};
  // Calcola indici
  const peso=v('peso'),statura=v('statura'),vita=v('c_vita'),fianchi=v('c_fianchi');
  const imc=(peso&&statura)?peso/((statura/100)**2):null;
  const ivf=(vita&&fianchi)?vita/fianchi:null;
  const rvs=(vita&&statura)?vita/statura:null;
  const sesso=c.sesso||'F';
  function semaforo(val,ok,warn){
    if(val==null)return'';
    if(ok(val))return'color:#27ae60;font-weight:700';
    if(warn(val))return'color:#f39c12;font-weight:700';
    return'color:#e03a3e;font-weight:700';
  }
  const imcStyle=semaforo(imc,x=>x>=18.5&&x<=24.9,x=>x>=17&&x<18.5||x>24.9&&x<=29.9);
  const ivfStyle=semaforo(ivf,x=>x<(sesso==='M'?0.90:0.85),x=>x<0.95);
  const rvsStyle=semaforo(rvs,x=>x<0.50,x=>x<0.60);
  // Somatotipo
  function computeEndoFull(){
    const pt=v('p_triceps'),ps=v('p_sott'),pp=v('p_sopra'),h=v('statura');
    if(pt==null||ps==null||pp==null)return null;
    const s=pt+ps+pp,sc=(h>0)?s*(170.18/h):s;
    return -0.7182+0.1451*sc-0.00068*sc*sc+0.0000014*sc*sc*sc;
  }
  function computeMesoFull(){
    const H=v('statura'),om=v('d_omero'),fe=v('d_femore'),ptric=v('p_triceps'),pbr=v('c_br_ril'),pga=v('c_gamba'),pgam=v('p_gamba');
    if(!H||!om||!fe)return null;
    const brC=(pbr||0)-(ptric||0)/10,gaC=(pga||0)-(pgam||0)/10;
    return 0.858*om+0.601*fe+0.188*brC+0.161*gaC-0.131*H+4.5;
  }
  function computeEctoFull(){
    const H=v('statura'),W=v('peso');
    if(!H||!W)return null;
    const HWR=H/Math.cbrt(W);
    if(HWR>40.75)return 0.732*HWR-28.58;
    if(HWR>=38.25)return 0.463*HWR-17.63;
    return 0.1;
  }
  const endo=computeEndoFull(),meso=computeMesoFull(),ecto=computeEctoFull();
  const mg=v('mg_kg'),mpg=(peso&&mg)?peso-mg:null,pmg=(peso&&mg&&peso>0)?mg/peso*100:null;
  let html=`<div class="pr-sec">Misure ISAK & Composizione Corporea</div>`;
  if(isak.data)html+=`<div style="font-family:'Inter',sans-serif;font-size:9px;color:#999;letter-spacing:2px;margin-bottom:9px;text-transform:uppercase">Data rilevazione: ${isak.data.split('-').reverse().join('/')} · Rilevazione n° ${isak.num||1}</div>`;
  // ── Misure di base ──
  html+=`<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:5px;margin-bottom:10px;font-family:'Inter',sans-serif">
    ${[['Massa Corporea','peso','kg'],['Statura','statura','cm'],['Statura Seduto','statura_sed','cm'],['Apertura Braccia','apertura','cm']].map(([lbl,k,u])=>`
      <div style="background:#f5f5f5;padding:7px 9px;border-top:2px solid #e03a3e">
        <div style="font-size:7px;letter-spacing:2px;color:#999;text-transform:uppercase;margin-bottom:2px">${lbl}</div>
        <div style="font-size:18px;font-family:'Bebas Neue',sans-serif;color:#111">${fmt(k)} <span style="font-size:9px;color:#999">${u}</span></div>
      </div>`).join('')}
  </div>`;
  // ── Pliche ──
  html+=`<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px">
    <div>
      <div class="pr-sec" style="font-size:10px">Pliche Cutanee (mm)</div>
      <table class="pr-food-table"><thead><tr><th>Plica</th><th style="text-align:right">mm</th></tr></thead><tbody>
      ${[['Triceps','p_triceps'],['Sottoscapolare','p_sott'],['Biceps','p_biceps'],['Cresta iliaca','p_cresta'],['Sopraspinale','p_sopra'],['Addome','p_add'],['Coscia (ant.)','p_coscia'],['Gamba (med.)','p_gamba']].map(([l,k],i)=>`<tr style="${i%2===1?'background:#fafafa':''}"><td>${l}</td><td style="text-align:right;font-weight:700">${fmt(k)}</td></tr>`).join('')}
      </tbody></table>
    </div>
    <div>
      <div class="pr-sec" style="font-size:10px">Perimetri (cm)</div>
      <table class="pr-food-table"><thead><tr><th>Perimetro</th><th style="text-align:right">cm</th></tr></thead><tbody>
      ${[['Braccio rilassato','c_br_ril'],['Braccio contratto','c_br_fl'],['Vita (minimo)','c_vita'],['Fianchi (massimo)','c_fianchi'],['Coscia prossimale','c_coscia'],['Gamba (massimo)','c_gamba']].map(([l,k],i)=>`<tr style="${i%2===1?'background:#fafafa':''}"><td>${l}</td><td style="text-align:right;font-weight:700">${fmt(k)}</td></tr>`).join('')}
      </tbody></table>
      <div class="pr-sec" style="font-size:10px;margin-top:8px">Diametri ossei (cm)</div>
      <table class="pr-food-table"><thead><tr><th>Diametro</th><th style="text-align:right">cm</th></tr></thead><tbody>
      ${[['Omero (bicondilare)','d_omero'],['Biestiloideo polso','d_bist'],['Femore (bicondilare)','d_femore']].map(([l,k],i)=>`<tr style="${i%2===1?'background:#fafafa':''}"><td>${l}</td><td style="text-align:right;font-weight:700">${fmt(k)}</td></tr>`).join('')}
      </tbody></table>
    </div>
  </div>`;
  // ── Composizione corporea & Indici ──
  html+=`<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px">
    <div>
      <div class="pr-sec" style="font-size:10px">Composizione Corporea</div>
      <table class="pr-food-table"><thead><tr><th>Componente</th><th style="text-align:right">Valore</th></tr></thead><tbody>
        <tr><td>Massa Grassa</td><td style="text-align:right;font-weight:700">${mg!=null?mg.toFixed(2)+' kg':'—'}</td></tr>
        <tr style="background:#fafafa"><td>Massa Magra</td><td style="text-align:right;font-weight:700">${mpg!=null?mpg.toFixed(2)+' kg':'—'}</td></tr>
        <tr><td>% Massa Grassa</td><td style="text-align:right;font-weight:700">${pmg!=null?pmg.toFixed(1)+'%':'—'}</td></tr>
        <tr style="background:#fafafa"><td>T. Adiposo</td><td style="text-align:right;font-weight:700">${fmt('t_adiposo')} kg</td></tr>
        <tr><td>T. Muscolare</td><td style="text-align:right;font-weight:700">${fmt('t_musc')} kg</td></tr>
        <tr style="background:#fafafa"><td>T. Osseo</td><td style="text-align:right;font-weight:700">${fmt('t_osseo')} kg</td></tr>
        ${v('fc')!=null?`<tr><td>Freq. Cardiaca a riposo</td><td style="text-align:right;font-weight:700">${fmtI('fc')} bpm</td></tr>`:''}
        ${v('acqua')!=null?`<tr style="background:#fafafa"><td>Acqua corporea</td><td style="text-align:right;font-weight:700">${fmt('acqua')} L</td></tr>`:''}
      </tbody></table>
    </div>
    <div>
      <div class="pr-sec" style="font-size:10px">Indici di Salute</div>
      <table class="pr-food-table"><thead><tr><th>Indice</th><th style="text-align:right">Valore</th><th style="text-align:right">Range</th></tr></thead><tbody>
        <tr><td>IMC (kg/m²)</td><td style="text-align:right;${imcStyle}">${imc!=null?imc.toFixed(1):'—'}</td><td style="text-align:right;color:#999;font-size:8px">18.5 – 24.9</td></tr>
        <tr style="background:#fafafa"><td>Vita / Fianchi</td><td style="text-align:right;${ivfStyle}">${ivf!=null?ivf.toFixed(2):'—'}</td><td style="text-align:right;color:#999;font-size:8px">${sesso==='M'?'< 0.90':'< 0.85'}</td></tr>
        <tr><td>Vita / Statura</td><td style="text-align:right;${rvsStyle}">${rvs!=null?rvs.toFixed(2):'—'}</td><td style="text-align:right;color:#999;font-size:8px">< 0.50</td></tr>
        ${(v('p_sist')!=null||v('p_diast')!=null)?`<tr style="background:#fafafa"><td>Pressione Arteriosa</td><td style="text-align:right;font-weight:700">${fmtI('p_sist')}/${fmtI('p_diast')}<span style="font-size:8px;color:#999"> mmHg</span></td><td style="text-align:right;color:#999;font-size:8px">< 120/80</td></tr>`:''}
      </tbody></table>
      ${(endo!=null&&meso!=null&&ecto!=null)?`
      <div class="pr-sec" style="font-size:10px;margin-top:8px">Somatotipo</div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:5px;font-family:'Bebas Neue',sans-serif;text-align:center">
        <div style="background:#f5f5f5;padding:8px 5px;border-top:2px solid #e03a3e">
          <div style="font-size:8px;font-family:'Inter',sans-serif;letter-spacing:2px;color:#999;text-transform:uppercase">Endo</div>
          <div style="font-size:22px;color:#e03a3e">${endo.toFixed(1)}</div>
        </div>
        <div style="background:#f5f5f5;padding:8px 5px;border-top:2px solid #27ae60">
          <div style="font-size:8px;font-family:'Inter',sans-serif;letter-spacing:2px;color:#999;text-transform:uppercase">Meso</div>
          <div style="font-size:22px;color:#27ae60">${meso.toFixed(1)}</div>
        </div>
        <div style="background:#f5f5f5;padding:8px 5px;border-top:2px solid #4a9eff">
          <div style="font-size:8px;font-family:'Inter',sans-serif;letter-spacing:2px;color:#999;text-transform:uppercase">Ecto</div>
          <div style="font-size:22px;color:#4a9eff">${ecto.toFixed(1)}</div>
        </div>
      </div>`:''}
    </div>
  </div>`;
  return html;
}


// Quando si applica un template a tutta la settimana, ogni giorno riceve varianti diverse
function applyDietTemplateToWeek(tpl,mode){
  const days=mode==='all'?[0,1,2,3,4,5,6]:mode==='weekdays'?[0,1,2,3,4]:mode==='weekend'?[5,6]:[activeDietDay];
  const PROT_VAR=['Petto di Pollo','Manzo magro (scamone)','Salmone fresco','Merluzzo','Tonno al naturale'];
  const CARB_VAR=['Riso bianco cotto','Pasta grano duro cruda','Pane integrale','Avena fiocchi','Patate dolci'];
  const VEG_VAR=['Spinaci freschi','Broccoli','Zucchine','Cavolfiore','Fagiolini'];
  const protSrcNames=['Petto di Pollo','Coscia Pollo s/pelle','Tacchino petto','Manzo magro (scamone)','Manzo macinato 5%','Bistecca di vitello','Maiale lonza','Salmone fresco','Tonno al naturale','Merluzzo','Orata','Branzino','Sgombro','Gamberi'];
  const carbSrcNames=['Riso bianco cotto','Riso integrale cotto','Pasta grano duro cruda','Pasta integrale cruda','Avena fiocchi','Pane integrale','Patate','Patate dolci','Quinoa cotta','Farro cotto'];
  const vegSrcNames=['Spinaci freschi','Broccoli','Zucchine','Insalata mista','Peperoni rossi','Cavolfiore','Asparagi','Fagiolini','Melanzane'];
  days.forEach((di,idx)=>{
    const varSeed=idx%5;
    const meals=tpl.meals.map(m=>({
      name:m.name,
      foods:m.foods.map(f=>{
        if(protSrcNames.includes(f.name)){const nf=fd(PROT_VAR[varSeed]);return{...nf,qta:f.qta};}
        if(carbSrcNames.includes(f.name)){const nf=fd(CARB_VAR[varSeed]);return{...nf,qta:f.qta};}
        if(vegSrcNames.includes(f.name)){const nf=fd(VEG_VAR[varSeed%VEG_VAR.length]);return{...nf,qta:f.qta};}
        return f;
      })
    }));
    dietWeek[di]=meals;
  });
  document.getElementById('diet_nome').value=tpl.nome;
  document.getElementById('diet_kcal_target').value=tpl.kcal_target;
  document.getElementById('diet_durata').value=tpl.durata;
  initDietDayTabs();renderDiet();computeDiet();
}


// ═══════════════════════════ TEMPLATE MANAGER ═══════════════════════════
// Storage keys: nm_pro3_wk_tpl (workout custom), nm_pro3_diet_tpl (diet custom)
function loadCustomWkTemplates(){try{return JSON.parse(localStorage.getItem('nm_pro3_wk_tpl')||'[]')}catch(e){return[]}}
function saveCustomWkTemplates(arr){try{localStorage.setItem('nm_pro3_wk_tpl',JSON.stringify(arr))}catch(e){}}
function loadCustomDietTemplates(){try{return JSON.parse(localStorage.getItem('nm_pro3_diet_tpl')||'[]')}catch(e){return[]}}
function saveCustomDietTemplates(arr){try{localStorage.setItem('nm_pro3_diet_tpl',JSON.stringify(arr))}catch(e){}}

let tplManagerMode='workout'; // 'workout' | 'diet'
let tplManagerTab='list';     // 'list' | 'edit'
let tplEditObj=null;          // oggetto in editing

function openTplManager(mode){
  tplManagerMode=mode;
  tplManagerTab='list';
  tplEditObj=null;
  document.getElementById('tpl_manager_title').textContent=mode==='workout'?'Template Allenamento':'Template Dieta';
  document.getElementById('modal_tpl_manager').style.display='flex';
  renderTplManagerList();
  switchTplManagerTab('list');
}
function closeTplManager(){
  document.getElementById('modal_tpl_manager').style.display='none';
  tplEditObj=null;
  // Aggiorna pulsanti dinamici nella barra template
  refreshCustomTplButtons();
}
function switchTplManagerTab(tab){
  tplManagerTab=tab;
  document.querySelectorAll('.tpl-mtab').forEach(t=>t.classList.remove('active'));
  document.getElementById('tpl_mtab_'+tab).classList.add('active');
  if(tab==='list') renderTplManagerList();
  else renderTplManagerEdit();
}

// ── LISTA ──
function renderTplManagerList(){
  const body=document.getElementById('tpl_manager_body');
  const builtIn=tplManagerMode==='workout'
    ?Object.entries(WORKOUT_TEMPLATES).map(([k,t])=>({key:k,nome:t.nome,tipo:t.tipo,built:true,giorni:t.groups.length+' gruppi'}))
    :Object.entries(DIET_TEMPLATES).map(([k,t])=>({key:k,nome:t.nome,kcal:t.kcal_target,built:true,pasti:t.meals.length+' pasti'}));
  const custom=tplManagerMode==='workout'?loadCustomWkTemplates():loadCustomDietTemplates();

  let html=`<div style="font-family:'Inter',sans-serif;font-size:8px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;margin-bottom:7px">Predefiniti (${builtIn.length})</div>`;
  html+=builtIn.map(t=>`
    <div class="tpl-list-row">
      <div class="tl-badge">${tplManagerMode==='workout'?t.tipo:t.kcal+' kcal'}</div>
      <div class="tl-name">${t.nome}</div>
      <div class="tl-meta">${tplManagerMode==='workout'?t.giorni:t.pasti}</div>
      <button class="btn-sm btn-ghost" style="font-size:8px;padding:3px 9px" onclick="editBuiltInTpl('${t.key}')">Modifica copia</button>
      <button class="btn-sm btn-accent" style="font-size:8px;padding:3px 9px" onclick="applyBuiltInTpl('${t.key}')">Applica</button>
    </div>`).join('');

  html+=`<div style="font-family:'Inter',sans-serif;font-size:8px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;margin:14px 0 7px">Personalizzati (${custom.length})
    <button class="btn-sm btn-ghost" style="font-size:8px;padding:3px 9px;margin-left:10px;border-color:rgba(74,158,255,0.28);color:var(--blue)" onclick="newCustomTpl()">+ Crea nuovo</button></div>`;

  if(!custom.length){
    html+=`<div style="font-family:'Inter',sans-serif;font-size:10.5px;color:var(--text-muted);padding:14px;text-align:center;border:1px dashed rgba(255,255,255,0.07)">Nessun template personalizzato. Crea il tuo o clona un predefinito.</div>`;
  } else {
    html+=custom.map((t,i)=>`
      <div class="tpl-list-row">
        <div class="tl-badge green">Custom</div>
        <div class="tl-name">${t.nome||'Template '+i}</div>
        <div class="tl-meta">${tplManagerMode==='workout'?(t.groups?.length||0)+' gruppi':(t.meals?.length||0)+' pasti'}</div>
        <button class="btn-sm btn-ghost" style="font-size:8px;padding:3px 9px" onclick="editCustomTpl(${i})">Modifica</button>
        <button class="btn-sm btn-accent" style="font-size:8px;padding:3px 9px" onclick="applyCustomTpl(${i})">Applica</button>
        <button class="btn-sm btn-ghost" style="font-size:8px;padding:3px 9px;color:var(--accent);border-color:rgba(224,58,62,0.2)" onclick="deleteCustomTpl(${i})">X</button>
      </div>`).join('');
  }
  body.innerHTML=html;
}

function applyBuiltInTpl(key){
  if(tplManagerMode==='workout'){confirmLoadTemplate(key);closeTplManager();}
  else{confirmLoadDietTemplate(key);closeTplManager();}
}
function editBuiltInTpl(key){
  if(tplManagerMode==='workout'){
    const t=WORKOUT_TEMPLATES[key];
    tplEditObj=JSON.parse(JSON.stringify(t));tplEditObj._isNew=true;
  } else {
    const t=DIET_TEMPLATES[key];
    tplEditObj=JSON.parse(JSON.stringify(t));tplEditObj._isNew=true;
  }
  switchTplManagerTab('edit');
}
function newCustomTpl(){
  if(tplManagerMode==='workout'){
    tplEditObj={nome:'Nuovo Template',tipo:'Full Body',warm:'10',dur:'60',rec:'90',note:'',groups:[{name:'GRUPPO A',exercises:[{name:'',reps:'3×10',kg:'—',rest:'90s',rpe:'7',note:''}]}],_isNew:true};
  } else {
    tplEditObj={nome:'Nuovo Piano',kcal_target:2000,durata:4,meals:[{name:'Colazione',foods:[]},{name:'Pranzo',foods:[]},{name:'Cena',foods:[]}],_isNew:true};
  }
  switchTplManagerTab('edit');
}
function editCustomTpl(idx){
  const arr=tplManagerMode==='workout'?loadCustomWkTemplates():loadCustomDietTemplates();
  tplEditObj=JSON.parse(JSON.stringify(arr[idx]));tplEditObj._editIdx=idx;tplEditObj._isNew=false;
  switchTplManagerTab('edit');
}
function deleteCustomTpl(idx){
  if(!confirm('Eliminare questo template?'))return;
  if(tplManagerMode==='workout'){const arr=loadCustomWkTemplates();arr.splice(idx,1);saveCustomWkTemplates(arr);}
  else{const arr=loadCustomDietTemplates();arr.splice(idx,1);saveCustomDietTemplates(arr);}
  renderTplManagerList();flashSave('Template eliminato');
}
function applyCustomTpl(idx){
  if(tplManagerMode==='workout'){
    const arr=loadCustomWkTemplates();const t=arr[idx];
    workoutDays=buildWorkoutDaysFromTemplate(t);activeWkDay=0;
    document.getElementById('wk_freq').value=t.freq||'3x/settimana';
    selectWkDay(0);flashSave('Template caricato!');
  } else {
    const arr=loadCustomDietTemplates();const t=arr[idx];
    applyDietTemplateToWeek(t,'all');flashSave('Dieta caricata!');
  }
  closeTplManager();
}

// ── EDIT ──
function renderTplManagerEdit(){
  const body=document.getElementById('tpl_manager_body');
  if(!tplEditObj){body.innerHTML='<p style="color:var(--text-muted);font-family:Inter,sans-serif;font-size:11px">Nessun template selezionato.</p>';return;}
  if(tplManagerMode==='workout') renderWkTplEdit(body);
  else renderDietTplEdit(body);
}

// ── WORKOUT EDIT ──
function renderWkTplEdit(body){
  const t=tplEditObj;
  const groups=t.groups||[];
  let html=`
    <div class="tpl-edit-form">
      <div class="te-title">${t._isNew&&!t._editIdx!==undefined&&t._editIdx===undefined?'Nuova Copia':'Modifica Template Allenamento'}</div>
      <div class="tpl-row-3" style="margin-bottom:9px">
        <div class="field" style="margin:0"><label>Nome Template</label><input type="text" id="te_wk_nome" value="${t.nome||''}" oninput="tplEditObj.nome=this.value" style="background:var(--grey-dark);border:1px solid var(--grey-line);color:var(--white);font-family:'Barlow',sans-serif;font-size:12px;padding:6px 9px;width:100%;outline:none"></div>
        <div class="field" style="margin:0"><label>Tipo</label>
          <select id="te_wk_tipo" onchange="tplEditObj.tipo=this.value" style="background:var(--grey-dark);border:1px solid var(--grey-line);color:var(--white);font-family:'Barlow',sans-serif;font-size:12px;padding:6px 9px;width:100%;outline:none">
            ${getAllWkTypes().map(o=>`<option ${t.tipo===o?'selected':''}>${o}</option>`).join('')}
          </select>
        </div>
        <div class="field" style="margin:0"><label>Frequenza</label><input type="text" id="te_wk_freq" value="${t.freq||'3x/settimana'}" oninput="tplEditObj.freq=this.value" style="background:var(--grey-dark);border:1px solid var(--grey-line);color:var(--white);font-family:'Barlow',sans-serif;font-size:12px;padding:6px 9px;width:100%;outline:none"></div>
      </div>
      <div class="tpl-row-3" style="margin-bottom:9px">
        <div class="field" style="margin:0"><label>Riscaldamento (min)</label><input type="number" value="${t.warm||10}" oninput="tplEditObj.warm=this.value" style="background:var(--grey-dark);border:1px solid var(--grey-line);color:var(--white);font-family:'Barlow',sans-serif;font-size:12px;padding:6px 9px;width:100%;outline:none"></div>
        <div class="field" style="margin:0"><label>Durata sessione (min)</label><input type="number" value="${t.dur||60}" oninput="tplEditObj.dur=this.value" style="background:var(--grey-dark);border:1px solid var(--grey-line);color:var(--white);font-family:'Barlow',sans-serif;font-size:12px;padding:6px 9px;width:100%;outline:none"></div>
        <div class="field" style="margin:0"><label>Recupero serie (sec)</label><input type="number" value="${t.rec||90}" oninput="tplEditObj.rec=this.value" style="background:var(--grey-dark);border:1px solid var(--grey-line);color:var(--white);font-family:'Barlow',sans-serif;font-size:12px;padding:6px 9px;width:100%;outline:none"></div>
      </div>
      <div class="field" style="margin-bottom:9px"><label>Note</label><textarea oninput="tplEditObj.note=this.value" style="background:var(--grey-dark);border:1px solid var(--grey-line);color:var(--white);font-family:'Barlow',sans-serif;font-size:12px;padding:6px 9px;width:100%;outline:none;resize:vertical;min-height:44px">${t.note||''}</textarea></div>
      <div class="tpl-section-head">Gruppi & Esercizi</div>
      <div id="te_groups_container">`;
  groups.forEach((g,gi)=>{
    html+=`<div class="tpl-group-edit">
      <div class="tge-name">
        <input type="text" value="${g.name}" oninput="tplEditObj.groups[${gi}].name=this.value" style="background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.09);color:var(--white);font-family:'Bebas Neue',sans-serif;font-size:12px;letter-spacing:2px;outline:none;flex:1">
        <button class="te-del" onclick="tplWkRemoveGroup(${gi})">Gruppo</button>
      </div>`;
    g.exercises.forEach((ex,ei)=>{
      html+=`<div class="tpl-ex-mini">
        <input type="text" value="${ex.name}" placeholder="Esercizio" oninput="tplEditObj.groups[${gi}].exercises[${ei}].name=this.value" style="flex:2;min-width:130px">
        <input type="text" value="${ex.reps}" placeholder="Serie×Reps" oninput="tplEditObj.groups[${gi}].exercises[${ei}].reps=this.value" style="width:80px">
        <input type="text" value="${ex.kg}" placeholder="Kg" oninput="tplEditObj.groups[${gi}].exercises[${ei}].kg=this.value" style="width:55px">
        <input type="text" value="${ex.rest||'90s'}" placeholder="Rec" oninput="tplEditObj.groups[${gi}].exercises[${ei}].rest=this.value" style="width:50px">
        <input type="text" value="${ex.rpe||'7'}" placeholder="RPE" oninput="tplEditObj.groups[${gi}].exercises[${ei}].rpe=this.value" style="width:40px">
        <input type="text" value="${ex.note||''}" placeholder="Note" oninput="tplEditObj.groups[${gi}].exercises[${ei}].note=this.value" style="flex:1;min-width:80px">
        <button class="te-del" onclick="tplWkRemoveEx(${gi},${ei})">X</button>
      </div>`;
    });
    html+=`<button class="btn-add-ex" style="margin-top:5px;font-size:8.5px" onclick="tplWkAddEx(${gi})">+ Esercizio</button>
    </div>`;
  });
  html+=`</div>
      <div style="display:flex;gap:7px;margin-top:9px">
        <button class="btn-add-ex" style="width:auto;padding:5px 14px;font-size:9px" onclick="tplWkAddGroup()">+ Gruppo</button>
      </div>
      <div style="display:flex;gap:7px;justify-content:flex-end;margin-top:16px;border-top:1px solid var(--grey-line);padding-top:14px">
        <button class="btn-sm btn-ghost" onclick="switchTplManagerTab('list')">← Lista</button>
        <button class="btn-sm btn-green" onclick="saveCustomTpl()">Salva Template</button>
      </div>
    </div>`;
  body.innerHTML=html;
}
function tplWkAddGroup(){tplEditObj.groups.push({name:'NUOVO GRUPPO',exercises:[]});renderTplManagerEdit();}
function tplWkRemoveGroup(gi){tplEditObj.groups.splice(gi,1);renderTplManagerEdit();}
function tplWkAddEx(gi){tplEditObj.groups[gi].exercises.push({name:'',reps:'3×10',kg:'—',rest:'90s',rpe:'7',note:''});renderTplManagerEdit();}
function tplWkRemoveEx(gi,ei){tplEditObj.groups[gi].exercises.splice(ei,1);renderTplManagerEdit();}

// ── DIET EDIT ──
function renderDietTplEdit(body){
  const t=tplEditObj;
  const meals=t.meals||[];
  let html=`
    <div class="tpl-edit-form">
      <div class="te-title">Modifica Template Dieta</div>
      <div class="tpl-row-3" style="margin-bottom:9px">
        <div class="field" style="margin:0"><label>Nome Piano</label><input type="text" value="${t.nome||''}" oninput="tplEditObj.nome=this.value" style="background:var(--grey-dark);border:1px solid var(--grey-line);color:var(--white);font-family:'Barlow',sans-serif;font-size:12px;padding:6px 9px;width:100%;outline:none"></div>
        <div class="field" style="margin:0"><label>Kcal/die obiettivo</label><input type="number" value="${t.kcal_target||2000}" oninput="tplEditObj.kcal_target=parseFloat(this.value)||2000" style="background:var(--grey-dark);border:1px solid var(--grey-line);color:var(--white);font-family:'Barlow',sans-serif;font-size:12px;padding:6px 9px;width:100%;outline:none"></div>
        <div class="field" style="margin:0"><label>Durata (settimane)</label><input type="number" value="${t.durata||4}" oninput="tplEditObj.durata=parseInt(this.value)||4" style="background:var(--grey-dark);border:1px solid var(--grey-line);color:var(--white);font-family:'Barlow',sans-serif;font-size:12px;padding:6px 9px;width:100%;outline:none"></div>
      </div>
      <div class="tpl-section-head">Pasti & Alimenti</div>
      <div id="te_meals_container">`;
  meals.forEach((m,mi)=>{
    const mkcal=m.foods.reduce((a,f)=>a+(f.kcal||0)*((f.qta||f.g||100)/100),0);
    html+=`<div class="tpl-group-edit">
      <div class="tge-name">
        <input type="text" value="${m.name}" oninput="tplEditObj.meals[${mi}].name=this.value" style="background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.09);color:var(--white);font-family:'Bebas Neue',sans-serif;font-size:12px;letter-spacing:2px;outline:none;flex:1">
        <span style="font-family:'Bebas Neue',sans-serif;font-size:13px;color:var(--yellow);margin-right:5px">${mkcal.toFixed(0)} kcal</span>
        <button class="te-del" onclick="tplDietRemoveMeal(${mi})">Pasto</button>
      </div>`;
    // Food autocomplete search per questo pasto
    html+=`<div style="display:flex;gap:5px;margin-bottom:5px">
      <input type="text" placeholder="Cerca alimento…" id="te_food_search_${mi}" oninput="tplFoodSearch(this.value,${mi})" style="background:var(--grey-dark);border:1px solid var(--grey-line);color:var(--white);font-family:'Inter',sans-serif;font-size:11px;padding:4px 8px;flex:1;outline:none">
      <div id="te_food_results_${mi}" style="position:relative"></div>
    </div>
    <div id="te_food_dropdown_${mi}" style="display:none;background:var(--grey-mid);border:1px solid var(--grey-line);max-height:140px;overflow-y:auto;margin-bottom:5px"></div>`;
    m.foods.forEach((f,fi)=>{
      const q=parseFloat(f.qta||f.g||100);const r=q/100;
      html+=`<div class="tpl-ex-mini">
        <span style="font-family:'Inter',sans-serif;font-size:11px;flex:2;min-width:120px;letter-spacing:.5px">${f.name}</span>
        <input type="number" value="${q}" onchange="tplEditObj.meals[${mi}].foods[${fi}].qta=parseFloat(this.value)||100;renderTplManagerEdit()" style="width:65px">
        <span style="font-family:'Inter',sans-serif;font-size:9px;color:var(--text-muted)">g</span>
        <span style="font-family:'Bebas Neue',sans-serif;font-size:13px;color:var(--yellow);min-width:42px;text-align:right">${((f.kcal||0)*r).toFixed(0)}</span>
        <span style="font-family:'Inter',sans-serif;font-size:9px;color:#6ee;min-width:38px">P:${((f.prot||0)*r).toFixed(1)}</span>
        <span style="font-family:'Inter',sans-serif;font-size:9px;color:#ee6;min-width:38px">C:${((f.carb||0)*r).toFixed(1)}</span>
        <span style="font-family:'Inter',sans-serif;font-size:9px;color:#e96;min-width:38px">G:${((f.fat||0)*r).toFixed(1)}</span>
        <button class="te-del" onclick="tplDietRemoveFood(${mi},${fi})">X</button>
      </div>`;
    });
    html+=`</div>`;
  });
  html+=`</div>
      <div style="display:flex;gap:7px;margin-top:9px">
        <button class="btn-add-ex" style="width:auto;padding:5px 14px;font-size:9px" onclick="tplDietAddMeal()">+ Pasto</button>
      </div>
      <div style="display:flex;gap:7px;justify-content:flex-end;margin-top:16px;border-top:1px solid var(--grey-line);padding-top:14px">
        <button class="btn-sm btn-ghost" onclick="switchTplManagerTab('list')">← Lista</button>
        <button class="btn-sm btn-green" onclick="saveCustomTpl()">Salva Template</button>
      </div>
    </div>`;
  body.innerHTML=html;
}
function tplDietAddMeal(){const n=tplEditObj.meals.length+1;tplEditObj.meals.push({name:'PASTO '+n,foods:[]});renderTplManagerEdit();}
function tplDietRemoveMeal(mi){tplEditObj.meals.splice(mi,1);renderTplManagerEdit();}
function tplDietRemoveFood(mi,fi){tplEditObj.meals[mi].foods.splice(fi,1);renderTplManagerEdit();}
function tplFoodSearch(val,mi){
  const drop=document.getElementById('te_food_dropdown_'+mi);
  if(!val||val.length<2){drop.style.display='none';return;}
  const ALL=getFullFoodDB();
  const matches=ALL.filter(f=>f.name.toLowerCase().includes(val.toLowerCase())).slice(0,10);
  if(!matches.length){drop.style.display='none';return;}
  drop.style.display='block';
  drop.innerHTML=matches.map((f,i)=>`<div onclick="tplDietAddFood(${ALL.indexOf(f)},${mi})" style="padding:6px 10px;cursor:pointer;font-family:'Inter',sans-serif;font-size:11px;letter-spacing:.5px;border-bottom:1px solid rgba(255,255,255,0.04);display:flex;gap:8px;align-items:center" onmouseover="this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.background='transparent'">
    <span style="flex:1">${f._custom?'★ ':''}${f.name}</span>
    <span style="color:var(--yellow);font-family:'Bebas Neue',sans-serif;font-size:13px">${f.kcal}</span>
    <span style="color:var(--text-muted);font-size:9px">kcal/${f.g}g</span>
  </div>`).join('');
}
function tplDietAddFood(fi,mi){
  const ALL=getFullFoodDB();
  const src=ALL[fi];if(!src)return;
  const f={name:src.name,g:src.g,kcal:src.kcal,prot:src.prot,carb:src.carb,fat:src.fat,fibre:src.fibre};
  tplEditObj.meals[mi].foods.push({...f,qta:f.g});
  const searchEl=document.getElementById('te_food_search_'+mi);
  const drop=document.getElementById('te_food_dropdown_'+mi);
  if(searchEl)searchEl.value='';
  if(drop)drop.style.display='none';
  renderTplManagerEdit();
}

// ── SAVE ──
function saveCustomTpl(){
  if(!tplEditObj)return;
  if(tplManagerMode==='workout'){
    const arr=loadCustomWkTemplates();
    const toSave={...tplEditObj};delete toSave._isNew;
    const editIdx=toSave._editIdx;delete toSave._editIdx;
    if(editIdx!==undefined)arr[editIdx]=toSave;else arr.push(toSave);
    saveCustomWkTemplates(arr);
  } else {
    const arr=loadCustomDietTemplates();
    const toSave={...tplEditObj};delete toSave._isNew;
    const editIdx=toSave._editIdx;delete toSave._editIdx;
    if(editIdx!==undefined)arr[editIdx]=toSave;else arr.push(toSave);
    saveCustomDietTemplates(arr);
  }
  flashSave('Template salvato!');
  tplEditObj=null;
  switchTplManagerTab('list');
}

// Aggiorna pulsanti dinamici nelle barre (dopo close manager)
function refreshCustomTplButtons(){
  // Workout bar — rimuovi vecchi custom e ri-aggiungi
  const wkBar=document.querySelector('.template-bar');
  if(wkBar){
    wkBar.querySelectorAll('.tpl-btn.custom-tpl').forEach(b=>b.remove());
    const customWk=loadCustomWkTemplates();
    const gestBtn=wkBar.querySelector('button.btn-ghost');
    customWk.forEach((t,i)=>{
      const b=document.createElement('button');b.className='tpl-btn custom-tpl';
      b.textContent='★ '+t.nome;b.title='Template personalizzato';
      b.onclick=()=>{if(confirm('Applicare "'+t.nome+'"? Sostituisce il piano attuale.')){workoutDays=buildWorkoutDaysFromTemplate(t);activeWkDay=0;document.getElementById('wk_freq').value=t.freq||'3x/settimana';selectWkDay(0);flashSave('Template caricato!');}};
      b.style.cssText='background:rgba(46,204,113,0.07);border-color:rgba(46,204,113,0.2);color:var(--green)';
      if(gestBtn)wkBar.insertBefore(b,gestBtn);else wkBar.appendChild(b);
    });
  }
  // Diet bar
  const dietBar=document.querySelector('.diet-tpl-bar');
  if(dietBar){
    dietBar.querySelectorAll('.dtpl-btn.custom-tpl').forEach(b=>b.remove());
    const customDiet=loadCustomDietTemplates();
    const gestBtn=dietBar.querySelector('button.btn-ghost');
    customDiet.forEach((t,i)=>{
      const b=document.createElement('button');b.className='dtpl-btn custom-tpl';
      b.textContent='★ '+t.nome;b.title='Template personalizzato';
      b.onclick=()=>{tplManagerMode='diet';pendingDietTemplate='__custom_'+i;
        document.getElementById('modal_dtpl_title').textContent='Carica: '+t.nome;
        document.getElementById('modal_dtpl_desc').textContent=(t.meals?.length||0)+' pasti preimpostati.';
        document.getElementById('modal_diet_tpl').style.display='flex';
        // Override apply to use custom
        window._pendingCustomDietIdx=i;
      };
      if(gestBtn)dietBar.insertBefore(b,gestBtn);else dietBar.appendChild(b);
    });
  }
}

// Override applyDietTemplate to handle custom templates
const _origApplyDietTemplate=applyDietTemplate;
function applyDietTemplate(){
  if(pendingDietTemplate&&pendingDietTemplate.startsWith('__custom_')){
    const idx=window._pendingCustomDietIdx;
    const arr=loadCustomDietTemplates();const t=arr[idx];
    if(t){const mode=document.getElementById('diet_tpl_days').value;applyDietTemplateToWeek(t,mode);flashSave('Piano personalizzato caricato!');}
    closeDietTplModal();window._pendingCustomDietIdx=null;return;
  }
  _origApplyDietTemplate();
}

// ═══════════════════════════ TIPI ALLENAMENTO PERSONALIZZATI ═══════════════════════════
const BUILTIN_WK_TYPES=['Full Body','Upper/Lower','Push/Pull/Legs','Forza','Ipertrofia','Resistenza','HIIT','Cardio'];
function loadCustomWkTypes(){try{return JSON.parse(localStorage.getItem('nm_pro3_wk_types')||'[]')}catch(e){return[]}}
function saveCustomWkTypesArr(arr){try{localStorage.setItem('nm_pro3_wk_types',JSON.stringify(arr))}catch(e){}}
function getAllWkTypes(){return [...BUILTIN_WK_TYPES, ...loadCustomWkTypes()];}

function refreshWkTypeSelects(){
  const sel=document.getElementById('wk_tipo');
  if(sel){
    const cur=sel.value;
    sel.innerHTML=getAllWkTypes().map(t=>`<option ${t===cur?'selected':''}>${t}</option>`).join('');
  }
}

function openWkTypeManager(){
  document.getElementById('modal_wk_types').style.display='flex';
  renderWkTypesLists();
  document.getElementById('wk_new_type').value='';
  setTimeout(()=>document.getElementById('wk_new_type').focus(),50);
}
function closeWkTypeManager(){document.getElementById('modal_wk_types').style.display='none';}

function renderWkTypesLists(){
  document.getElementById('wk_types_built').innerHTML=BUILTIN_WK_TYPES.map(t=>`<span class="type-chip built">${t}</span>`).join('');
  const custom=loadCustomWkTypes();
  const cBox=document.getElementById('wk_types_custom');
  if(!custom.length){
    cBox.innerHTML=`<span style="font-family:'Inter',sans-serif;font-size:10.5px;color:var(--text-muted);letter-spacing:1px">Nessun tipo personalizzato. Aggiungilo qui sotto.</span>`;
  } else {
    cBox.innerHTML=custom.map((t,i)=>`<span class="type-chip custom">${t}<button class="tc-del" onclick="removeCustomWkType(${i})" title="Elimina">X</button></span>`).join('');
  }
}

function addCustomWkType(){
  const inp=document.getElementById('wk_new_type');
  const val=(inp.value||'').trim();
  if(!val){flashSave('Inserisci un nome');return;}
  const all=getAllWkTypes().map(t=>t.toLowerCase());
  if(all.includes(val.toLowerCase())){flashSave('Tipo già esistente');return;}
  const arr=loadCustomWkTypes();
  arr.push(val);
  saveCustomWkTypesArr(arr);
  inp.value='';
  renderWkTypesLists();
  refreshWkTypeSelects();
  flashSave('Tipo aggiunto');
}

function removeCustomWkType(idx){
  const arr=loadCustomWkTypes();
  if(!confirm('Eliminare il tipo "'+arr[idx]+'"?'))return;
  arr.splice(idx,1);
  saveCustomWkTypesArr(arr);
  renderWkTypesLists();
  refreshWkTypeSelects();
  flashSave('Tipo rimosso');
}

// ═══════════════════════════ ALIMENTI PERSONALIZZATI ═══════════════════════════
function loadCustomFoods(){try{return JSON.parse(localStorage.getItem('nm_pro3_custom_foods')||'[]')}catch(e){return[]}}
function saveCustomFoodsArr(arr){try{localStorage.setItem('nm_pro3_custom_foods',JSON.stringify(arr))}catch(e){}}

function getFullFoodDB(){
  const custom=loadCustomFoods().map(f=>({...f, _custom:true}));
  return [...FOOD_DB, ...custom];
}

let foodAddTab='search';
let editingCustomFoodIdx=null;

function openFoodAdder(){
  document.getElementById('modal_food_add').style.display='flex';
  resetFoodAdderForm();
  switchFoodAddTab('manual');
}
function closeFoodAdder(){
  document.getElementById('modal_food_add').style.display='none';
  editingCustomFoodIdx=null;
}

function resetFoodAdderForm(){
  document.getElementById('fa_name').value='';
  document.getElementById('fa_g').value=100;
  document.getElementById('fa_kcal').value='';
  document.getElementById('fa_prot').value='';
  document.getElementById('fa_carb').value='';
  document.getElementById('fa_fat').value='';
  document.getElementById('fa_fibre').value='';
  document.getElementById('fa_source').textContent='';
  editingCustomFoodIdx=null;
  document.getElementById('fa_save_btn').textContent='Salva alimento';
}

function switchFoodAddTab(tab){
  foodAddTab=tab;
  ['manual','list'].forEach(t=>{
    document.getElementById('fa_tab_'+t).classList.toggle('active', t===tab);
    document.getElementById('fa_panel_'+t).style.display = t===tab?'block':'none';
  });
  if(tab==='list')renderCustomFoodList();
  document.getElementById('fa_save_btn').style.display = tab==='list'?'none':'';
}

function escapeHtml(s){return String(s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));}

function saveCustomFood(){
  const name=(document.getElementById('fa_name').value||'').trim();
  if(!name){alert('Il nome è obbligatorio');return;}
  const g=parseFloat(document.getElementById('fa_g').value)||100;
  const obj={
    name,
    g:g,
    kcal:parseFloat(document.getElementById('fa_kcal').value)||0,
    prot:parseFloat(document.getElementById('fa_prot').value)||0,
    carb:parseFloat(document.getElementById('fa_carb').value)||0,
    fat:parseFloat(document.getElementById('fa_fat').value)||0,
    fibre:parseFloat(document.getElementById('fa_fibre').value)||0
  };
  const arr=loadCustomFoods();
  if(editingCustomFoodIdx!==null){
    arr[editingCustomFoodIdx]=obj;
    flashSave('Alimento modificato');
  } else {
    const allNames=getFullFoodDB().map(f=>f.name.toLowerCase());
    if(allNames.includes(name.toLowerCase())){
      if(!confirm('Esiste già un alimento con questo nome. Aggiungere comunque?'))return;
    }
    arr.push(obj);
    flashSave('Alimento aggiunto');
  }
  saveCustomFoodsArr(arr);
  resetFoodAdderForm();
  renderFoodLibrary();
  switchFoodAddTab('list');
}

function renderCustomFoodList(){
  const arr=loadCustomFoods();
  const box=document.getElementById('fa_custom_list');
  if(!arr.length){
    box.innerHTML=`<div style="font-family:'Inter',sans-serif;font-size:11px;color:var(--text-muted);padding:20px;text-align:center;border:1px dashed rgba(255,255,255,0.07);letter-spacing:1px">Nessun alimento personalizzato. Cerca online o inseriscine uno manualmente.</div>`;
    return;
  }
  box.innerHTML=arr.map((f,i)=>`<div class="fa-custom-row">
    <div class="fa-custom-name">${escapeHtml(f.name)}</div>
    <div class="fa-custom-macros">${f.kcal} kcal/${f.g}g · P${f.prot} C${f.carb} F${f.fat}</div>
    <button class="btn-sm btn-ghost" style="font-size:8px;padding:3px 8px" onclick="editCustomFood(${i})">Modifica</button>
    <button class="btn-sm btn-ghost" style="font-size:8px;padding:3px 8px;color:var(--accent);border-color:rgba(224,58,62,0.2)" onclick="deleteCustomFood(${i})">X</button>
  </div>`).join('');
}

function editCustomFood(i){
  const arr=loadCustomFoods();
  const f=arr[i];if(!f)return;
  editingCustomFoodIdx=i;
  document.getElementById('fa_name').value=f.name;
  document.getElementById('fa_g').value=f.g;
  document.getElementById('fa_kcal').value=f.kcal;
  document.getElementById('fa_prot').value=f.prot;
  document.getElementById('fa_carb').value=f.carb;
  document.getElementById('fa_fat').value=f.fat;
  document.getElementById('fa_fibre').value=f.fibre;
  document.getElementById('fa_source').textContent='Modifica alimento personalizzato.';
  document.getElementById('fa_save_btn').textContent='💾 Salva modifiche';
  switchFoodAddTab('manual');
}

function deleteCustomFood(i){
  const arr=loadCustomFoods();
  if(!confirm('Eliminare "'+arr[i].name+'"? I pasti che lo contengono manterranno una copia dei valori.'))return;
  arr.splice(i,1);
  saveCustomFoodsArr(arr);
  renderCustomFoodList();
  renderFoodLibrary();
  flashSave('Alimento eliminato');
}

// ═══════════════════════════ ESERCIZI PERSONALIZZATI ═══════════════════════════
function loadCustomExercises(){try{return JSON.parse(localStorage.getItem('nm_pro3_custom_ex')||'[]')}catch(e){return[]}}
function saveCustomExercisesArr(arr){try{localStorage.setItem('nm_pro3_custom_ex',JSON.stringify(arr))}catch(e){}}

// Restituisce EXERCISE_LIBRARY fusa con i custom (per gruppo)
function getFullExerciseLib(){
  // Clona il base
  const merged={};
  Object.keys(EXERCISE_LIBRARY).forEach(g=>merged[g]=EXERCISE_LIBRARY[g].map(e=>({...e})));
  // Aggiungi custom
  loadCustomExercises().forEach(e=>{
    if(!merged[e.group])merged[e.group]=[];
    merged[e.group].push({name:e.name,reps:e.reps,kg:e.kg,note:e.note,_custom:true});
  });
  return merged;
}

let exAddTab='manual';
let editingCustomExIdx=null;

function openExAdder(){
  document.getElementById('modal_ex_add').style.display='flex';
  resetExAdderForm();
  switchExAddTab('manual');
}
function closeExAdder(){
  document.getElementById('modal_ex_add').style.display='none';
  editingCustomExIdx=null;
}

function resetExAdderForm(){
  document.getElementById('ex_name').value='';
  document.getElementById('ex_group').value='Petto';
  document.getElementById('ex_reps').value='3×10';
  document.getElementById('ex_kg').value='—';
  document.getElementById('ex_note').value='';
  editingCustomExIdx=null;
  document.getElementById('ex_save_btn').textContent='Salva esercizio';
}

function switchExAddTab(tab){
  exAddTab=tab;
  ['manual','list'].forEach(t=>{
    document.getElementById('ex_tab_'+t).classList.toggle('active', t===tab);
    document.getElementById('ex_panel_'+t).style.display = t===tab?'block':'none';
  });
  if(tab==='list')renderCustomExList();
  document.getElementById('ex_save_btn').style.display = tab==='list'?'none':'';
}

function saveCustomEx(){
  const name=(document.getElementById('ex_name').value||'').trim();
  if(!name){alert('Il nome è obbligatorio');return;}
  const obj={
    name,
    group:document.getElementById('ex_group').value||'Petto',
    reps:(document.getElementById('ex_reps').value||'3×10').trim(),
    kg:(document.getElementById('ex_kg').value||'—').trim(),
    note:(document.getElementById('ex_note').value||'').trim()
  };
  const arr=loadCustomExercises();
  if(editingCustomExIdx!==null){
    arr[editingCustomExIdx]=obj;
    flashSave('Esercizio modificato');
  } else {
    // Verifica duplicato (stesso nome stesso gruppo)
    const dup=arr.some(e=>e.name.toLowerCase()===name.toLowerCase()&&e.group===obj.group)
      ||(EXERCISE_LIBRARY[obj.group]||[]).some(e=>e.name.toLowerCase()===name.toLowerCase());
    if(dup){
      if(!confirm('Esiste già un esercizio "'+name+'" in '+obj.group+'. Aggiungere comunque?'))return;
    }
    arr.push(obj);
    flashSave('Esercizio aggiunto');
  }
  saveCustomExercisesArr(arr);
  resetExAdderForm();
  renderLibrary();
  switchExAddTab('list');
}

function renderCustomExList(){
  const arr=loadCustomExercises();
  const box=document.getElementById('ex_custom_list');
  if(!arr.length){
    box.innerHTML=`<div style="font-family:'Inter',sans-serif;font-size:11px;color:var(--text-muted);padding:20px;text-align:center;border:1px dashed rgba(255,255,255,0.07);letter-spacing:1px">Nessun esercizio personalizzato. Creane uno dal tab "Nuovo / Modifica".</div>`;
    return;
  }
  // Raggruppa per gruppo muscolare
  const byGroup={};
  arr.forEach((e,i)=>{(byGroup[e.group]=byGroup[e.group]||[]).push({...e,_idx:i})});
  let html='';
  Object.keys(byGroup).forEach(g=>{
    html+=`<div style="font-family:'Inter',sans-serif;font-size:8px;letter-spacing:3px;color:var(--blue);text-transform:uppercase;margin:10px 0 5px">${g}</div>`;
    html+=byGroup[g].map(e=>`<div class="fa-custom-row">
      <div class="fa-custom-name">${escapeHtml(e.name)}</div>
      <div class="fa-custom-macros">${escapeHtml(e.reps)} · ${escapeHtml(e.kg)}${e.note?' · '+escapeHtml(e.note):''}</div>
      <button class="btn-sm btn-ghost" style="font-size:8px;padding:3px 8px" onclick="editCustomEx(${e._idx})">Modifica</button>
      <button class="btn-sm btn-ghost" style="font-size:8px;padding:3px 8px;color:var(--accent);border-color:rgba(224,58,62,0.2)" onclick="deleteCustomEx(${e._idx})">X</button>
    </div>`).join('');
  });
  box.innerHTML=html;
}

function editCustomEx(i){
  const arr=loadCustomExercises();
  const e=arr[i];if(!e)return;
  editingCustomExIdx=i;
  document.getElementById('ex_name').value=e.name;
  document.getElementById('ex_group').value=e.group;
  document.getElementById('ex_reps').value=e.reps;
  document.getElementById('ex_kg').value=e.kg;
  document.getElementById('ex_note').value=e.note||'';
  document.getElementById('ex_save_btn').textContent='💾 Salva modifiche';
  switchExAddTab('manual');
}

function deleteCustomEx(i){
  const arr=loadCustomExercises();
  if(!confirm('Eliminare "'+arr[i].name+'"? Le schede che lo contengono manterranno l\'esercizio.'))return;
  arr.splice(i,1);
  saveCustomExercisesArr(arr);
  renderCustomExList();
  renderLibrary();
  flashSave('Esercizio eliminato');
}

function init(){
  renderSidebar();updateHomeDashboard();renderCalendar();renderLibrary();renderFoodLibrary();
  document.getElementById('isak_data').value=new Date().toISOString().split('T')[0];
  document.getElementById('pay_date').value=new Date().toISOString().split('T')[0];
  refreshCustomTplButtons();
  refreshWkTypeSelects();
}

// ═══════════════════════════════════════════════════════════
//  SUPABASE INTEGRATION
// ═══════════════════════════════════════════════════════════
const SB_CONF_KEY='nm_sb_config';
const SB_TABLE='nm_data';
const SB_BUCKET='nm-photos';
let _sbClient=null;
let _sbUser=null;

// ── Config persistence ──────────────────────────────────────
function sbLoadConfig(){
  try{return JSON.parse(localStorage.getItem(SB_CONF_KEY)||'{}')}catch(e){return{}}
}
function sbSaveConfig(){
  const url=(document.getElementById('sb_url')?.value||'').trim();
  const key=(document.getElementById('sb_key')?.value||'').trim();
  localStorage.setItem(SB_CONF_KEY,JSON.stringify({url,key}));
}
function toggleSbConfig(){
  const sec=document.getElementById('sb_config_section');
  sec.classList.toggle('open');
}

// ── Init Supabase client ────────────────────────────────────
function sbGetClient(){
  if(_sbClient)return _sbClient;
  const conf=sbLoadConfig();
  if(!conf.url||!conf.key)return null;
  try{
    _sbClient=window.supabase.createClient(conf.url,conf.key);
    return _sbClient;
  }catch(e){return null;}
}

// ── Populate config fields from saved values ────────────────
function sbPreloadConfig(){
  const conf=sbLoadConfig();
  if(conf.url){const el=document.getElementById('sb_url');if(el)el.value=conf.url;}
  if(conf.key){const el=document.getElementById('sb_key');if(el)el.value=conf.key;}
}

// ── Set nav status indicator ────────────────────────────────
function sbSetNavStatus(state){
  // state: 'ok' | 'ko' | 'sync'
  const dot=document.getElementById('sb_nav_dot');
  const lbl=document.getElementById('sb_nav_label');
  if(!dot||!lbl)return;
  dot.className='sb-status-dot '+state;
  if(state==='ok')lbl.textContent=_sbUser?.email?.split('@')[0]||'Cloud';
  else if(state==='sync')lbl.textContent='Sync…';
  else lbl.textContent='Offline';
}

function sbShowSyncStatus(){
  const user=_sbUser;
  if(!user){flashSave('Non connesso a Supabase',true);return;}
  flashSave('✓ Connesso come '+user.email);
}

// ── LOGIN ───────────────────────────────────────────────────
async function sbLogin(){
  const btn=document.getElementById('sb_login_btn');
  const errEl=document.getElementById('sb_error');
  const email=(document.getElementById('sb_email')?.value||'').trim();
  const pass=document.getElementById('sb_pass')?.value||'';
  errEl.textContent='';
  if(!email||!pass){errEl.textContent='Inserisci email e password.';return;}
  const sb=sbGetClient();
  if(!sb){errEl.textContent='Configura prima URL e Anon Key Supabase (⚙ sotto).';return;}
  btn.disabled=true;btn.textContent='Accesso in corso…';
  try{
    const {data,error}=await sb.auth.signInWithPassword({email,password:pass});
    if(error)throw error;
    _sbUser=data.user;
    await sbLoadFromCloud();
    document.getElementById('sb_login_overlay').classList.add('hidden');
    sbSetNavStatus('ok');
    flashSave('✓ Benvenuto, '+(data.user.email.split('@')[0]));
  }catch(err){
    errEl.textContent=err.message||'Errore di accesso. Controlla credenziali.';
    btn.disabled=false;btn.textContent='Entra';
  }
}

// ── LOGOUT ──────────────────────────────────────────────────
async function sbLogout(){
  if(!confirm('Disconnettersi da Supabase?'))return;
  const sb=sbGetClient();
  if(sb)await sb.auth.signOut();
  _sbUser=null;
  sbSetNavStatus('ko');
  document.getElementById('sb_login_overlay').classList.remove('hidden');
  document.getElementById('sb_pass').value='';
  flashSave('Disconnesso');
}

// ── LOAD DATA FROM CLOUD ────────────────────────────────────
async function sbLoadFromCloud(){
  const sb=sbGetClient();
  if(!sb||!_sbUser)return;
  try{
    const {data,error}=await sb
      .from(SB_TABLE)
      .select('payload')
      .eq('user_id',_sbUser.id)
      .single();
    if(error&&error.code==='PGRST116'){
      // No row yet — first time, push local data
      await sbPushToCloud();
      return;
    }
    if(error)throw error;
    if(data?.payload){
      const remote=data.payload;
      // Merge: prefer remote, but keep local photos if remote has none
      const localDB=loadStore();
      // If remote is newer (has more clients or same), use remote
      const merged=remote;
      // Restore photos from local if remote photos are stripped
      if(merged.clients){
        merged.clients.forEach((rc,i)=>{
          if(!rc.foto?.length && localDB.clients?.[i]?.foto?.length){
            rc.foto=localDB.clients[i].foto;
          }
        });
      }
      DB=merged;
      if(!DB.clients)DB.clients=[];
      if(!DB.appointments)DB.appointments={};
      saveStore(DB);
      init();
    }
  }catch(err){
    console.warn('sbLoad error:',err);
    flashSave('Cloud: '+err.message,true);
  }
}

// ── PUSH DATA TO CLOUD ──────────────────────────────────────
async function sbPushToCloud(){
  const sb=sbGetClient();
  if(!sb||!_sbUser)return;
  sbSetNavStatus('sync');
  try{
    // Strip photo base64 from cloud copy (store photos in Storage separately)
    const dbCopy=JSON.parse(JSON.stringify(DB));
    // Keep photo metadata but strip data URLs from cloud JSON to save space
    // Photos are stored in Supabase Storage by sbSavePhoto()
    if(dbCopy.clients){
      dbCopy.clients.forEach(c=>{
        if(c.foto){
          c.foto=c.foto.map(f=>({
            id:f.id,date:f.date,nome:f.nome,sizeKb:f.sizeKb,w:f.w,h:f.h,
            // store data URL in local only; cloud path if uploaded
            storagePath:f.storagePath||null
          }));
        }
      });
    }
    const {error}=await sb
      .from(SB_TABLE)
      .upsert({user_id:_sbUser.id,payload:dbCopy,updated_at:new Date().toISOString()},
              {onConflict:'user_id'});
    if(error)throw error;
    sbSetNavStatus('ok');
  }catch(err){
    console.warn('sbPush error:',err);
    sbSetNavStatus('ko');
    flashSave('⚠ Sync cloud fallita',true);
  }
}

// ── SAVE PHOTO TO SUPABASE STORAGE ──────────────────────────
async function sbSavePhoto(clientIdx,photoEntry){
  const sb=sbGetClient();
  if(!sb||!_sbUser)return null;
  try{
    // Convert data URL to Blob
    const res=await fetch(photoEntry.data);
    const blob=await res.blob();
    const path=`${_sbUser.id}/${clientIdx}/${photoEntry.id}.jpg`;
    const {error}=await sb.storage
      .from(SB_BUCKET)
      .upload(path,blob,{contentType:'image/jpeg',upsert:true});
    if(error)throw error;
    // Get public URL
    const {data}=sb.storage.from(SB_BUCKET).getPublicUrl(path);
    return {path,url:data.publicUrl};
  }catch(err){
    console.warn('sbPhoto error:',err);
    return null;
  }
}

// ── LOAD PHOTO FROM STORAGE (restore data URL) ──────────────
async function sbLoadPhotoData(storagePath){
  const sb=sbGetClient();
  if(!sb)return null;
  try{
    const {data}=sb.storage.from(SB_BUCKET).getPublicUrl(storagePath);
    return data.publicUrl; // Return URL directly (use as img src)
  }catch(e){return null;}
}

// ── OVERRIDE saveStore to also push to cloud ─────────────────
const _origSaveStore=saveStore;
function saveStore(d){
  _origSaveStore(d);
  if(_sbUser)sbPushToCloud();
}

// ── OVERRIDE handleFotoUpload to also save to Storage ────────
const _origHandleFotoUpload=handleFotoUpload;
function handleFotoUpload(input){
  // Run original upload (saves base64 locally)
  _origHandleFotoUpload(input);
  // After a brief delay, push photos to Storage too
  if(_sbUser&&currentClientIdx!==null){
    setTimeout(async()=>{
      const fotos=DB.clients[currentClientIdx]?.foto||[];
      for(const f of fotos){
        if(!f.storagePath&&f.data){
          const result=await sbSavePhoto(currentClientIdx,f);
          if(result){f.storagePath=result.path;f.storageUrl=result.url;}
        }
      }
      // Re-save with updated paths
      _origSaveStore(DB);
      sbPushToCloud();
    },500);
  }
}

// ── AUTO LOGIN on load (check existing session) ──────────────
async function sbAutoLogin(){
  sbPreloadConfig();
  const sb=sbGetClient();
  if(!sb){
    // No config yet — show overlay with config section open
    document.getElementById('sb_config_section').classList.add('open');
    return;
  }
  try{
    const {data}=await sb.auth.getSession();
    if(data?.session?.user){
      _sbUser=data.session.user;
      document.getElementById('sb_email').value=_sbUser.email||'';
      await sbLoadFromCloud();
      document.getElementById('sb_login_overlay').classList.add('hidden');
      sbSetNavStatus('ok');
      flashSave('✓ Sessione ripristinata');
    }
  }catch(e){
    // Session expired or error — stay on login screen
    console.warn('sbAutoLogin:',e);
  }
}

// ── START ────────────────────────────────────────────────────
init();
sbAutoLogin();

</script>

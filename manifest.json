function showAddPayment(){document.getElementById('pay_date').value=new Date().toISOString().split('T')[0];document.getElementById('pay_amount').value='';document.getElementById('pay_desc').value='';document.getElementById('pay_status').value='paid';document.getElementById('pay_note_text').value='';document.getElementById('modal_payment').style.display='flex';}
function closePayModal(){document.getElementById('modal_payment').style.display='none';}
function addPayment(){
  if(currentClientIdx===null)return;
  const c=DB.clients[currentClientIdx];if(!c.payments)c.payments=[];
  c.payments.push({date:document.getElementById('pay_date').value,amount:parseFloat(document.getElementById('pay_amount').value)||0,desc:document.getElementById('pay_desc').value,status:document.getElementById('pay_status').value,note:document.getElementById('pay_note_text').value});
  c.payments.sort((a,b)=>b.date.localeCompare(a.date));saveStore(DB);closePayModal();renderPayments();updateHomeDashboard();flashSave('Pagamento aggiunto!');
}
function deletePayment(idx){if(!confirm('Eliminare?'))return;DB.clients[currentClientIdx].payments.splice(idx,1);saveStore(DB);renderPayments();updateHomeDashboard();}
function renderPayments(){
  if(currentClientIdx===null)return;
  const payments=DB.clients[currentClientIdx].payments||[];
  let total=0,paidN=0,pending=0,pendingN=0;
  payments.forEach(p=>{if(p.status==='paid'){total+=parseFloat(p.amount)||0;paidN++;}else{pending+=parseFloat(p.amount)||0;pendingN++;}});
  document.getElementById('pay_totale').textContent='€'+total.toFixed(2);
  document.getElementById('pay_totale_sub').textContent=paidN+' pagamento/i';
  document.getElementById('pay_pending').textContent='€'+pending.toFixed(2);
  document.getElementById('pay_pending_sub').textContent=pendingN+' in sospeso';
  const list=document.getElementById('pay_list');
  if(!payments.length){list.innerHTML='<div class="empty-state" style="padding:26px"><div class="es-icon">💳</div><p>Nessun pagamento</p></div>';return;}
  const sl={paid:'Pagato',pending:'In attesa',overdue:'Scaduto'};
  list.innerHTML=payments.map((p,i)=>{const pts=p.date.split('-');return`<div class="pay-item"><div class="pi-date">${pts[2]}/${pts[1]}/${pts[0]}</div><div><div class="pi-desc">${p.desc||'Pagamento'}</div><div class="pi-note">${p.note||'—'}</div></div><div class="pi-amt">€${parseFloat(p.amount).toFixed(2)}</div><div class="pi-badge ${p.status}">${sl[p.status]||p.status}</div><button class="ex-del" onclick="deletePayment(${i})" style="margin-left:7px">X</button></div>`;}).join('');
}


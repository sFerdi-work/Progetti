// ═══════════════════════════ MIFFLIN–ST JEOR ═══════════════════════════
const MSJ_AF={
  'Sedentario':       {f:1.200, label:'Sedentario'},
  '1-2 volte/sett':  {f:1.375, label:'Leg. attivo'},
  '3-5 volte/sett':  {f:1.550, label:'Mod. attivo'},
  'Ogni giorno':     {f:1.725, label:'Molto attivo'},
  'Atleta agonista': {f:1.900, label:'Atleta'}
};
const MSJ_OBJ={
  'dimagrimento':  {delta:-500, label:'Dimagrimento',   hint:'Deficit ~500 kcal → −0.5 kg/sett. Proteine ≥ 1.8 g/kg'},
  'ipertrofia':    {delta:+400, label:'Ipertrofia',      hint:'Surplus ~400 kcal. Proteine 2.0–2.2 g/kg, CHO elevati'},
  'forza':         {delta:+200, label:'Forza',           hint:'Surplus moderato ~200 kcal. Proteine 1.8–2.0 g/kg'},
  'tonificazione': {delta:  -200, label:'Tonificazione', hint:'Lieve deficit ~200 kcal. Proteine 1.8 g/kg, training HV'},
  'resistenza':    {delta:   0, label:'Mantenimento',    hint:'Mantenimento. Carboidrati elevati (5–7 g/kg) per performance'},
  'riabilitazione':{delta:   0, label:'Mantenimento',    hint:'Mantenimento. Dieta bilanciata, anti-infiammatoria'},
  'sport':         {delta:+300, label:'Performance',     hint:'Surplus ~300 kcal. CHO 6–8 g/kg, proteine 2.0 g/kg'}
};

function syncMSJSesso(v){const el=document.getElementById('msj_sesso');if(el)el.value=v;computeMSJ();}

function computeMSJ(){
  const peso=parseFloat(document.getElementById('msj_peso')?.value);
  const alt=parseFloat(document.getElementById('msj_altezza')?.value);
  const eta=parseFloat(document.getElementById('msj_eta')?.value);
  const sesso=document.getElementById('msj_sesso')?.value;
  const attivita=document.getElementById('cl_attivita')?.value||'';
  const obiettivo=document.getElementById('cl_obiettivo')?.value||'';
  const res=document.getElementById('msj_results');
  const inc=document.getElementById('msj_incomplete');
  if(!peso||!alt||!eta||!sesso){if(res)res.style.display='none';if(inc)inc.style.display='block';return;}
  if(inc)inc.style.display='none';
  // BMR
  const bmr=sesso==='M'
    ?(10*peso)+(6.25*alt)-(5*eta)+5
    :(10*peso)+(6.25*alt)-(5*eta)-161;
  // TDEE
  const af=MSJ_AF[attivita]||{f:1.375,label:'Leg. attivo'};
  const tdee=Math.round(bmr*af.f);
  // Target obiettivo
  const obj=MSJ_OBJ[obiettivo];
  const target=obj?tdee+obj.delta:tdee;
  const delta=obj?obj.delta:0;
  // Aggiorna UI
  document.getElementById('msj_bmr_val').textContent=Math.round(bmr);
  document.getElementById('msj_tdee_val').textContent=tdee;
  document.getElementById('msj_attivita_label').textContent=af.label;
  document.getElementById('msj_target_val').textContent=target;
  document.getElementById('msj_obiettivo_label').textContent=obj?obj.label:'Nessun obiettivo';
  const deltaEl=document.getElementById('msj_delta_label');
  if(delta!==0) deltaEl.textContent=(delta>0?'+ ':'− ')+Math.abs(delta)+' kcal vs TDEE';
  else deltaEl.textContent='= TDEE';
  document.getElementById('msj_macro_hint').textContent=obj?obj.hint:'';
  if(res)res.style.display='block';
}

function applyMSJTarget(){
  const tv=document.getElementById('msj_target_val')?.textContent;
  if(!tv||tv==='—')return;
  const el=document.getElementById('diet_kcal_target');
  if(el){el.value=tv;computeDiet();}
  flashSave('✓ Target '+tv+' kcal applicato al piano dieta');
  showDtab('dieta');
}
function applyObiettivoTemplate(withDiet){
  if(!pendingObiettivoKey)return;
  const map=OBIETTIVO_MAP[pendingObiettivoKey];
  const wktpl=WORKOUT_TEMPLATES[map.workout];
  if(wktpl){document.getElementById('wk_freq').value=map.freq;workoutDays=buildWorkoutDaysFromTemplate(wktpl);activeWkDay=0;selectWkDay(0);}
  if(withDiet){const dtpl=DIET_TEMPLATES[map.diet];if(dtpl)applyDietTemplateToWeek(dtpl,'all');}
  document.getElementById('obiettivo_suggestion').style.display='none';
  showDtab('allenamento');flashSave('Scheda generata da obiettivo!');
}

// ═══════════════════════════ ISAK ═══════════════════════════
function iv(id){return parseFloat(document.getElementById(id)?.value)||0}
function ivr(id){return parseFloat(document.getElementById(id)?.value)}
function computeISAK(){
  const peso=ivr('peso'),mg=ivr('mg_kg'),statura=ivr('statura');
  if(!isNaN(mg)&&!isNaN(peso)&&peso>0){
    document.getElementById('mpg_disp').innerHTML=(peso-mg).toFixed(2)+'<span class="m-unit" style="font-size:9.5px;margin-left:3px">kg</span>';
    const perc=((mg/peso)*100).toFixed(1);
    document.getElementById('perc_mg_disp').innerHTML=perc+'<span class="m-unit" style="font-size:9.5px;margin-left:3px">%</span>';
    document.getElementById('s_perc_mg').textContent=perc;
  }else{document.getElementById('mpg_disp').innerHTML='—<span class="m-unit" style="font-size:9.5px;margin-left:3px">kg</span>';document.getElementById('perc_mg_disp').innerHTML='—<span class="m-unit" style="font-size:9.5px;margin-left:3px">%</span>';document.getElementById('s_perc_mg').textContent='—';}
  if(!isNaN(peso)&&!isNaN(statura)&&statura>0)document.getElementById('s_imc').textContent=(peso/((statura/100)**2)).toFixed(1);else document.getElementById('s_imc').textContent='—';
  document.getElementById('s_peso').textContent=isNaN(ivr('peso'))?'—':ivr('peso');
  const p6=['p_triceps','p_sott','p_cresta','p_sopra','p_add','p_coscia'],p8=[...p6,'p_biceps','p_gamba'];
  const v6=p6.map(id=>ivr(id)).filter(x=>!isNaN(x)),v8=p8.map(id=>ivr(id)).filter(x=>!isNaN(x));
  document.getElementById('s_sigma6').textContent=v6.length===6?v6.reduce((a,b)=>a+b,0).toFixed(1):'—';
  document.getElementById('s_sigma8').textContent=v8.length===8?v8.reduce((a,b)=>a+b,0).toFixed(1):'—';
  // Sync peso/statura → MSJ
  if(!isNaN(peso)&&peso>0){const mp=document.getElementById('msj_peso');if(mp&&!mp.value)mp.value=peso;}
  if(!isNaN(statura)&&statura>0){const ma=document.getElementById('msj_altezza');if(ma&&!ma.value)ma.value=statura;}
  computeMSJ();
}


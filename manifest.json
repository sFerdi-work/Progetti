// dietWeek: array di 7 giorni, ogni giorno è array di pasti
let dietWeek=Array.from({length:7},()=>([{name:'Colazione',foods:[]},{name:'Pranzo',foods:[]},{name:'Cena',foods:[]}]));
let activeDietDay=0;
let activeMealIdx=null;
let pendingDietTemplate=null;

function initDietDayTabs(){
  const tabs=document.getElementById('diet_day_tabs');
  tabs.innerHTML=DAYS_IT.map((d,i)=>`<div class="day-tab ${i===activeDietDay?'active':''} ${hasDietData(i)?'has-data':''}" onclick="selectDietDay(${i})">${d.slice(0,3)}</div>`).join('');
}
function hasDietData(dayIdx){return dietWeek[dayIdx].some(m=>m.foods.length>0);}
function selectDietDay(i){activeDietDay=i;activeMealIdx=null;initDietDayTabs();renderDiet();computeDiet();}
function loadDiet(diet){
  if(diet&&diet.week&&Array.isArray(diet.week)&&diet.week.length===7){
    dietWeek=JSON.parse(JSON.stringify(diet.week));
    document.getElementById('diet_nome').value=diet.nome||'';
    document.getElementById('diet_kcal_target').value=diet.kcal_target||'';
    document.getElementById('diet_durata').value=diet.durata||'';
    document.getElementById('diet_note').value=diet.note||'';
    document.getElementById('diet_scad').value=diet.scad||'';
  }else{dietWeek=Array.from({length:7},()=>JSON.parse(JSON.stringify([{name:'Colazione',foods:[]},{name:'Pranzo',foods:[]},{name:'Cena',foods:[]}])));}
  activeDietDay=0;activeMealIdx=null;
  const foodSearch=document.getElementById('food_library_search');if(foodSearch)foodSearch.value='';
  initDietDayTabs();renderDiet();computeDiet();renderFoodLibrary();
}

function confirmLoadDietTemplate(key){
  pendingDietTemplate=key;const tpl=DIET_TEMPLATES[key];
  document.getElementById('modal_dtpl_title').textContent='Carica: '+tpl.nome;
  document.getElementById('modal_dtpl_desc').textContent=tpl.meals.length+' pasti preimpostati con alimenti. Scegli su quanti giorni applicarlo:';
  document.getElementById('modal_diet_tpl').style.display='flex';
}
function closeDietTplModal(){document.getElementById('modal_diet_tpl').style.display='none';pendingDietTemplate=null;}
function applyDietTemplate(){
  if(!pendingDietTemplate)return;
  const tpl=DIET_TEMPLATES[pendingDietTemplate];
  const mode=document.getElementById('diet_tpl_days').value;
  applyDietTemplateToWeek(tpl,mode);
  closeDietTplModal();flashSave('Piano dieta caricato!');
}
function loadDietTemplateDirect(key){
  const tpl=DIET_TEMPLATES[key];
  if(!tpl)return;
  const mode=document.getElementById('diet_tpl_scope').value;
  applyDietTemplateToWeek(tpl,mode);
  const scopeLabel={all:'tutta la settimana',current:'giorno selezionato',weekdays:'Lun–Ven',weekend:'Sab–Dom'};
  flashSave('✓ '+tpl.nome+' → '+scopeLabel[mode]);
}
function copyDayToAll(){
  const src=JSON.parse(JSON.stringify(dietWeek[activeDietDay]));
  dietWeek.forEach((_,i)=>{if(i!==activeDietDay)dietWeek[i]=JSON.parse(JSON.stringify(src));});
  initDietDayTabs();flashSave('Giorno copiato su tutta la settimana!');
}
function renderDiet(){
  const meals=dietWeek[activeDietDay];
  const container=document.getElementById('diet_meals');
  if(!meals.length){container.innerHTML='<div class="empty-state" style="padding:22px"><div class="es-icon">🥗</div><p>Usa un template o aggiungi un pasto</p></div>';return;}
  container.innerHTML=meals.map((meal,mi)=>{
    const mkcal=meal.foods.reduce((a,f)=>a+(parseFloat(f.kcal)||0)*(parseFloat(f.qta)||100)/100,0);
    const isActive=activeMealIdx===mi;
    return`<div class="meal-block" style="${isActive?'border-color:rgba(46,204,113,0.3)':''}">
      <div class="meal-head">
        <input value="${meal.name}" style="background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.09);color:var(--white);font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:2px;outline:none;width:160px" onchange="dietWeek[${activeDietDay}][${mi}].name=this.value">
        <button class="btn-add-ex" style="width:auto;padding:3px 9px;margin:0 0 0 7px;font-size:8.5px;border-color:${isActive?'rgba(46,204,113,0.4)':'rgba(255,255,255,0.09)'};color:${isActive?'var(--green)':'var(--text-muted)'}" onclick="setActiveMeal(${mi})">${isActive?'✓ Attivo':'Seleziona'}</button>
        <button class="btn-add-ex" style="width:auto;padding:3px 9px;margin:0 0 0 4px;font-size:8.5px" onclick="addFoodToMeal(${mi})">+ Alimento</button>
        <div class="meal-kcal" style="margin-left:auto">${mkcal.toFixed(0)}</div><div class="meal-kcal-label">kcal</div>
        <button class="ex-del" onclick="removeMeal(${mi})" style="margin-left:7px">X</button>
      </div>
      <table class="food-table" style="width:100%">
        <thead><tr><th style="width:30%">Alimento</th><th style="width:10%">g</th><th style="width:9%">kcal</th><th style="width:9%">Prot</th><th style="width:9%">Carb</th><th style="width:9%">Grassi</th><th style="width:9%">Fibre</th><th style="width:5%"></th></tr></thead>
        <tbody>${meal.foods.map((f,fi)=>{const q=parseFloat(f.qta)||100,r=q/100;return`<tr><td><input class="food-input food-name" value="${f.name}" onchange="dietWeek[${activeDietDay}][${mi}].foods[${fi}].name=this.value;computeDiet()" style="width:100%"></td><td><input class="food-input food-num" type="number" value="${q}" onchange="dietWeek[${activeDietDay}][${mi}].foods[${fi}].qta=parseFloat(this.value)||100;renderDiet();computeDiet()" style="width:58px"></td><td style="font-family:'Bebas Neue',sans-serif;font-size:13px;color:var(--yellow)">${((f.kcal||0)*r).toFixed(0)}</td><td style="font-family:'Inter',sans-serif;font-size:11px;color:#6ee">${((f.prot||0)*r).toFixed(1)}g</td><td style="font-family:'Inter',sans-serif;font-size:11px;color:#ee6">${((f.carb||0)*r).toFixed(1)}g</td><td style="font-family:'Inter',sans-serif;font-size:11px;color:#e96">${((f.fat||0)*r).toFixed(1)}g</td><td style="font-family:'Inter',sans-serif;font-size:11px;color:var(--text-muted)">${((f.fibre||0)*r).toFixed(1)}g</td><td><button class="ex-del" onclick="removeFoodFromMeal(${mi},${fi})">X</button></td></tr>`;}).join('')}</tbody>
      </table>
    </div>`;
  }).join('');
}
function renderFoodLibrary(filter=''){
  const grid=document.getElementById('food_library_grid');
  const f=(filter||'').toLowerCase().trim();
  if(!f){grid.innerHTML='';return;}
  const all=getFullFoodDB();
  grid.innerHTML=all.map((fd,fi)=>{if(!fd.name.toLowerCase().includes(f))return'';return`<div class="food-chip ${fd._custom?'custom-food':''}" onclick="quickAddFood(${fi})" title="${fd._custom?'Personalizzato':''}">${fd._custom?'★ ':''}${fd.name}<span class="fc-kcal">${fd.kcal}</span><span style="font-family:'Inter',sans-serif;font-size:7px;color:var(--text-muted)">kcal/${fd.g}g</span></div>`;}).join('');
}
function setActiveMeal(mi){activeMealIdx=mi;renderDiet();}
function quickAddFood(fi){
  let mi=activeMealIdx;
  if(mi===null){const meals=dietWeek[activeDietDay];if(meals.length){mi=meals.length-1;}else{addMealToDay();mi=0;}}
  const all=getFullFoodDB();
  const src=all[fi];if(!src)return;
  const f={name:src.name,g:src.g,kcal:src.kcal,prot:src.prot,carb:src.carb,fat:src.fat,fibre:src.fibre,qta:src.g};
  dietWeek[activeDietDay][mi].foods.push(f);renderDiet();computeDiet();
}
function addMealToDay(){const n=dietWeek[activeDietDay].length+1;dietWeek[activeDietDay].push({name:'PASTO '+n,foods:[]});activeMealIdx=dietWeek[activeDietDay].length-1;renderDiet();computeDiet();initDietDayTabs();}
function removeMeal(mi){dietWeek[activeDietDay].splice(mi,1);activeMealIdx=null;renderDiet();computeDiet();initDietDayTabs();}
function addFoodToMeal(mi){dietWeek[activeDietDay][mi].foods.push({name:'',qta:100,kcal:0,prot:0,carb:0,fat:0,fibre:0});renderDiet();computeDiet();}
function removeFoodFromMeal(mi,fi){dietWeek[activeDietDay][mi].foods.splice(fi,1);renderDiet();computeDiet();}
function computeDiet(){
  let totK=0,totP=0,totC=0,totF=0;
  dietWeek[activeDietDay].forEach(m=>m.foods.forEach(f=>{const r=(parseFloat(f.qta)||100)/100;totK+=(parseFloat(f.kcal)||0)*r;totP+=(parseFloat(f.prot)||0)*r;totC+=(parseFloat(f.carb)||0)*r;totF+=(parseFloat(f.fat)||0)*r;}));
  document.getElementById('ds_kcal').textContent=totK.toFixed(0);document.getElementById('ds_prot').textContent=totP.toFixed(1);document.getElementById('ds_carb').textContent=totC.toFixed(1);document.getElementById('ds_fat').textContent=totF.toFixed(1);
  // media sett
  let totWeek=0;dietWeek.forEach(day=>day.forEach(m=>m.foods.forEach(f=>{totWeek+=(parseFloat(f.kcal)||0)*((parseFloat(f.qta)||100)/100);})));
  document.getElementById('ds_avg').textContent=(totWeek/7).toFixed(0);
}


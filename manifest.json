      <button class="btn-sm" style="background:var(--accent);color:#fff;font-weight:700;padding:9px 16px;border:none;cursor:pointer;font-family:'Inter',sans-serif;font-size:11px;letter-spacing:2px;text-transform:uppercase;width:100%" onclick="deleteClient(false)">Elimina cliente e le sue foto</button>
      <button class="btn-sm" style="background:rgba(244,196,48,0.12);color:var(--yellow);border:1px solid rgba(244,196,48,0.25);padding:9px 16px;cursor:pointer;font-family:'Inter',sans-serif;font-size:11px;letter-spacing:2px;text-transform:uppercase;width:100%" onclick="deleteClient(true)">Elimina cliente, mantieni le foto</button>
      <button class="btn-sm btn-ghost" style="width:100%;padding:9px 16px" onclick="closeDeleteClientModal()">Annulla</button>
    </div>
  </div>
</div>


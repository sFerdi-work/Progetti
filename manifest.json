<script>
// ═══════════════════════════ DATA ═══════════════════════════
function loadStore(){try{return JSON.parse(localStorage.getItem('nm_pro3')||'{}')}catch(e){return{}}}
function saveStore(d){try{localStorage.setItem('nm_pro3',JSON.stringify(d))}catch(e){}}
let DB=loadStore();
if(!DB.clients)DB.clients=[];
if(!DB.appointments)DB.appointments={};
let currentClientIdx=null;
let calYear=new Date().getFullYear(),calMonth=new Date().getMonth(),calSelectedDate=null;
const MONTHS_IT=['Gennaio','Febbraio','Marzo','Aprile','Maggio','Giugno','Luglio','Agosto','Settembre','Ottobre','Novembre','Dicembre'];
const DAYS_IT=['Lunedì','Martedì','Mercoledì','Giovedì','Venerdì','Sabato','Domenica'];

// ═══════════════════════════ NAV ═══════════════════════════
function showPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  const btn=document.querySelector(`.tab-btn[onclick="showPage('${id}')"]`);
  if(btn)btn.classList.add('active');
  if(id==='home')updateHomeDashboard();
  if(id==='grafici')setTimeout(buildCharts,80);
  if(id==='calendario')renderCalendar();
}

// ═══════════════════════════ HOME ═══════════════════════════
function updateHomeDashboard(){
  document.getElementById('stat_clienti').textContent=DB.clients.length;
  document.getElementById('stat_appt').textContent=Object.values(DB.appointments).flat().length;
  let totalInc=0;DB.clients.forEach(c=>{(c.payments||[]).forEach(p=>{if(p.status==='paid')totalInc+=parseFloat(p.amount)||0})});
  document.getElementById('stat_incasso').textContent='€'+totalInc.toFixed(0);
  const today=new Date();today.setHours(0,0,0,0);
  let payOk=0,schedeExp=0,payOverdue=0;
  DB.clients.forEach(c=>{
    (c.payments||[]).forEach(p=>{if(p.status==='paid')payOk++;if(p.status==='overdue')payOverdue++;});
    const diff7=7*24*3600*1000;
    ['scad_all','scad_diet'].forEach(k=>{if(c[k]){const d=new Date(c[k]);if(d-today<=diff7&&d>=today)schedeExp++;}});
  });
  document.getElementById('stat_pay_ok').textContent=payOk;
  document.getElementById('stat_schede_exp').textContent=schedeExp;
  document.getElementById('stat_pay_overdue').textContent=payOverdue;
  const list=document.getElementById('home_clients_list');
  if(!DB.clients.length){list.innerHTML='<div class="empty-state"><div class="es-icon">👤</div><p>Nessun cliente</p></div>';return;}
  list.innerHTML=DB.clients.slice(-8).reverse().map((c,i)=>{
    const ri=DB.clients.length-1-i;
    const initials=((c.nome||'?')[0]+(c.cognome||'')[0]).toUpperCase();
    const imc=(c.isak&&c.isak.peso&&c.isak.statura)?(c.isak.peso/((c.isak.statura/100)**2)).toFixed(1):'—';
    let bc='nb',bt=c.isak?'ISAK ✓':'No misure';
    if(c.scad_pag){const d=new Date(c.scad_pag),diff=Math.ceil((d-new Date())/86400000);if(diff<0){bc='wb';bt='Pag. scaduto';}else if(diff<=7){bc='wb';bt='Scade presto';}}
    if(c.isak)bc='ab';
    return`<div class="client-row-home" onclick="showPage('clienti');selectClient(${ri})">
      <div class="cr-avatar" style="background:${avatarColor(ri)}">${initials}</div>
      <div><div class="cr-name">${c.nome||''} ${c.cognome||''}</div><div class="cr-info">${c.sport||'—'} · IMC ${imc}</div></div>
      <div class="cr-badge ${bc}">${bt}</div>
    </div>`;
  }).join('');
}
function avatarColor(i){return['#e03a3e','#4a9eff','#2ecc71','#f4c430','#9b59b6','#e87a3a','#1abc9c'][i%7]}

// ═══════════════════════════ CLIENTS ═══════════════════════════
function renderSidebar(filter=''){
  const list=document.getElementById('clients_sidebar_list');
  const f=filter.toLowerCase();
  if(!DB.clients.length){list.innerHTML='<div style="padding:16px 13px;font-family:\'Inter\',sans-serif;font-size:9.5px;color:var(--text-muted);letter-spacing:2px;text-transform:uppercase">Nessun cliente</div>';return;}
  const today=new Date();today.setHours(0,0,0,0);
  list.innerHTML=DB.clients.map((c,i)=>{
    if(f&&!(`${c.nome} ${c.cognome}`.toLowerCase().includes(f)))return'';
    const initials=((c.nome||'?')[0]+(c.cognome||'')[0]).toUpperCase();
    let dotColor='#333';
    if(c.scad_pag){const d=new Date(c.scad_pag),diff=Math.ceil((d-today)/86400000);dotColor=diff<0?'#e03a3e':diff<=7?'#f4c430':'#2ecc71';}
    return`<div class="client-item ${currentClientIdx===i?'selected':''}" onclick="selectClient(${i})">
      <div class="ci-avatar" style="background:${avatarColor(i)}">${initials}</div>
      <div class="ci-info"><div class="ci-name">${c.nome||''} ${c.cognome||''}</div><div class="ci-sub">${c.sport||'—'}${c.citta?` · ${c.citta}${c.provincia?' ('+c.provincia.toUpperCase()+')':''}`:''}</div></div>
      <div class="ci-exp" style="background:${dotColor}"></div>
    </div>`;
  }).join('');
}
function filterClients(val){renderSidebar(val)}
function showDeleteClientModal(){
  if(currentClientIdx===null)return;
  const c=DB.clients[currentClientIdx];
  const name=(`${c.nome||''} ${c.cognome||''}`).trim()||'Nuovo Cliente';
  document.getElementById('del_client_name').textContent=name;
  const fotos=c.foto||[];
  const totalKb=fotos.reduce((s,f)=>s+(f.sizeKb||0),0);
  const infoEl=document.getElementById('del_foto_info');
  if(fotos.length){
    infoEl.style.display='block';
    infoEl.textContent=`📸 ${fotos.length} foto · circa ${totalKb>1024?Math.round(totalKb/1024)+' MB':totalKb+' KB'} in localStorage`;
  }else{
    infoEl.style.display='none';
  }
  document.getElementById('modal_delete_client').style.display='flex';
}
function closeDeleteClientModal(){document.getElementById('modal_delete_client').style.display='none';}
function deleteClient(keepFotos){
  if(currentClientIdx===null)return;
  const c=DB.clients[currentClientIdx];
  const name=(`${c.nome||''} ${c.cognome||''}`).trim()||'Cliente';
  if(keepFotos&&c.foto&&c.foto.length){
    // Sposta le foto in un archivio separato per non perderle
    if(!DB.archivedFotos)DB.archivedFotos=[];
    DB.archivedFotos.push({clientName:name,foto:c.foto,archivedAt:new Date().toISOString().split('T')[0]});
  }
  DB.clients.splice(currentClientIdx,1);
  currentClientIdx=null;
  saveStore(DB);
  closeDeleteClientModal();
  document.getElementById('detail_empty').style.display='flex';
  document.getElementById('detail_content').style.display='none';
  renderSidebar();
  updateHomeDashboard();
  flashSave(keepFotos?`✓ ${name} eliminato — foto archiviate`:`✓ ${name} eliminato`);
}
function newClient(){
  DB.clients.push({nome:'',cognome:'',dob:'',sesso:'',email:'',tel:'',citta:'',provincia:'',sport:'',attivita:'',obiettivo:'',patologie:'',integratori:'',scad_all:'',scad_diet:'',scad_pag:'',isak:null,workout:null,diet:null,payments:[],notes:'',foto:[]});
  saveStore(DB);currentClientIdx=DB.clients.length-1;renderSidebar();loadClientDetail(currentClientIdx);
}
function selectClient(idx){currentClientIdx=idx;renderSidebar();loadClientDetail(idx);}

function loadClientDetail(idx){
  const c=DB.clients[idx];
  document.getElementById('detail_empty').style.display='none';
  document.getElementById('detail_content').style.display='block';
  document.getElementById('sb_client_name').textContent=`${c.nome||'?'} ${c.cognome||''}`.trim()||'Nuovo Cliente';
  ['nome','cognome','dob','sesso','email','tel','citta','provincia','sport','attivita','obiettivo','patologie','integratori','scad_all','scad_diet','scad_pag'].forEach(f=>{const el=document.getElementById('cl_'+f);if(el)el.value=c[f]||'';});
  updateClientHeader();updateScadenze();
  const isak=c.isak||{};
  ['peso','statura','statura_sed','apertura','p_triceps','p_sott','p_biceps','p_cresta','p_sopra','p_add','p_coscia','p_gamba','c_br_ril','c_br_fl','c_vita','c_fianchi','c_coscia','c_gamba','d_omero','d_bist','d_femore','mg_kg','t_adiposo','t_musc','t_osseo','fc','p_sist','p_diast','acqua'].forEach(f=>{const el=document.getElementById(f);if(el)el.value=isak[f]!==undefined?isak[f]:'';});
  document.getElementById('isak_data').value=isak.data||new Date().toISOString().split('T')[0];
  document.getElementById('isak_num').value=isak.num||1;
  computeISAK();
  // Sync campi MSJ da ISAK + anagrafica
  const msjPeso=document.getElementById('msj_peso');
  const msjAlt=document.getElementById('msj_altezza');
  const msjEta=document.getElementById('msj_eta');
  const msjSesso=document.getElementById('msj_sesso');
  if(msjPeso)msjPeso.value=c.msj?.peso||isak.peso||'';
  if(msjAlt)msjAlt.value=c.msj?.altezza||isak.statura||'';
  if(msjSesso)msjSesso.value=c.sesso||'';
  if(msjEta&&c.msj?.eta){msjEta.value=c.msj.eta;}
  else if(msjEta&&c.dob){const age=Math.floor((new Date()-new Date(c.dob))/31557600000);if(age>0)msjEta.value=age;}
  else if(msjEta)msjEta.value='';
  computeMSJ();
  loadWorkout(c.workout);
  loadDiet(c.diet);
  renderPayments();
  document.getElementById('cl_note_text').value=c.notes||'';
  renderFotoGallery();
}
function updateClientHeader(){
  const n=document.getElementById('cl_nome').value||'',cg=document.getElementById('cl_cognome').value||'';
  document.getElementById('det_nome_title').textContent=(n+' '+cg).trim()||'Nuovo Cliente';
  document.getElementById('sb_client_name').textContent=(n+' '+cg).trim()||'Nuovo Cliente';
}

// ══ SAVE UNIFICATO ══
function saveAllClientData(){
  if(currentClientIdx===null)return;
  const c=DB.clients[currentClientIdx];
  // Anagrafica
  ['nome','cognome','dob','sesso','email','tel','citta','provincia','sport','attivita','obiettivo','patologie','integratori','scad_all','scad_diet','scad_pag'].forEach(f=>{const el=document.getElementById('cl_'+f);if(el)c[f]=el.value;});
  // ISAK
  const isakFields=['peso','statura','statura_sed','apertura','p_triceps','p_sott','p_biceps','p_cresta','p_sopra','p_add','p_coscia','p_gamba','c_br_ril','c_br_fl','c_vita','c_fianchi','c_coscia','c_gamba','d_omero','d_bist','d_femore','mg_kg','t_adiposo','t_musc','t_osseo','fc','p_sist','p_diast','acqua'];
  c.isak=c.isak||{};
  isakFields.forEach(f=>{const el=document.getElementById(f);if(el)c.isak[f]=el.value?parseFloat(el.value):null;});
  c.isak.data=document.getElementById('isak_data').value;c.isak.num=document.getElementById('isak_num').value;
  // Workout — salva tutti i giorni
  saveCurrentWkDay();
  const wkScad=document.getElementById('wk_scad').value;
  c.workout={freq:document.getElementById('wk_freq').value,days:JSON.parse(JSON.stringify(workoutDays)),scad:wkScad};
  if(wkScad)c.scad_all=wkScad;
  // Dieta
  const dietScad=document.getElementById('diet_scad').value;
  c.diet={nome:document.getElementById('diet_nome').value,kcal_target:document.getElementById('diet_kcal_target').value,durata:document.getElementById('diet_durata').value,note:document.getElementById('diet_note').value,week:JSON.parse(JSON.stringify(dietWeek)),scad:dietScad};
  if(dietScad)c.scad_diet=dietScad;
  // Note
  c.notes=document.getElementById('cl_note_text').value;
  // MSJ campi custom (se modificati manualmente)
  c.msj={peso:document.getElementById('msj_peso')?.value||'',altezza:document.getElementById('msj_altezza')?.value||'',eta:document.getElementById('msj_eta')?.value||''};
  saveStore(DB);renderSidebar();updateHomeDashboard();
  flashSave('✓ Scheda '+((c.nome||'')+' '+(c.cognome||'')).trim()+' salvata!');
}

function updateScadenze(){
  const today=new Date();today.setHours(0,0,0,0);
  function setScad(key,cid,did,dyid){
    const val=document.getElementById('cl_'+key)?.value;
    const card=document.getElementById(cid);const dateEl=document.getElementById(did);const daysEl=document.getElementById(dyid);
    if(!val){card.className='scad-card';dateEl.textContent='—';daysEl.textContent='Non impostata';daysEl.style.color='var(--text-muted)';return;}
    const d=new Date(val),diff=Math.ceil((d-today)/86400000),parts=val.split('-');
    dateEl.textContent=`${parts[2]}/${parts[1]}/${parts[0]}`;
    if(diff<0){card.className='scad-card crit';daysEl.textContent=`Scaduta ${Math.abs(diff)} giorni fa`;daysEl.style.color='var(--accent)';}
    else if(diff<=7){card.className='scad-card warn';daysEl.textContent=`Scade tra ${diff} giorni`;daysEl.style.color='var(--yellow)';}
    else{card.className='scad-card ok';daysEl.textContent=`Tra ${diff} giorni`;daysEl.style.color='var(--green)';}
  }
  setScad('scad_all','scad_allenamento_card','scad_allenamento','scad_allenamento_days');
  setScad('scad_diet','scad_dieta_card','scad_dieta','scad_dieta_days');
  setScad('scad_pag','scad_pag_card','scad_pag','scad_pag_days');
}

function showDtab(id){
  document.querySelectorAll('.dtab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.detail-body').forEach(b=>b.classList.add('hidden'));
  document.getElementById('dtab-'+id).classList.remove('hidden');
  document.querySelectorAll('.dtab').forEach(t=>{if(t.getAttribute('onclick')===`showDtab('${id}')`)t.classList.add('active');});
  if(id==='pagamenti')renderPayments();
}

function flashSave(msg,isErr=false){
  const div=document.createElement('div');
  div.style.cssText=`position:fixed;bottom:20px;right:20px;background:${isErr?'var(--accent)':'var(--green)'};color:#000;font-family:'Bebas Neue',sans-serif;font-size:12.5px;letter-spacing:2px;padding:8px 16px;z-index:9999;animation:fadeUp .2s;box-shadow:0 4px 18px rgba(0,0,0,0.4)`;
  div.textContent=msg;document.body.appendChild(div);setTimeout(()=>div.remove(),2400);
}
function showGcalToast(msg){
  const div=document.createElement('div');div.className='gcal-toast';
  div.innerHTML=`<span class="gt-icon">📅</span>${msg}`;document.body.appendChild(div);setTimeout(()=>div.remove(),3000);
}


function updateApptClientDropdown(){
  const sel=document.getElementById('appt_client');if(!sel)return;
  const cur=sel.value;sel.innerHTML='<option value="">— Seleziona cliente —</option>'+DB.clients.map((c,i)=>`<option value="${i}">${c.nome||''} ${c.cognome||''}</option>`).join('');sel.value=cur;
}

// ═══════════════════════════ CALENDAR UI ═══════════════════════════
function changeMonth(dir){calMonth+=dir;if(calMonth>11){calMonth=0;calYear++;}if(calMonth<0){calMonth=11;calYear--;}renderCalendar();}
function renderCalendar(){
  document.getElementById('cal_month_label').textContent=MONTHS_IT[calMonth]+' '+calYear;
  updateApptClientDropdown();
  const today=new Date(),firstDay=new Date(calYear,calMonth,1);
  let startDow=firstDay.getDay();if(startDow===0)startDow=7;
  const daysInMonth=new Date(calYear,calMonth+1,0).getDate(),prevDays=new Date(calYear,calMonth,0).getDate();
  const grid=document.getElementById('cal_days');
  grid.querySelectorAll('.cal-day').forEach(el=>el.remove());
  let html='';
  for(let d=startDow-1;d>=1;d--)html+=`<div class="cal-day other-month"><div class="cal-dn" style="opacity:0.22">${prevDays-d+1}</div></div>`;
  for(let d=1;d<=daysInMonth;d++){
    const ds=`${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const isToday=today.getFullYear()===calYear&&today.getMonth()===calMonth&&today.getDate()===d;
    const isSel=calSelectedDate===ds;const events=DB.appointments[ds]||[];
    const evHtml=events.slice(0,2).map(ev=>`<div class="cal-event ${ev.type||'other'}">${ev.time} ${ev.clientName||''}</div>`).join('');
    html+=`<div class="cal-day ${isToday?'today':''} ${isSel?'selected':''} ${events.length?'has-events':''}" onclick="selectDay('${ds}')"><div class="cal-dn">${d}</div>${evHtml}</div>`;
  }
  const total=Math.ceil((startDow-1+daysInMonth)/7)*7,next=total-(startDow-1+daysInMonth);
  for(let d=1;d<=next;d++)html+=`<div class="cal-day other-month"><div class="cal-dn" style="opacity:0.22">${d}</div></div>`;
  grid.insertAdjacentHTML('beforeend',html);
  if(calSelectedDate)renderDayDetail(calSelectedDate);
}
function selectDay(ds){calSelectedDate=ds;renderCalendar();renderDayDetail(ds);}
function renderDayDetail(ds){
  const[y,m,d]=ds.split('-');
  document.getElementById('cal_selected_label').textContent=`${parseInt(d)} ${MONTHS_IT[parseInt(m)-1]} ${y}`;
  const events=DB.appointments[ds]||[];const list=document.getElementById('cal_events_list');
  if(!events.length){list.innerHTML='<div style="font-family:\'Inter\',sans-serif;font-size:9.5px;color:var(--text-muted);letter-spacing:2px;text-transform:uppercase;padding:5px 0">Nessun appuntamento</div>';return;}
  list.innerHTML=events.map((ev,i)=>`<div class="cal-event-item"><div class="ce-bar ${ev.type||'other'}"></div><div class="ce-content"><div class="ce-time">${ev.time}</div><div class="ce-title">${APPT_TYPE_LABELS[ev.type]||ev.type} ${ev.note?'· '+ev.note:''}</div><div class="ce-client">${ev.clientName||'—'} · ${ev.dur||60} min${ev.location?' · '+ev.location:''}</div></div><button class="cal-del-ev" onclick="deleteAppt('${ds}',${i})">X</button></div>`).join('');
}


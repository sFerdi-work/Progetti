// workoutDays: array di giorni, ciascuno con {label, groups}
let workoutDays=[];
let activeWkDay=0;
let pendingTemplate=null;
// workoutGroups è sempre un riferimento ai gruppi del giorno attivo
function getWkGroups(){return workoutDays[activeWkDay]?.groups||[];}
function setWkGroups(g){if(workoutDays[activeWkDay])workoutDays[activeWkDay].groups=g;}
function initWkDayTabs(){
  const tabs=document.getElementById('wk_day_tabs');if(!tabs)return;
  tabs.innerHTML=workoutDays.map((d,i)=>`<div class="day-tab ${i===activeWkDay?'active':''} ${d.groups.some(g=>g.exercises.length)?'has-data':''}" onclick="selectWkDay(${i})">${d.label}</div>`).join('')
  +`<div class="day-tab" onclick="addWorkoutDay()" style="border-style:dashed;opacity:0.5">+</div>`;
}
function selectWkDay(i){
  saveCurrentWkDay();
  activeWkDay=i;
  const d=workoutDays[i];
  document.getElementById('wk_nome').value=d.nome||'';
  document.getElementById('wk_tipo').value=d.tipo||'Full Body';
  document.getElementById('wk_warm').value=d.warm||'';
  document.getElementById('wk_dur').value=d.dur||'';
  document.getElementById('wk_rec').value=d.rec||'';
  document.getElementById('wk_note').value=d.note||'';
  initWkDayTabs();renderWorkout();
}
function saveCurrentWkDay(){
  if(!workoutDays[activeWkDay])return;
  workoutDays[activeWkDay].nome=document.getElementById('wk_nome')?.value||'';
  workoutDays[activeWkDay].tipo=document.getElementById('wk_tipo')?.value||'';
  workoutDays[activeWkDay].warm=document.getElementById('wk_warm')?.value||'';
  workoutDays[activeWkDay].dur=document.getElementById('wk_dur')?.value||'';
  workoutDays[activeWkDay].rec=document.getElementById('wk_rec')?.value||'';
  workoutDays[activeWkDay].note=document.getElementById('wk_note')?.value||'';
}
function syncWkDayName(){
  if(workoutDays[activeWkDay])workoutDays[activeWkDay].nome=document.getElementById('wk_nome').value;
  initWkDayTabs();
}
function addWorkoutDay(){
  saveCurrentWkDay();
  const labels=['A','B','C','D','E','F','G'];
  const label=labels[workoutDays.length]||'+'+(workoutDays.length+1);
  workoutDays.push({label,nome:'Giorno '+label,tipo:'Full Body',warm:'10',dur:'60',rec:'90',note:'',groups:[]});
  activeWkDay=workoutDays.length-1;
  selectWkDay(activeWkDay);
}
function removeWkDay(i){
  if(workoutDays.length<=1){flashSave('Almeno un giorno richiesto',true);return;}
  workoutDays.splice(i,1);
  activeWkDay=Math.min(activeWkDay,workoutDays.length-1);
  selectWkDay(activeWkDay);
}
function confirmLoadTemplate(key){
  pendingTemplate=key;const tpl=WORKOUT_TEMPLATES[key];
  document.getElementById('modal_tpl_title').textContent='Carica: '+tpl.nome;
  document.getElementById('modal_tpl_desc').textContent='Genera giorni distinti automaticamente per questo template. Il piano attuale verrà sostituito.';
  document.getElementById('modal_template').style.display='flex';
}
function closeTemplateModal(){document.getElementById('modal_template').style.display='none';pendingTemplate=null;}
function applyTemplate(){
  if(!pendingTemplate)return;
  const tpl=WORKOUT_TEMPLATES[pendingTemplate];
  workoutDays=buildWorkoutDaysFromTemplate(tpl);
  activeWkDay=0;
  document.getElementById('wk_freq').value=tpl.freq||'3x/settimana';
  selectWkDay(0);
  closeTemplateModal();flashSave('Template caricato con giorni separati!');
}

// Costruisce giorni distinti da un template: ogni gruppo diventa un giorno separato
function buildWorkoutDaysFromTemplate(tpl){
  const labels=['A','B','C','D','E','F'];
  return tpl.groups.map((g,i)=>({
    label:labels[i]||String(i+1),
    nome:`Giorno ${labels[i]||i+1} – ${g.name}`,
    tipo:tpl.tipo||'Full Body',
    warm:tpl.warm,dur:tpl.dur,rec:tpl.rec,
    note:tpl.note,
    groups:[JSON.parse(JSON.stringify(g))]
  }));
}

function loadWorkout(wk){
  if(wk&&wk.days&&Array.isArray(wk.days)&&wk.days.length){
    workoutDays=JSON.parse(JSON.stringify(wk.days));
    document.getElementById('wk_freq').value=wk.freq||'3x/settimana';
  }else if(wk&&wk.groups&&wk.groups.length){
    const labels=['A','B','C','D','E','F'];
    workoutDays=wk.groups.map((g,i)=>({
      label:labels[i]||String(i+1),
      nome:`Giorno ${labels[i]||i+1} – ${g.name}`,
      tipo:wk.tipo||'Full Body',
      warm:wk.warm,dur:wk.dur,rec:wk.rec,
      note:wk.note||'',
      groups:[JSON.parse(JSON.stringify(g))]
    }));
    document.getElementById('wk_freq').value=wk.freq||'3x/settimana';
  }else{
    workoutDays=[{label:'A',nome:'Giorno A',tipo:'Full Body',warm:'10',dur:'60',rec:'90',note:'',groups:[]}];
  }
  document.getElementById('wk_scad').value=wk?.scad||'';
  const exSearch=document.getElementById('ex_library_search');if(exSearch)exSearch.value='';
  activeWkDay=0;
  selectWkDay(0);
  renderLibrary();
}
function syncScadFromWorkout(){
  const v=document.getElementById('wk_scad').value;
  if(v){document.getElementById('cl_scad_all').value=v;updateScadenze();}
}
function syncScadFromDiet(){
  const v=document.getElementById('diet_scad').value;
  if(v){document.getElementById('cl_scad_diet').value=v;updateScadenze();}
}

// ═══════════════════════════ FOTO ═══════════════════════════
let fotoSelectorMode='prima'; // 'prima' o 'dopo'
function getCurrentClientFoto(){
  if(currentClientIdx===null)return[];
  return DB.clients[currentClientIdx].foto||[];
}
function handleFotoUpload(input){
  if(currentClientIdx===null){flashSave('Seleziona prima un cliente',true);return;}
  const files=Array.from(input.files);
  if(!files.length)return;
  let processed=0;
  files.forEach(file=>{
    const reader=new FileReader();
    reader.onload=function(e){
      const img=new Image();
      img.onload=function(){
        // Resize: max 1200px largo mantenendo ratio, qualità 0.75 → drastica riduzione kb
        const MAX=1200;
        let w=img.width,h=img.height;
        if(w>MAX){h=Math.round(h*MAX/w);w=MAX;}
        const canvas=document.createElement('canvas');canvas.width=w;canvas.height=h;
        const ctx=canvas.getContext('2d');ctx.drawImage(img,0,0,w,h);
        const dataUrl=canvas.toDataURL('image/jpeg',0.75);
        const sizeKb=Math.round(dataUrl.length*0.75/1024);
        const entry={
          id:Date.now()+'_'+Math.random().toString(36).substr(2,5),
          data:dataUrl,
          date:new Date().toISOString().split('T')[0],
          nome:file.name,
          sizeKb,
          w,h
        };
        if(!DB.clients[currentClientIdx].foto)DB.clients[currentClientIdx].foto=[];
        DB.clients[currentClientIdx].foto.push(entry);
        processed++;
        if(processed===files.length){
          saveStore(DB);renderFotoGallery();
          flashSave(`✓ ${processed} foto caricate`);
        }
      };
      img.src=e.target.result;
    };
    reader.readAsDataURL(file);
  });
  input.value='';
}
function renderFotoGallery(){
  if(currentClientIdx===null)return;
  const fotos=getCurrentClientFoto();
  const gallery=document.getElementById('foto_gallery');
  const compArea=document.getElementById('foto_comparison_area');
  const badge=document.getElementById('foto_count_badge');
  badge.textContent=fotos.length?`(${fotos.length})` :'';
  if(!fotos.length){
    gallery.innerHTML='<div class="empty-state" style="grid-column:1/-1;padding:30px"><div class="es-icon">📷</div><p>Nessuna foto. Caricane una con il tasto ↑</p></div>';
    compArea.style.display='none';
    return;
  }
  // Confronto: prima = la più vecchia, dopo = la più recente
  const sorted=[...fotos].sort((a,b)=>a.date.localeCompare(b.date));
  const primaF=sorted[0],dopoF=sorted[sorted.length-1];
  compArea.style.display='block';
  document.getElementById('foto_img_prima').src=primaF.data;
  document.getElementById('foto_date_prima').textContent=fmtDate(primaF.date);
  document.getElementById('foto_label_prima').textContent=`— ${fmtDate(primaF.date)} · ${primaF.sizeKb}KB`;
  if(sorted.length>1){
    document.getElementById('foto_img_dopo').src=dopoF.data;
    document.getElementById('foto_date_dopo').textContent=fmtDate(dopoF.date);
    document.getElementById('foto_label_dopo').textContent=`— ${fmtDate(dopoF.date)} · ${dopoF.sizeKb}KB`;
  }else{
    document.getElementById('foto_img_dopo').src='';
    document.getElementById('foto_date_dopo').textContent='';
    document.getElementById('foto_label_dopo').textContent='— ancora nessuna foto successiva';
  }
  gallery.innerHTML=fotos.map((f,i)=>`
    <div style="position:relative;background:var(--grey-dark);border:1px solid var(--grey-line);overflow:hidden;cursor:pointer" onclick="enlargeFoto('${f.id}')">
      <img src="${f.data}" style="width:100%;aspect-ratio:1;object-fit:cover;display:block">
      <div style="padding:5px 7px 4px;background:rgba(0,0,0,0.55)">
        <div style="font-family:'Inter',sans-serif;font-size:8.5px;color:#bbb;letter-spacing:1px">${fmtDate(f.date)}</div>
        <div style="font-family:'Inter',sans-serif;font-size:7.5px;color:var(--text-muted)">${f.sizeKb}KB · ${f.w}×${f.h}</div>
      </div>
      <button onclick="event.stopPropagation();deleteFoto('${f.id}')" style="position:absolute;top:4px;right:4px;background:rgba(224,58,62,0.8);border:none;color:#fff;font-size:10px;width:20px;height:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif">X</button>
    </div>`).join('');
}
function fmtDate(iso){if(!iso)return'—';const p=iso.split('-');return`${p[2]}/${p[1]}/${p[0]}`;}
function deleteFoto(id){
  if(!confirm('Eliminare questa foto?'))return;
  if(currentClientIdx===null)return;
  DB.clients[currentClientIdx].foto=(DB.clients[currentClientIdx].foto||[]).filter(f=>f.id!==id);
  saveStore(DB);renderFotoGallery();
}
function enlargeFoto(id){
  const f=(getCurrentClientFoto()).find(x=>x.id===id);
  if(!f)return;
  const ov=document.createElement('div');
  ov.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,0.9);z-index:900;display:flex;align-items:center;justify-content:center;cursor:pointer';
  ov.innerHTML=`<img src="${f.data}" style="max-width:92vw;max-height:90vh;object-fit:contain"><div style="position:absolute;top:14px;right:18px;color:#fff;font-family:\'Bebas Neue\',sans-serif;font-size:16px;letter-spacing:2px;cursor:pointer" onclick="this.parentNode.remove()">✕ CHIUDI</div>`;
  ov.onclick=()=>ov.remove();
  document.body.appendChild(ov);
}
function openFotoSelector(mode){
  fotoSelectorMode=mode;
  document.getElementById('foto_selector_title').textContent=mode==='prima'?'Scegli foto — PRIMA':'Scegli foto — DOPO';
  const fotos=getCurrentClientFoto();
  const grid=document.getElementById('foto_selector_grid');
  grid.innerHTML=fotos.map(f=>`<div style="cursor:pointer;border:2px solid transparent;transition:border-color .15s" onclick="applyFotoSelector('${f.id}')" onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='transparent'">
    <img src="${f.data}" style="width:100%;aspect-ratio:1;object-fit:cover;display:block">
    <div style="padding:3px 5px;background:var(--grey-dark);font-family:'Inter',sans-serif;font-size:8px;color:#bbb">${fmtDate(f.date)} · ${f.sizeKb}KB</div>
  </div>`).join('');
  document.getElementById('foto_selector_modal').style.display='flex';
}
function applyFotoSelector(id){
  const f=(getCurrentClientFoto()).find(x=>x.id===id);
  if(!f)return;
  if(fotoSelectorMode==='prima'){
    document.getElementById('foto_img_prima').src=f.data;
    document.getElementById('foto_date_prima').textContent=fmtDate(f.date);
    document.getElementById('foto_label_prima').textContent=`— ${fmtDate(f.date)} · ${f.sizeKb}KB`;
  }else{
    document.getElementById('foto_img_dopo').src=f.data;
    document.getElementById('foto_date_dopo').textContent=fmtDate(f.date);
    document.getElementById('foto_label_dopo').textContent=`— ${fmtDate(f.date)} · ${f.sizeKb}KB`;
  }
  closeFotoSelector();
}
function closeFotoSelector(){document.getElementById('foto_selector_modal').style.display='none';}


function renderWorkout(){
  const groups=getWkGroups();
  const container=document.getElementById('workout_groups');
  if(!groups.length){container.innerHTML='<div class="empty-state" style="padding:22px"><div class="es-icon">💪</div><p>Usa un template o aggiungi esercizi</p></div>';return;}
  container.innerHTML=groups.map((g,gi)=>`<div style="margin-bottom:8px"><div class="group-header"><input class="ex-input exname" value="${g.name}" style="font-family:'Bebas Neue',sans-serif;font-size:13px;letter-spacing:2px;color:var(--text-soft);background:transparent;border:none;border-bottom:1px solid rgba(255,255,255,0.07);outline:none;flex:1" onchange="getWkGroups()[${gi}].name=this.value"><button class="ex-del" onclick="removeGroup(${gi})">Gruppo</button></div><table class="ex-table" style="width:100%"><thead><tr><th style="width:28%">Esercizio</th><th style="width:13%">Serie×Reps</th><th style="width:9%">Kg</th><th style="width:9%">Recup.</th><th style="width:8%">RPE</th><th style="width:28%">Note</th><th style="width:5%"></th></tr></thead><tbody>${g.exercises.map((ex,ei)=>`<tr><td><input class="ex-input exname" value="${ex.name}" onchange="getWkGroups()[${gi}].exercises[${ei}].name=this.value" style="width:100%"></td><td><input class="ex-input exnum" value="${ex.reps}" onchange="getWkGroups()[${gi}].exercises[${ei}].reps=this.value" style="width:85px"></td><td><input class="ex-input exnum" value="${ex.kg}" onchange="getWkGroups()[${gi}].exercises[${ei}].kg=this.value" style="width:60px"></td><td><input class="ex-input exnum" value="${ex.rest||'90s'}" onchange="getWkGroups()[${gi}].exercises[${ei}].rest=this.value" style="width:60px"></td><td><input class="ex-input exnum" value="${ex.rpe||'7'}" onchange="getWkGroups()[${gi}].exercises[${ei}].rpe=this.value" style="width:50px"></td><td><input class="ex-input exnote" value="${ex.note||''}" onchange="getWkGroups()[${gi}].exercises[${ei}].note=this.value" style="width:100%"></td><td><button class="ex-del" onclick="removeExercise(${gi},${ei})">X</button></td></tr>`).join('')}</tbody></table><button class="btn-add-ex" onclick="addExerciseToGroup(${gi})">+ Esercizio</button></div>`).join('');
}
function renderLibrary(filter=''){const lib=document.getElementById('exercise_library');const f=(filter||'').toLowerCase().trim();if(!f){lib.innerHTML='';return;}const FULL=getFullExerciseLib();lib.innerHTML=Object.entries(FULL).map(([group,exs])=>{const filtered=exs.filter(ex=>ex.name.toLowerCase().includes(f)||group.toLowerCase().includes(f));if(!filtered.length)return'';return`<div style="margin-bottom:5px"><span style="font-family:'Inter',sans-serif;font-size:7.5px;letter-spacing:3px;color:var(--text-muted);text-transform:uppercase;display:inline-block;margin-right:4px">${group}</span>${filtered.map(ex=>`<span class="muscle-badge${ex._custom?' custom-ex':''}" onclick="quickAddEx('${group}','${ex.name.replace(/'/g,"\\'")}','${ex.reps}','${ex.kg}','${(ex.note||'').replace(/'/g,"\\'")}')">${ex._custom?'★ ':'+ '}${ex.name}</span>`).join('')}</div>`;}).join('');}
function addGroup(){const g=getWkGroups();g.push({name:'NUOVO GRUPPO',exercises:[]});setWkGroups(g);renderWorkout();}
function removeGroup(gi){const g=getWkGroups();g.splice(gi,1);setWkGroups(g);renderWorkout();}
function addExerciseToGroup(gi){getWkGroups()[gi].exercises.push({name:'',reps:'3×10',kg:'—',rest:'90s',rpe:'7',note:''});renderWorkout();}
function addFreeExercise(){const g=getWkGroups();if(!g.length)addGroup();else addExerciseToGroup(g.length-1);}
function removeExercise(gi,ei){getWkGroups()[gi].exercises.splice(ei,1);renderWorkout();}
function quickAddEx(group,name,reps,kg,note){const g=getWkGroups();let gi=g.findIndex(x=>x.name.toUpperCase()===group.toUpperCase());if(gi===-1){g.push({name:group.toUpperCase(),exercises:[]});gi=g.length-1;}g[gi].exercises.push({name,reps,kg,rest:'90s',rpe:'7',note});setWkGroups(g);renderWorkout();}


